LD_NETCDF ?= `pkg-config netcdf-fortran --libs`
LD_MSCL   ?= `pkg-config mscl --libs`
LD_NAG    ?= `pkg-config nag --libs`
LD_SONNET ?= -L${SOLPSLIB} -lsonnet -lstdc++
NODENAME  ?= `hostname`

CPP = /lib/cpp -traditional

FC ?= gfortran
ifndef SOLPS_DEBUG
FCOPTS  += -fdefault-real-8
endif

SOLPSINCLUDE += `pkg-config libtirpc --cflags`
LDLIBES  = `pkg-config libtirpc --libs`

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:


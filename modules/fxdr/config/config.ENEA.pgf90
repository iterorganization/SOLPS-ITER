#  VERSION : 09.05.95 17:03

# File compiler.macro for IBM xlf

ifndef SOLPSLIB
  $(error SOLPSLIB not defined)
endif

FC       = pgf90

ifdef SOLPS_DEBUG
FFLAGS   = -g -C
else
FFLAGS   = -O
endif

INCLUDE  = -Isrc
COMPILE  = ${FC} -c ${FFLAGS}
CPP      = /lib/cpp -C -traditional

LDLIBS   = -L${SOLPSLIB} -lsonnet ${LD_MSCL} -L/usr/local/lib
LDEXTRA  = 

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

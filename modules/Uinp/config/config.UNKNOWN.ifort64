# File compiler.macro for Fujitsu frt

# Test whether necessary variables are defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif


FC	 = ifort
FFLAGS	 = -g
INCLUDE  = -I${SRCDIR} -I${EIRINC} -I${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP	 = /lib/cpp -C -traditional

MOD 	 = mod
LDLIBS	 = ${LD_MSCL}

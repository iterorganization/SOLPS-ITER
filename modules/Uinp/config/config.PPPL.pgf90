# Test whether necessary variables are defined
ifndef LD_MSCL
  MSCL_ROOT ?= /p/solps/solps_other/mscl/linux_pgf90
  LD_MSCL   ?= -L${MSCL_ROOT} -lmscl
endif

FC       = pgf90

ifdef SOLPS_DEBUG
FFLAGS  += -g
else
FFLAGS  += -O
endif
ifdef SOLPS_OPENMP
FFLAGS  += -mp=nonuma
endif

INCLUDE  = -I${SRCDIR} ${EIRINC} ${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP      = /lib/cpp -traditional
MOD      = mod

LDLIBS   = ${LD_MSCL}
#LDLIBS  = ${LD_MSCL} -L${EIROBJ} -leirene
LDEXTRA  = 
ifdef USE_MPI
LDLIBS  += ${LD_MPI}
endif

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:


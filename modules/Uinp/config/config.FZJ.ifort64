# Test whether necessary variables are defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

MPI_FC  ?= mpif90
ifdef SOLPS_MPI
 FC      = ${MPI_FC}
 COMPILER_TYPE = $(shell ${FC} --version | head -1 | cut -d ' ' -f 1)
 ifeq (${COMPILER_TYPE},GNU)
  COMPILER_REDEF = yes
 endif
endif

ifdef SOLPS_DEBUG
FFLAGS  += -g -C -traceback -debug all -check all
endif

CPP      = /lib/cpp -C -traditional -ffreestanding


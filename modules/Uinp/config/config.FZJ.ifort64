# Test whether necessary variables are defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

MPI_FC  ?= mpif90
ifdef USE_MPI
FC       = ${MPI_FC}
ifdef SOLPS_OPENMP
FFLAGS   = -fopenmp
endif
else
FC      ?= ifort
endif

ifdef SOLPS_DEBUG
FFLAGS  += -g -C -traceback -debug all -check all
endif

CPP      = /lib/cpp -C -traditional -ffreestanding


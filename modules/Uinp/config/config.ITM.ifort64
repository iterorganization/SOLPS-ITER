#  VERSION : 28.07.99 20:34

MSCL_ROOT ?= /pfs/work/dpc/SOLPS-ITER/mscl
LD_MSCL ?= -L${MSCL_ROOT} -lmscl

ifdef USE_MPI
FC 	 = mpiifort
else
FC	 = ifort
endif
ifdef SOLPS_DEBUG
FFLAGS	 = -g -C -traceback -debug all -check all
else
FFLAGS   =
endif
INCLUDE  = -I${SRCDIR} -I${EIRINC} -I${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP	 = /lib/cpp -C -traditional

MOD 	 = mod
LDLIBS	 = ${LD_MSCL}
LDEXTRA  =

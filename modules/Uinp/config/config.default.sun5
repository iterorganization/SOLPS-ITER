# Test whether necessary variables are defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

FC       = f90

ifdef SOLPS_DEBUG
FFLAGS   = -g
else
FFLAGS   = -O
endif

INCLUDE  = -I${SRCDIR} ${EIRINC} ${B2INC} ${CRRINC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP      = /usr/ccs/lib/cpp
MOD      = mod

LDLIBS   = ${LD_MSCL} ${LD_NAG}
LDEXTRA  =

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

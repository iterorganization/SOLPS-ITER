FC       = pgf90

ifdef SOLPS_DEBUG
FFLAGS   = -g
else
FFLAGS   = -O
endif
ifdef SOLPS_OPENMP
FFLAGS  += -mp=nonuma
endif

INCLUDE  = -I${SRCDIR} ${EIRINC} ${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}
MOD      = mod

LDLIBS  += ${LD_MSCL} ${LD_NAG}
LDEXTRA  =
ifdef USE_MPI
LDLIBS  += ${LD_MPI}
endif


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:


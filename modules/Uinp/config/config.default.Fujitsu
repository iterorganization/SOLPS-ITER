#  VERSION : 28.07.99 20:34

# Test whether necessary variables are defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

FC       = f95f
FFLAGS   = -Am -X9 -fw
ifdef SOLPS_DEBUG
FFLAGS  += -g -O0
else
FFLAGS  += Kfast,eval -x- -O
endif
INCLUDE  = -I${SRCDIR} ${EIRINC} ${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP      = /lib/cpp -C -traditional
MOD      = mod

LDLIBS   = ${LD_MSCL} ${LD_NAG}
LDEXTRA  =

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

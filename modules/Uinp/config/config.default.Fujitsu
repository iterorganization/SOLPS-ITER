#  VERSION : 28.07.99 20:34

# Test whether necessary variables are defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

FC	     = f95f
ifdef SOLPS_DEBUG
FFLAGS	 = -g -Am -X9 -O0 -fw
else
FFLAGS	 = -Am -X9 -fw -Kfast,eval -x- -O
endif
INCLUDE  = -I${SRCDIR} ${EIRINC} ${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP	     = /lib/cpp -C -traditional
MOD      = mod

LDLIBS 	 = ${LD_MSCL}
LDEXTRA  =


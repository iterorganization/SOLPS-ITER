#  VERSION : 28.07.99 20:34

# Test whether necessary variables are defined
ifndef LD_MSCL
  LD_MSCL ?= -L${SOLPSLIB} -lmscl
endif

FC       = g95
ifdef SOLPS_DEBUG
FFLAGS	 = -g -fbounds-check -ftrace=full
endif
INCLUDE  = -I${SRCDIR} ${EIRINC} ${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP      = /lib/cpp -C -traditional

MOD      = mod
LDLIBS	 = ${LD_MSCL}
LDEXTRA  =


# Test whether necessary variables are defined
MSCL_ROOT ?= /pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/mscl
LD_MSCL ?= -L${MSCL_ROOT}/lib -lmscl

MPI_FC  ?= mpif90
ifdef USE_MPI
FC       = ${MPI_FC}
endif

FFLAGS   = -fno-second-underscore -fno-unsafe-math-optimizations -frounding-math
ifdef SOLPS_DEBUG
FFLAGS  += -fbacktrace
endif

CPP      = /lib/cpp -traditional


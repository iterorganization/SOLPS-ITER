#  VERSION : 28.07.99 20:34
NODENAME ?= $(shell echo `hostname`)
LD_MSCL  ?= `pkg-config mscl --libs` -lgfortran
LD_MPI   ?= -Wl,-rpath,${MPDIR}/lib64

MPI_FC   ?= mpiifort
ifdef SOLPS_MPI
FC        = ${MPI_FC}
MPDIR    ?= ${EBROOTMPI}
endif

FFLAGS    = -fPIC -assume no2underscore
ifndef SOLPS_DEBUG
FFLAGS   += -O2
endif

CPP       = /lib/cpp -C -traditional -ffreestanding


# Test whether necessary variables are defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

MPI_FC  ?= mpif90
ifdef USE_MPI
FC       = ${MPI_FC}
else
FC       = nagfor
endif

ifdef SOLPS_DEBUG
FFLAGS   = -g
else
FFLAGS   = -O
endif

INCLUDE  = -I${SRCDIR} ${EIRINC} ${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP      = /lib/cpp -traditional
MOD      = mod

LDLIBS   = ${LD_MSCL} ${LD_NAG}
LDEXTRA  =
ifdef USE_MPI
LDLIBS  += ${LD_MPI}
endif

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:


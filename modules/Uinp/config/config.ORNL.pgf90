# Test whether necessary variables are defined
ifndef GR_ROOT
  $(error GR_ROOT not defined)
endif
ifndef GLI_HOME
  $(error GLI_HOME not defined)
endif
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif
LD_GR   ?= -L${GR_ROOT} -lgr
LD_GKS  ?= -L${GLI_HOME} -lgks

CPP      = /lib/cpp -traditional

LDLIBS   = ${LD_GR} ${LD_GKS} -lX11 -lXt


#  VERSION : 28.07.99 20:34

# File compiler.macro for Fujitsu frt

LD_MSCL ?= `pkg-config mscl --libs`

FC	     = gfortran
ifdef SOLPS_DEBUG
FFLAGS	 = -g
else
FFLAGS   =
endif
INCLUDE  = -I${SRCDIR} -I${EIRINC} -I${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP	     = /lib/cpp -traditional

MOD 	   = mod
LDLIBS	 = ${LD_MSCL}
LDEXTRA  =

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:


#  VERSION : 28.08.98 10:20

# File compiler.macro for HPUX FORTRAN compiler

# Test whether necessary variables are defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

FC       = f77
ifdef SOLPS_DEBUG
FFLAGS   = -g
endif
INCLUDE  = -I${SRCDIR} ${EIRINC} ${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP      = /lib/cpp

LDLIBS   = -Wl, ${LD_MSCL} ${LD_NAG}
LDEXTRA  =

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

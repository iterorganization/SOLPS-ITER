# Test whether necessary variables are defined
IRISLIB   ?= /fusion/projects/codes/solps/SOLPS-ITER/public_lib/GA.ifort64
MSCL_ROOT ?= ${IRISLIB}
LD_MSCL   ?= -L${MSCL_ROOT} -lmscl

MPI_FC  ?= mpif90
ifdef USE_MPI
 FC       = ${MPI_FC}
 COMPILER_TYPE = $(shell ${FC} --version | head -1 | cut -d ' ' -f 1)
 ifeq (${COMPILER_TYPE},GNU)
  COMPILER_REDEF = yes
 endif
endif


CPP      = /lib/cpp -traditional


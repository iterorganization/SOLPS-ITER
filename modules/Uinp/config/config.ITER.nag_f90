# Test whether necessary variables are defined
LD_MSCL ?= `pkg-config mscl --libs`

ifdef USE_MPI
FC       = mpif90
else
FC	 = nagfor
endif

ifdef SOLPS_DEBUG
FFLAGS	 = -g -PIC -compatible
else
FFLAGS	 = -O -PIC -compatible
endif

INCLUDE  = -I${SRCDIR} ${EIRINC} ${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP	 = /lib/cpp -traditional
MOD      = mod

LDLIBS 	 = ${LD_MSCL}
LDEXTRA  = 
ifdef USE_MPI
LDLIBS  += ${LD_MPI}
endif

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:


# Test whether necessary variables are defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

MPI_FC  ?= mpif90
ifdef SOLPS_MPI
FC       = ${MPI_FC}
endif

FFLAGS   = -fno-second-underscore -fno-unsafe-math-optimizations -frounding-math
ifdef SOLPS_DEBUG
FFLAGS  += -fbounds-check -fbacktrace
endif
CPP      = /lib/cpp -traditional


# MPI_FC      ?= mpiifort
MPI_FC        ?= mpi_f90
ifdef SOLPS_MPI
 FC            = ${MPI_FC}
 COMPILER_TYPE = $(shell ${FC} --version | head -1 | cut -d ' ' -f 1)
 ifeq (${COMPILER_TYPE},GNU)
  COMPILER_REDEF = yes
 endif
endif

CPP            = /lib/cpp -C -traditional


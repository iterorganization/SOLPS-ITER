# Test whether necessary variables are defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

ifdef USE_MPI
FC	 = mpif90
else
FC	 = gfortran
endif

ifdef SOLPS_DEBUG
FFLAGS	 = -g 
else
FFLAGS	 = -O 
endif

INCLUDE  = -I${SRCDIR} ${EIRINC} ${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP	 = /lib/cpp -traditional
MOD 	 = mod

LDLIBS 	 = ${LD_MSCL}
LDEXTRA  = 

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:


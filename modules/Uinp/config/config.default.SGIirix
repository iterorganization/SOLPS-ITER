#  VERSION : 11.05.95 13:39

# File compiler.macro for SGI f77

# Test whether necessary variables are defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif

FC       = f77
FFLAGS   = -static -O2 -nocpp
INCLUDE  = -I${SRCDIR} ${EIRINC} ${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP      = /lib/cpp
MOD      = mod
LDLIBS   = ${LD_MSCL} ${LD_NAG}
LDEXTRA  =

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:

#  VERSION : 28.07.99 20:34

# Test whether necessary variables are defined
LD_MSCL ?= -L${SOLPSLIB} -lmscl

FC       = g95
FFLAGS   = -fno-second-underscore
ifdef SOLPS_DEBUG
FFLAGS  += -g -fbounds-check -ftrace=full
else
FFLAGS  +=
endif
INCLUDE  = -I${SRCDIR} ${EIRINC} ${B2INC} ${CRRINC}
COMPILE  = ${FC} -c ${FFLAGS}
CPP      = /lib/cpp -C -traditional -ffreestanding

MOD      = mod
LDLIBS   = ${LD_MSCL}
LDEXTRA  =

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:


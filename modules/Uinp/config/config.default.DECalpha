# File compiler.macro for DEC Alpha

# Test whether necessary variables are defined
ifndef LD_MSCL
  $(error LD_MSCL not defined)
endif


FC	     = f90
CPP	     = /usr/ucb/cpp -C
MOD	     = mod
FFLAGS	 = -i4 -fast
INCLUDE  = -I${SRCDIR} -I${EIRINC} -I${B2INC}
COMPILE  = ${FC} -c ${FFLAGS}

LDLIBS 	 = ${LD_MSCL}
LDEXTRA  = 

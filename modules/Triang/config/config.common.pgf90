DEFINES += -DPGF90
EQUIVS =

CPPOPTS = -P -I${srcdir} ${EQUIVS}
LINK_MOD =

FC = pgf90
FCOPTS += -Mbackslash
ifdef SOLPS_DEBUG
FCOPTS += -C -g -Mchkfpstk -Mchkptr -Mchkstk -Mpgicoff
else
# FCOPTS += -O2
FCOPTS += -fast
endif

DBLFC = ${FC}
DBLOPTION =

INCMOD = -I
MOD = mod
OBJDEST = -o ${OBJDIR}/$*.o

BLD = ar rcv

LD = ${FC}

ifdef SOLPS_DEBUG
LDOPTS += -g -C
endif

GKS = ${LD_GR} ${LD_GKS} -lX11 -lXt
LDLIBS =
LDEXTRA =

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:


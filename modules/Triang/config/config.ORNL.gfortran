# Test whether necessary variables are defined
ifndef LD_GR
  $(error LD_GR not defined)
endif
ifndef LD_GKS
  $(error LD_GKS not defined)
endif

CPP = /lib/cpp -traditional

ifdef SOLPS_DEBUG
FCOPTS = -Wall -ffpe-trap=invalid -ffpe-trap=zero -ftrapv -fsignaling-nans
endif

DBLFC = ${FC}
DBLOPTION =
DBLSED = 

ifdef SOLPS_DEBUG
LDOPTS = -g -C -Wall
DEFINES += -DDBG
else
LDOPTS =
endif

GKS       = ${LD_GR} ${LD_GKS} -lX11 -lXt
LDLIBS    = 

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:


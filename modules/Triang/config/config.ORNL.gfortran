# Test whether necessary variables are defined
ifndef LD_GR
  $(error LD_GR not defined)
endif
ifndef LD_GKS
  $(error LD_GKS not defined)
endif

DEFINES =
EQUIVS =

CPP = /lib/cpp -traditional
CPPOPTS = -P -I${srcdir} ${EQUIVS}
SED = 
LINK_MOD =

FC = gfortran
ifdef SOLPS_DEBUG
FCOPTS = -C -g -Wall
else
FCOPTS = -O3
endif

DBLFC = ${FC}
DBLOPTION =
DBLSED = 

INCMOD = -I
MOD = mod
OBJDEST = -o ${OBJDIR}/$*.o

BLD = ar rcv

LD = gfortran
ifdef SOLPS_DEBUG
LDOPTS = -g -C -Wall
else
LDOPTS =
endif

GKS		    = ${LD_GR} ${LD_GKS} -lX11 -lXt
LDLIBS    = 
LDEXTRA 	=

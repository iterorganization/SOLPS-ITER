c=======================================================================
c*** Common definitions

#include <DIMENSIONS.F>
c=======================================================================
c*** User-defined dimensions
c=======================================================================

c*** Geometry. the parameters are:
c***      n1st      the maximum number of radial standard surfaces
c***      n2nd      the maximum number of poloidal standard surfaces
c***      n3rd      the maximum number of toroidal standard surfaces
c***      nadd      the maximum number of additional cells
c***      nlim      the maximum number of additional surfaces
c***      nsts      the maximum number of non-default standard surfaces
c***      nplg      the maximum number of poligons
c***      nppart    the maximum number of valid parts of the poligons
c***      n[nm][ia]f something for the Fourier approach
c***      nknot, ntri  something for triangular mesh (???)

      parameter (n1st=DEF_NYD+1, n2nd=DEF_NXD+DEF_NCUT+1, n3rd=1)
      parameter (nadd=200)
      parameter (nlim=DEF_NLIM, nsts=DEF_NSTS)
      parameter (nplg=n2nd,nppart=6)
      parameter (nmif=0,nmaf=1,nnif=0,nnaf=1)
      parameter (nknot=1,ntri=1)

c*** Primary source. The parameters are:
c***      nstra     the maximum number of strata
c***      nsrfs     the maximum number of surfaces in a stratum
c***      nstep     the maximum number of surface sources
c***      ngitt     max(n1st,nplg): space for the "step functions"

      parameter (nstra=DEF_NSTRA, nsrfs=DEF_NSRFS)
      parameter (nstep=DEF_NSTRA, ngitt=nplg)

c*** Species and tallies. The parameters are:
c***      natm      the maximum number of atomic species
c***      nmol      the maximum number of molecular species
c***      nion      the maximum number of test ion species
c***      npls      the maximum number of plasma species
c***      nadv      the maximum number of volume tallies
c***      nads      the maximum number of surface tallies

      parameter (natm=DEF_NATM, nmol=DEF_NMOL,
     ,           nion=DEF_NION, npls=DEF_NPLS,
     ,           nadv=1, nads=1,
     ,           nclv=1, nsnv=1, nalv=1, nals=1, nain=1,
     ,           ncop=5)
c  statistics
      parameter (nsd=1,nsdw=1,ncv=1,nhst=1)

c** Atomic data. The parameters are:
c***      ndisk     something apparently for H-alpha
c***      nreac     the maximum number of different reactions
c***      neli      the maximum number of elastic collisions (?)
c***      ndis      the maximum number of dissociation reactions (?)
c***      nrec      the maximum number of recombination reactions (?)

      parameter (ndisk=26)
      parameter (nreac=60,neli=10,ndis=27,nrec=2)
      parameter (nrcx=6,nrel=3,nrii=1)

c*** Surface reflection data (one block must be left uncommented)

c*  TRIM data
c***  nhd6: max. number of different TRIM data files
      parameter (nhd1=12,nhd2=7,nhd3=5,nhd4=5,nhd5=5,nhd6=6*DEF_NATM)

cank!!!      parameter (nhd1=12,nhd2=7,nhd3=5,nhd4=5,nhd5=5,nhd6=9)
cank!!! The setting above caused a problem with neutral pressure etc. !!!

c*  MARLOWE data
c     parameter (nhd1=7,nhd2=5,nhd3=5,nhd4=5,nhd5=5,nhd6=3)

c*  Behrisch matrix
c     parameter (nhd1=1,nhd2=1,nhd3=1,nhd4=1,nhd5=1,nhd6=1)

c*** Sputtering data
c***
c***    nsptpr  max. number of projectiles in the database SPUTER
c***    nspttg  max. number of target materials in the database SPUTER
c***    nchsppr max. number of aux. data entries for wall reactions
c***                                                         (block 6C)
      parameter (nsptpr=11, nspttg=28, nchsppr=36)
#define SPUTDIM

c*** Diagnostic chords data
c***
c***  nchor   max. number of explicitly specified diagnostic chords
c***  nchen   max. number of energy points in neutral spectra
c***  lntsputx  max. number of material template surfaces
c***  mgwtiesx  max. number of wall segments tied to a grid edge segment

      parameter (nchor=250,nchen=40,lntsputx=4,mgwtiesx=12)

c*** Data for surface properties visualisation (subr. srfprvsl)
c***
c***  nsrfclsx  max. number of views
c***  msrfclsx  max. number of comparison criteria

      parameter (nsrfclsx=12, msrfclsx=12)

c*** User supplied functions

      parameter (ndx=DEF_NXD+5*DEF_NCUT, ndy=DEF_NYD, nfl=DEF_NFL)
      parameter (ndxp=ndx+1,ndyp=ndy+1)

      parameter (nrech=2000)


# File compiler.macro for Fujitsu frt

FC	 = ifort
FFLAGS	 = -g
INCLUDE  = -I${SRCDIR} -I${EIRINC} -I${SOLPSTOP}/include.local -I${SOLPSTOP}/include
COMPILE  = ${FC} -c ${FFLAGS}
CPP	 = /lib/cpp -C -traditional

MOD 	 = mod
LDLIBS	 = -L${SOLPS_LIB} -lmscl -L$(SOLPSTOP)/base/b2/$(OBJECTCODE) -lb2 -lnetcdf

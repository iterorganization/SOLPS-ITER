#  VERSION : 30.06.2000 20:38

# The version relying on Fujitsu Fortran installed on AFS

#FC	= frt
FC      = f95f
ifdef SOLPS_DEBUG
FFLAGS	= -g -Am -X9 -AR -fw -Ha -Hs -Hu
else
FFLAGS	= -Am -X9 -fw -Kfast,eval -x- -O
endif
INCLUDE	= -I${SRCDIR} -I${EIRINC} -I${B2INC}
COMPILE = ${FC} -c ${FFLAGS}
CPP	= /lib/cpp -C -traditional
MOD 	= mod

LDLIBS	= -L${SOLPS_LIB} -lmscl
LDEXTRA	= -Wl,-Map $(OBJDIR)/map

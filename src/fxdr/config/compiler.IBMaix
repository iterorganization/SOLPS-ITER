#  VERSION : 09.05.95 17:03

# File compiler.macro for IBM xlf

FC	 = xlf

ifdef SOLPS_DEBUG
FFLAGS	 = -g
else
FFLAGS	 = -O
endif

INCLUDE  = -Isrc
COMPILE  = ${FC} -c ${FFLAGS}
CPP	 = /lib/cpp

LDLIBS	 = -L${SOLPS_LIB} -lsonnet -lmscl -L/usr/local/lib
LDEXTRA  = -bmap:$(OBJECTCODE)/fxdr.map -bloadmap:$(OBJECTCODE)/fxdr.lmp

#  VERSION : 09.05.95 17:03

# File compiler.macro for IBM xlf

FC	 = ifort

ifdef SOLPS_DEBUG
FFLAGS	 = -g debug all
else
FFLAGS	 = -O -vec_report0
endif

INCLUDE  = -Isrc
COMPILE  = ${FC} -c ${FFLAGS}
CPP	 = /lib/cpp -C -traditional

LDLIBS	 = -L${SOLPS_LIB} -lsonnet -lmscl -L/usr/local/lib
LDEXTRA  = 

$(error Using default file. Provide paths to libraries first.)

#
# Specify paths to root directories of following libraries on your system
# Specify system-specific additional compiler preprocessor definitions
#
# If using gfortran:
# Add -DGFORTRAN to SOLPS_CPP
#
# If using the Portland Group compiler:
# Add -DPGF90 -DNO_QUAD to SOLPS_CPP
#
# If using the G95 compiler:
# Add -DG95 to SOLPS_CPP
#
# If using the NAG compiler:
# Add -DNAGF95 to SOLPS_CPP
#
# If using the Cray compiler:
# Add -DCRAY to SOLPS_CPP
#
# If your compiler does not support Fortran 2003 features:
# Add -DLEGACYCOMP to SOLPS_CPP
#
# If you have NCAR version 3 (or no NCAR at all) on your system:
# Remove -DNCAR4 from SOLPS_CPP
#
# If you do not have NAG on your system:
# Use LD_NAG to link to the BLASLAPACK library instead
# Add -DNO_NAG to SOLPS_CPP
#
# If you have NAG Mark 17 or greater on your system:
# Add -DNO_F01AAF to SOLPS_CPP
#
# If you have NAG Mark 22 or greater on your system:
# Add -DNAG22 to SOLPS_CPP
#
# If compiling on an HP system:
# Add -DHPUX to SOLPS_CPP
#
# If compiling on an IBMaix system:
# Add -DIBMaix to SOLPS_CPP
#
# If compiling in a Windows environment:
# Add -DWINDOWS to SOLPS_CPP
#

       NCDIR ?=
   MSCL_ROOT ?=
       H5DIR ?=
     GR_ROOT ?=
    GLI_HOME ?=
  NCARG_ROOT ?=
      NAGDIR ?=
 MDSPLUS_DIR ?=
       MPDIR ?=

#
# Variables for linking
#

LD_NETCDF  = -L${NCDIR}/lib -lnetcdf
LD_MSCL    = -L${MSCL_ROOT}/lib -lmscl
ifdef GR_ROOT
LD_GR      = -L${GR_ROOT}/lib -lgr
endif
LD_GKS     = -L${GLI_HOME} -lgks -lgfortran
ifdef NCARG_ROOT
LD_NCARG   = -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -L/usr/X11R6/lib64 -lX11 -lm
endif
LD_NAG     = -L${NAGDIR}/lib -lnag
LD_MDSPLUS = -L${MDSPLUS_DIR}/lib -lMdsLib_client
LD_SONNET  = -L${SOLPSLIB} -lsonnet -lstdc++
LD_MPI     = -L${MPDIR}/lib -lmpi

LIBGKS     = ${GLI_HOME}/libgks.a
ifdef GR_ROOT
LIBGRS     = ${GR_ROOT}/lib/libgr.a
endif
LIBX11     = /usr/X11R6/lib64/libX11.so
ADDLIBS    = -lgfortran

#
# Provide compiler
#

MPI_FC    ?=
ifdef SOLPS_MPI
FC         = ${MPI_FC}
else
FC         =
endif
CC         =

#
# Preprocessor options
#

SOLPS_CPP      = -DNCAR4
B25_DEFINES    =
CARRE_DEFINES  =
EIRENE_DEFINES =
FFLAGSEXTRA    =
MPI_CPP        = -I${MPDIR}/include

# Autodetected optional features...

# Build with NetCDF tools if available
ifdef LD_NETCDF
  SOLPS_CPP   += -DCDF_MOVIE
else
  SOLPS_CPP   += -DNO_CDF
endif

# Build with MDSplus tools if MDSplus is present
ifdef LD_MDSPLUS
  SOLPS_CPP   += -DMDSPLUS
endif

# Build with Catalyst if ParaView is in PATH
ifdef LD_CATALYST
  SOLPS_CPP   += -DCATALYST
endif

# Build with Fundamental-Constants module if present
ifeq ($(shell `pkg-config --exists fundamental-constants`; echo $$?),0)
  SOLPS_CPP += -DCONSTANTS_PROVIDED
  SOLPSINCLUDE = `pkg-config fundamental-constants --cflags`
  IMAS_PKG_LIST = fundamental-constants
  export SOLPSINCLUDE
endif

# Build with JSON if present
ifeq ($(shell `pkg-config --exists json-fortran`; echo $$?),0)
  JSON_INC = `pkg-config json-fortran --cflags`
  LD_JSON = `pkg-config json-fortran --libs`
endif

# Build with IMAS if imas module is loaded
ifdef IMAS_VERSION
  ifdef AL_VERSION
    AL_MAJOR_VERSION = $(shell echo ${AL_VERSION} | cut -d '.' -f1 )
    AL_MINOR_VERSION = $(shell echo ${AL_VERSION} | cut -d '.' -f2 )
    AL_MICRO_VERSION = $(shell echo ${AL_VERSION} | cut -d '.' -f3 | cut -d '-' -f1 )
  else
    AL_MAJOR_VERSION = $(shell echo ${UAL_VERSION} | cut -d '.' -f1 )
    AL_MINOR_VERSION = $(shell echo ${UAL_VERSION} | cut -d '.' -f2 )
    AL_MICRO_VERSION = $(shell echo ${UAL_VERSION} | cut -d '.' -f3 | cut -d '-' -f1 )
  endif
  IMAS_MAJOR_VERSION = $(shell echo ${IMAS_VERSION} | cut -d '.' -f1 )
  IMAS_MINOR_VERSION = $(shell echo ${IMAS_VERSION} | cut -d '.' -f2 )
  IMAS_MICRO_VERSION = $(shell echo ${IMAS_VERSION} | cut -d '.' -f3 )
  ifeq ($(shell test ${AL_MAJOR_VERSION} -ge 5; echo $$?),0)
    IMAS_PKG_LIST += al-fortran al-identifiers-fortran
  else
    IMAS_PKG_LIST += imas-ifort
    ifeq ($(shell test ${IMAS_MAJOR_VERSION} -ge 4; echo $$?),0)
      IMAS_PKG_LIST += imas-identifiers-ifort
    else
      ifeq ($(shell test ${IMAS_MINOR_VERSION} -ge 31; echo $$?),0)
        IMAS_PKG_LIST += imas-identifiers-ifort
      endif
    endif
  endif
  ifeq ($(shell test ${IMAS_MAJOR_VERSION} -ge 4; echo $$?),0)
    ifdef GGD_VERSION
      GGD_MAJOR_VERSION = $(shell echo ${GGD_VERSION} | cut -d '.' -f1 )
      GGD_MINOR_VERSION = $(shell echo ${GGD_VERSION} | cut -d '.' -f2 )
      GGD_MICRO_VERSION = $(shell echo ${GGD_VERSION} | cut -d '.' -f3 | cut -d '-' -f1 )
    else
      GGD_MAJOR_VERSION = 0
      GGD_MINOR_VERSION = 0
      GGD_MICRO_VERSION = 0
    endif
  else
    ifeq ($(shell test ${IMAS_MINOR_VERSION} -ge 12; echo $$?),0)
      ifdef GGD_VERSION
        GGD_MAJOR_VERSION = $(shell echo ${GGD_VERSION} | cut -d '.' -f1 )
        GGD_MINOR_VERSION = $(shell echo ${GGD_VERSION} | cut -d '.' -f2 )
        GGD_MICRO_VERSION = $(shell echo ${GGD_VERSION} | cut -d '.' -f3 | cut -d '-' -f1 )
      else
        GGD_MAJOR_VERSION = 0
        GGD_MINOR_VERSION = 0
        GGD_MICRO_VERSION = 0
      endif
    else
      GGD_MAJOR_VERSION = 1
      GGD_MINOR_VERSION = 0
      GGD_MICRO_VERSION = 0
    endif
  endif
  ifeq ($(shell test ${GGD_MAJOR_VERSION} -gt 0; echo $$?),0)
    ifeq ($(shell test ${IMAS_MAJOR_VERSION} -ge 4; echo $$?),0)
      IMAS_PKG_LIST += ggd
    else
      ifeq ($(shell test ${IMAS_MINOR_VERSION} -ge 17; echo $$?),0)
        IMAS_PKG_LIST += ggd
      else
        ifeq ($(shell test ${IMAS_MINOR_VERSION} -ge 12; echo $$?),0)
          LD_GGD = -lggd_ifort
        else
          IMAS_PKG_LIST += imas-lowlevel
        endif
      endif
    endif
  endif
  ifdef AMNS_PREFIX
    IMAS_PKG_LIST += amns
    SOLPS_CPP += -DAMNS
  endif
  LD_AL = `pkg-config ${IMAS_PKG_LIST} --libs`
  ifdef LD_GGD
    LD_AL += ${LD_GGD}
  endif
  SOLPS_CPP += -DIMAS -DAL_MAJOR_VERSION=${AL_MAJOR_VERSION} -DAL_MINOR_VERSION=${AL_MINOR_VERSION} -DAL_MICRO_VERSION=${AL_MICRO_VERSION} -DIMAS_MAJOR_VERSION=${IMAS_MAJOR_VERSION} -DIMAS_MINOR_VERSION=${IMAS_MINOR_VERSION} -DIMAS_MICRO_VERSION=${IMAS_MICRO_VERSION} -DGGD_MAJOR_VERSION=${GGD_MAJOR_VERSION} -DGGD_MINOR_VERSION=${GGD_MINOR_VERSION} -DGGD_MICRO_VERSION=${GGD_MICRO_VERSION}
  export LD_AL
else
  AL_MAJOR_VERSION = 0
  AL_MINOR_VERSION = 0
  AL_MICRO_VERSION = 0
  GGD_MAJOR_VERSION = 0
  GGD_MINOR_VERSION = 0
  GGD_MICRO_VERSION = 0
  IMAS_MAJOR_VERSION = 0
  IMAS_MINOR_VERSION = 0
  IMAS_MICRO_VERSION = 0
endif
export AL_MAJOR_VERSION
export AL_MINOR_VERSION
export AL_MICRO_VERSION
export GGD_MAJOR_VERSION
export GGD_MINOR_VERSION
export GGD_MICRO_VERSION
export IMAS_MAJOR_VERSION
export IMAS_MINOR_VERSION
export IMAS_MICRO_VERSION
export IMAS_PKG_LIST

#
# Export for use in sub-makefiles
#

export NCDIR
export MSCL_ROOT
export H5DIR
export GR_ROOT
export GLI_HOME
export NCARG_ROOT
export NAGDIR
export MDSPLUS_DIR

export LD_NETCDF
export LD_MSCL
export LD_GR
export LD_GKS
export LD_NCARG
export LD_NAG
export LD_MDSPLUS
export LD_SONNET
export LD_MPI
export LD_JSON

export LIBGKS
export LIBGRS
export LIBX11
export ADDLIBS

export SOLPS_CPP
export SOLPS_MPI
export SOLPS_OPENMP
export FFLAGSEXTRA
export B25_DEFINES
export CARRE_DEFINES
export EIRENE_DEFINES
export MPI_CPP
export JSON_INC

#!!!Local Variables:
#!!! mode: Makefile
#!!! End:


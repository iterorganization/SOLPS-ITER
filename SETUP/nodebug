if ($?SOLPS_PATH) then
  setenv   OLD_SOLPS_PATH $SOLPS_PATH
  setenv   PATH `echo $PATH | sed "s|${SOLPS_PATH}:||"`
  setenv   SOLPS_PATH `echo $SOLPS_PATH | sed 's|\.debug:|:|g'`
  setenv   PATH ${SOLPS_PATH}:${PATH}
  unsetenv OLD_SOLPS_PATH IMAS_AMNS_DEBUG SOLPS_DEBUG I_MPI_DEBUG PMI_DEBUG
  if ($?SOLPS_OPENMP) then
    setenv OMP_DISPLAY_AFFINITY false
    setenv OMP_DISPLAY_ENV false
  endif
  rehash
  echo "SOLPS-ITER debug mode turned off"
else
  echo "SOLPS_PATH not set. Exiting."
endif


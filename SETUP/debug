if ($?SOLPS_PATH) then
  # Check whether HOST_NAME and COMPILER are defined
  if (! $?HOST_NAME) then
    echo "HOST_NAME not defined. Exiting."
    exit 1
  endif
  if (! $?COMPILER) then
    echo "COMPILER not defined. Exiting."
    exit 1
  endif

  setenv   OLD_SOLPS_PATH $SOLPS_PATH
  setenv   PATH `echo $PATH | sed "s|${SOLPS_PATH}:||"`
  setenv   SOLPS_PATH `echo $SOLPS_PATH | sed 's|\.debug||g'`
  setenv   SOLPS_PATH `echo $SOLPS_PATH | sed "s|${HOST_NAME}.${COMPILER}.mpi|${HOST_NAME}.${COMPILER}.mpi.debug|g"`
  setenv   SOLPS_PATH `echo $SOLPS_PATH | sed "s|${HOST_NAME}.${COMPILER}:|${HOST_NAME}.${COMPILER}.debug:|g"`
  setenv   PATH ${SOLPS_PATH}:${OLD_PATH}
  setenv   SOLPS_DEBUG yes
  setenv   PMI_DEBUG 1
  unsetenv OLD_SOLPS_PATH
  echo "SOLPS-ITER debug mode turned on"
else
  echo "SOLPS_PATH not set. Exiting."
endif


echo setup.csh.local
setenv SOLPS_CPP "$SOLPS_CPP -DTRIANG"
if (! $?EIRENE_DEFINES) then
  setenv EIRENE_DEFINES "-DNO_FORT10 -DNO_SHORT_CYCLE"
else
  setenv EIRENE_DEFINES "$EIRENE_DEFINES -DNO_FORT10 -DNO_SHORT_CYCLE"
endif

setenv B2PLOT_DEV ps
# alias b2plot /afs/ipp-garching.mpg.de/u/dpc/solps/solps4.0_test/src/Braams/b2plot/${OBJECTCODE}/b2plot

setenv NCARG_ROOT /b2-ext/ncarg

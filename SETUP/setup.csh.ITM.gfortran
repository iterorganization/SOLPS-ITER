setenv SOLPSWORK /pfs/work/$USER/solps-iter/runs
setenv SCRATCH_DIR /pfs/scratch/$USER
setenv MODULES_ADVANCED_VERSION_SPEC 0

# add IMAS module list to module system
module load ach-modules

# load IMAS modules for FOSS
module load IMAS/3.42.0-2025.01-foss-2023b
module load GGD/1.12.0-foss-2023b-DD-3.42.0
module load Fundamental-Constants/0.1.1
module load AMNS/1.5.1-foss-2023b-DD-3.42.0
module load texlive/20230313-GCC-13.2.0
module load json-fortran/8.5.2-GCC-13.2.0
module load netCDF/4.9.2-gompi-2023b
module load netCDF-Fortran/4.6.1-gompi-2023b
module load CMake/3.27.6-GCCcore-13.2.0
module load git/2.42.0-GCCcore-13.2.0
module load Doxygen/1.9.8-GCCcore-13.2.0
module load Ghostscript/10.02.1-GCCcore-13.2.0
module load makedepend/1.0.9-GCCcore-13.2.0
module load IMAS-ParaView/2.1.0-foss-2023b
module load GLI/4.5.31-GCCcore-13.2.0
module load GR/0.0.94-GCCcore-13.2.0
module load MSCL/1.2.5-GCCcore-13.2.0
module load NCL/6.6.2-foss-2023b
module load imkl/2023.2.0

pkg-config ggd --exists && setenv GGD_VERSION `pkg-config ggd --modversion` || setenv GGD_VERSION '0.0.0'
setenv GLI_HOME ${EBROOTGLI}
setenv SYSNAME x86_64_rhel9
setenv CMAKE_MAJOR_VERSION `cmake --version | head -1 | cut -d ' ' -f 3 | cut -d '.' -f 1`

# Compiler
setenv CC gcc
setenv FC gfortran
setenv CXX g++
setenv MPI_FC mpifort

# Set environment variables
if (! $?DEVICE) then
  if ($?TOKAMAKNAME) then
    setenv DEVICE $TOKAMAKNAME
  endif
endif

if (`where paraview-config` == "") then
  echo "Warning: paraview-config not found. ParaView with Catalyst will not be compiled-in!"
else
  # See ParaViewCatalystUsersGuide_v2.pdf Sec 3.7.2 Linking with Python ...
  setenv PARAVIEW_MAJOR_VERSION `paraview --version | cut -d '.' -f 1 | cut -d ' ' -f 3`
  if (${CMAKE_MAJOR_VERSION} > 2) then
    module switch CMake/3.20.0-GCCcore-13.2.0
    setenv LD_CATALYST `paraview-config --ldflags -c PythonCatalyst -v CommonDataModel`
    module switch CMake/3.27.6-GCCcore-13.2.0
    # Avoid a naming clash
    unsetenv BOOST_ROOT
    setenv PARAVIEW_INCLUDE `paraview-config --cppflags`
    setenv BOOST_ROOT ${EBROOTBOOST}
  else
    setenv PARAVIEW_LIB `paraview-config --libs --python | sed s/-L//`
    setenv LD_CATALYST `paraview-config --libs vtkPVPythonCatalyst`
    setenv PARAVIEW_INCLUDE `paraview-config --include`
    if ($?LD_LIBRARY_PATH) then
      setenv LD_LIBRARY_PATH "${PARAVIEW_LIB}:${LD_LIBRARY_PATH}"
    else
      setenv LD_LIBRARY_PATH ${PARAVIEW_LIB}
    endif
    setenv PYTHONPATH "${PARAVIEW_LIB}/site-packages/vtk:${PYTHONPATH}"
    setenv PYTHONPATH "${PARAVIEW_LIB}/site-packages:${PYTHONPATH}"
  endif
endif

# Debugger (set environment variable DBX)
module load totalview/2025.3.4
setenv DBX totalview


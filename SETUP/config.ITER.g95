#
# Specify paths to root-directories of following libraries on your system
#
# Special notes:
#
# If you have NCAR version 3 on your system:
# Remove -DNCAR4 from SOLPS_CPP
#
# If you do not have NAG on your system:
# Use LD_NAG to link to the BLASLAPACK library instead
# Add -DNO_NAG to SOLPS_CPP
#
# If you have NAG Mark 17 or greater on your system:
# Add -DNO_F01AAF to SOLPS_CPP
#
# If you have NAG Mark 22 or greater on your system:
# Add -DNAG22 to SOLPS_CPP
#
# If your compiler does not support Fortran 2003 features:
# Add -DLEGACYCOMP to SOLPS_CPP
#

       NCDIR ?= /work/imas/opt/netcdf-fortran/4.4.2
   MSCL_ROOT ?=
       H5DIR ?=
     GR_ROOT ?= /work/imas/opt/gr/0.0.94
    GLI_HOME ?= /pfs/work/g2dpc/SOLPS-ITER/${COMPILER}/gks
  NCARG_ROOT ?=
      NAGDIR ?=
 MDSPLUS_DIR ?=

#
# Variables for linking
#

LD_NETCDF  = $(shell nf-config --flibs)
LD_MSCL    = $(shell pkg-config mscl --libs)
LD_GR      = -L${GR_ROOT} -lgr
LD_GKS     = -L/work/imas/opt/EasyBuild/software/GR/0.56.0-GCCcore-10.2.0/lib -lGKS -lgfortran -lX11 -lXt
LD_NCARG   = -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -lX11 -lXext $(shell pkg-config cairo --libs) -lfontconfig -lfreetype -lpng -lz -lXrender -lbz2 ${LD_INTEL_LIBS} # for NCARG v6.x.x
#LD_NCARG  = -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -lX11                                                                                                            # for NCARG v4.x.x
#LD_NAG    = -L${NAGDIR}/lib -lnag_nag
LD_NAG     = -L${SOLPSLIB} -lblaslapack # -L${NAGDIR} -lnag
LD_MDSPLUS = -L${MDSPLUS_DIR}/lib -lMdsLib_client
LD_SONNET  = -L${SOLPSLIB} -lsonnet -lstdc++
LD_MPI     = $(shell pkg-config mvapich2 --libs)
LD_JSON    = $(shell pkg-config json-fortran --libs)

LIBGKS     = /work/imas/opt/EasyBuild/software/GR/0.56.0-GCCcore-10.2.0/lib/libGKS.so
ifdef GR_ROOT
LIBGRS     = ${GR_ROOT}/libgr.a
endif
ADDLIBS    = -lgfortran

#
# Preprocessor options
#

SOLPS_CPP      = -DNCAR4 -DNO_NAG -DLEGACYCOMP
B25_DEFINES    =
EIRENE_DEFINES =
MPI_CPP        = $(shell pkg-config mvapich2 --cflags)
JSON_INC       = $(shell pkg-config json-fortran --cflags)

# Autodetected optional features

# Build with NetCDF tools if available
ifdef LD_NETCDF
  SOLPS_CPP   += -DCDF_MOVIE
else
  SOLPS_CPP   += -DNO_CDF
endif

# Build with MDSplus tools if MDSplus is present
ifdef LD_MDSPLUS
  SOLPS_CPP   += -DMDSPLUS
endif

# Build with Catalyst if ParaView is in PATH
ifdef LD_CATALYST
  SOLPS_CPP   += -DCATALYST
  ifeq ($(strip $(PARAVIEW_MAJOR_VERSION)),)
    PARAVIEW_MAJOR_VERSION := 0
  endif
endif

# Build with Fundamental-Constants module if present
ifeq ($(shell `pkg-config --exists fundamental-constants`; echo $$?),0)
  CONSTANTS_MINOR_VERSION = $(shell pkg-config fundamental-constants --modversion | cut -d '.' -f 2)
  SOLPS_CPP += -DCONSTANTS_PROVIDED -DCONSTANTS_MINOR_VERSION=${CONSTANTS_MINOR_VERSION}
  SOLPSINCLUDE = $(shell pkg-config fundamental-constants --cflags)
  IMAS_PKG_LIST = fundamental-constants
  export SOLPSINCLUDE
endif

# Build with IMAS if imas module is loaded
ifdef IMAS_VERSION
  ifdef AL_VERSION
    AL_MAJOR_VERSION = $(shell echo ${AL_VERSION} | cut -d '.' -f1 )
    AL_MINOR_VERSION = $(shell echo ${AL_VERSION} | cut -d '.' -f2 )
    AL_MICRO_VERSION = $(shell echo ${AL_VERSION} | cut -d '.' -f3 | cut -d '-' -f1 )
  else
    AL_MAJOR_VERSION = $(shell echo ${UAL_VERSION} | cut -d '.' -f1 )
    AL_MINOR_VERSION = $(shell echo ${UAL_VERSION} | cut -d '.' -f2 )
    AL_MICRO_VERSION = $(shell echo ${UAL_VERSION} | cut -d '.' -f3 | cut -d '-' -f1 )
  endif
  IMAS_MAJOR_VERSION = $(shell echo ${IMAS_VERSION} | cut -d '.' -f1 )
  IMAS_MINOR_VERSION = $(shell echo ${IMAS_VERSION} | cut -d '.' -f2 )
  IMAS_MICRO_VERSION = $(shell echo ${IMAS_VERSION} | cut -d '.' -f3 )
  ifeq ($(shell test ${AL_MAJOR_VERSION} -ge 5; echo $$?),0)
    ifeq (,$(findstring fortran,${IMAS_PKG_LIST}))
      IMAS_PKG_LIST += al-fortran al-identifiers-fortran
    endif
  else
    ifeq (,$(findstring imas-,${IMAS_PKG_LIST}))
      IMAS_PKG_LIST += imas-g95
      ifeq ($(shell test ${IMAS_MAJOR_VERSION} -ge 4; echo $$?),0)
        IMAS_PKG_LIST += imas-identifiers-gfortran
      else
        ifeq ($(shell test ${IMAS_MINOR_VERSION} -ge 31; echo $$?),0)
          IMAS_PKG_LIST += imas-identifiers-gfortran
        endif
      endif
    endif
  endif
  ifeq ($(shell test ${IMAS_MAJOR_VERSION} -ge 4; echo $$?),0)
    ifdef GGD_VERSION
      GGD_MAJOR_VERSION = $(shell echo ${GGD_VERSION} | cut -d '.' -f1 )
      GGD_MINOR_VERSION = $(shell echo ${GGD_VERSION} | cut -d '.' -f2 )
      GGD_MICRO_VERSION = $(shell echo ${GGD_VERSION} | cut -d '.' -f3 | cut -d '-' -f1 )
    else
      GGD_MAJOR_VERSION = 0
      GGD_MINOR_VERSION = 0
      GGD_MICRO_VERSION = 0
    endif
  else
    ifeq ($(shell test ${IMAS_MINOR_VERSION} -ge 12; echo $$?),0)
      ifdef GGD_VERSION
        GGD_MAJOR_VERSION = $(shell echo ${GGD_VERSION} | cut -d '.' -f1 )
        GGD_MINOR_VERSION = $(shell echo ${GGD_VERSION} | cut -d '.' -f2 )
        GGD_MICRO_VERSION = $(shell echo ${GGD_VERSION} | cut -d '.' -f3 | cut -d '-' -f1 )
      else
        GGD_MAJOR_VERSION = 0
        GGD_MINOR_VERSION = 0
        GGD_MICRO_VERSION = 0
      endif
    else
      GGD_MAJOR_VERSION = 1
      GGD_MINOR_VERSION = 0
      GGD_MICRO_VERSION = 0
    endif
  endif
  ifeq ($(shell test ${GGD_MAJOR_VERSION} -gt 0; echo $$?),0)
    ifeq ($(shell test ${IMAS_MAJOR_VERSION} -ge 4; echo $$?),0)
      ifeq (,$(findstring ggd,${IMAS_PKG_LIST}))
        IMAS_PKG_LIST += ggd
      endif
    else
      ifeq ($(shell test ${IMAS_MINOR_VERSION} -ge 17; echo $$?),0)
        ifeq (,$(findstring ggd,${IMAS_PKG_LIST}))
          IMAS_PKG_LIST += ggd
        endif
      else
        ifeq ($(shell test ${IMAS_MINOR_VERSION} -ge 12; echo $$?),0)
          LD_GGD = -lggd_g95
        else
          ifeq (,$(findstring lowlevel,${IMAS_PKG_LIST}))
            IMAS_PKG_LIST += imas-lowlevel
          endif
        endif
      endif
    endif
  endif
  ifdef AMNS_PREFIX
    ifeq (,$(findstring amns,${IMAS_PKG_LIST}))
      IMAS_PKG_LIST += amns
    endif
    SOLPS_CPP += -DAMNS
  endif
  LD_AL = $(shell pkg-config ${IMAS_PKG_LIST} --libs)
  ifdef LD_GGD
    LD_AL += ${LD_GGD}
  endif
  SOLPS_CPP += -DIMAS -DAL_MAJOR_VERSION=${AL_MAJOR_VERSION} -DAL_MINOR_VERSION=${AL_MINOR_VERSION} -DAL_MICRO_VERSION=${AL_MICRO_VERSION} -DIMAS_MAJOR_VERSION=${IMAS_MAJOR_VERSION} -DIMAS_MINOR_VERSION=${IMAS_MINOR_VERSION} -DIMAS_MICRO_VERSION=${IMAS_MICRO_VERSION} -DGGD_MAJOR_VERSION=${GGD_MAJOR_VERSION} -DGGD_MINOR_VERSION=${GGD_MINOR_VERSION} -DGGD_MICRO_VERSION=${GGD_MICRO_VERSION}
  export LD_AL
else
  AL_MAJOR_VERSION = 0
  AL_MINOR_VERSION = 0
  AL_MICRO_VERSION = 0
  GGD_MAJOR_VERSION = 0
  GGD_MINOR_VERSION = 0
  GGD_MICRO_VERSION = 0
  IMAS_MAJOR_VERSION = 0
  IMAS_MINOR_VERSION = 0
  IMAS_MICRO_VERSION = 0
endif
export AL_MAJOR_VERSION
export AL_MINOR_VERSION
export AL_MICRO_VERSION
export GGD_MAJOR_VERSION
export GGD_MINOR_VERSION
export GGD_MICRO_VERSION
export IMAS_MAJOR_VERSION
export IMAS_MINOR_VERSION
export IMAS_MICRO_VERSION
export IMAS_PKG_LIST

#
# Export for use in sub-makefiles
#

export NCDIR
export MSCL_ROOT
export H5DIR
export GR_ROOT
export GLI_HOME
export NCARG_ROOT
export NAGDIR
export MDSPLUS_DIR

export LD_NETCDF
export LD_MSCL
export LD_GR
export LD_GKS
export LD_NCARG
export LD_NAG
export LD_MDSPLUS
export LD_SONNET
export LD_JSON
export LD_CATALYST
export PARAVIEW_MAJOR_VERSION
export PARAVIEW_INCLUDE

export SOLPS_CPP
export SOLPS_MPI
export SOLPS_OPENMP
export B25_DEFINES
export EIRENE_DEFINES
export JSON_INC

ifndef NO_CMAKE
  export CMAKE_MAJOR_VERSION
endif


## Local Variables:
## mode: Makefile
## End:

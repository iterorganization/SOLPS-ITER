# General
source /etc/profile.d/modules.sh
[ -d $HOME/privatemodules ] && module use $HOME/privatemodules
module use /work/imas/etc/modules/all

# Modules needed by SOLPS-ITER

nodename=`hostname`
export OS=`grep -m1 NAME /etc/os-release | cut -d '"' -f 2 | cut -d ' ' -f 1`
[ $OS = "CentOS" ] && {
  module load IMAS-AL-Fortran/5.2.1-foss-2020b-DD-3.41.0
  module load IMAS-AL-Python/5.2.1-foss-2020b-DD-3.41.0
  module load IDStools/1.14.1-foss-2020b
  module load GGD/1.11.0-foss-2020b-DD-3.41.0
  module load AMNS/1.5.0-foss-2020b-DD-3.41.0
  module load makedepend/1.0.6-GCCcore-10.2.0
  module load MSCL/1.2.3-GCCcore-10.2.0
  module load GR/0.0.94-GCCcore-10.2.0
  module load GLI/4.5.31-GCCcore-10.2.0
  module load NCL/6.6.2-foss-2020b
  module load flex/2.6.4-GCCcore-10.2.0
  module load Doxygen/1.8.20-GCCcore-10.2.0
  module load Ghostscript/9.53.3-GCCcore-10.2.0
  module load CMake/3.20.1-GCCcore-10.2.0
  module load ParaView/5.10.0-foss-2020b-mpi
  module load PyQt5/5.15.1-GCCcore-10.2.0
  module load netCDF-Fortran/4.5.3-gompi-2020b
  module load netcdf4-python/1.5.5.1-foss-2020b
  module load motif/2.3.8-GCCcore-10.2.0
  module load gnuplot/5.4.1-GCCcore-10.2.0
# module load MATLAB/2020b-GCCcore-10.2.0-Java-11
  module load texlive/20210216-GCCcore-10.2.0
  module load libtirpc/1.3.1-GCCcore-10.2.0
  module load SimDB/0.7.1-foss-2020b
  module load json-fortran/8.3.0-GCC-10.2.0
  export QTDIR=${EBROOTQT5}
  export SYSNAME="amd64_sles15"
} || {
  # RHEL9: select the EasyBuild toolchain generation. Default is 2023b
  # (existing production toolchain). Set SOLPS_TOOLCHAIN_VERSION=2025b
  # before sourcing setup.ksh to opt-in to the foss/intel 2025b stack.
  : ${SOLPS_TOOLCHAIN_VERSION:=2023b}
  echo "Loading modules for "$SOLPS_TOOLCHAIN_VERSION" toolchain"
  echo "Use the SOLPS_TOOLCHAIN_VERSION environment variable to change this choice"
  echo "and restart the session"
  case "$SOLPS_TOOLCHAIN_VERSION" in
  2025b)
    module use /work/imas/etc/modules-2025b/all
    module load IMAS-Fortran/5.6.0-foss-2025b-DD-4.1.1
    module load IDStools/2.4.0-foss-2025b
    module load GGD/1.14.0-foss-2025b-DD-4.1.1
    module load AMNS/1.6.0-foss-2025b-DD-4.1.1
    module load SimDB/0.15.1-foss-2025b
    module load makedepend/1.0.9-GCCcore-14.3.0
    module load MSCL/1.2.5-GCCcore-14.3.0
    module load Doxygen/1.14.0-GCCcore-14.3.0
    module load texlive/20250308-GCC-14.3.0
    module load Ghostscript/10.05.1-GCCcore-14.3.0
    module load netCDF/4.9.3-gompi-2025b
    module load netCDF-Fortran/4.6.2-gompi-2025b
    module load netcdf4-python/1.7.2-foss-2025b
    module load NCL/6.6.2-foss-2025b
    module load motif/2.3.8-GCCcore-14.3.0
    module load libtirpc/1.3.6-GCCcore-14.3.0
#   NAG is not (yet) available in 2025b; config.ITER.gfortran falls back to
#   OpenBLAS automatically when NAGDIR is unset.
    module load CMake/4.0.3-GCCcore-14.3.0
    module load json-fortran/9.0.5-GCC-14.3.0
    module load IMAS-ParaView/2.3.0-foss-2025b
    ;;
  2023b|*)
    module load IMAS-Fortran/5.5.0-foss-2023b-DD-4.1.0
    module load IDStools/2.4.0-gfbf-2023b
    module load GGD/1.14.0-foss-2023b-DD-4.1.0
    module load AMNS/1.6.0-foss-2023b-DD-4.1.0
    module load SimDB/0.14.1-foss-2023b
    module load makedepend/1.0.9-GCCcore-13.2.0
    module load MSCL/1.2.5-GCCcore-13.2.0
    module load Doxygen/1.9.8-GCCcore-13.2.0
#   module load ParaView/5.12.0-foss-2023b
    module load texlive/20230313-GCC-13.2.0
    module load Ghostscript/10.02.1-GCCcore-13.2.0
    module load netCDF/4.9.2-gompi-2023b
    module load netCDF-Fortran/4.6.1-gompi-2023b
    module load netcdf4-python/1.7.1-post2-foss-2023b
#   module load NAG/26-GCC-13.2.0
    module load CMake/3.27.6-GCCcore-13.2.0
    module load IMAS-ParaView/2.3.0-foss-2023b
    module load json-fortran/8.5.2-GCC-13.2.0
    ;;
  esac
  export QTDIR=${EBROOTQT6}
  export SYSNAME="x86_64_rhel9"
}
module load Fundamental-Constants/0.2.0

export GGD_VERSION=`pkg-config ggd --modversion`
export EBVERSIONMSCL=`pkg-config mscl --modversion`
export PARAVIEW_PREFIX=${EBROOTPARAVIEW}
export GLI_HOME=${EBROOTGLI}
export NCDIR=${EBROOTNETCDFMINFORTRAN}
export MPDIR=${EBROOTIMPI}
export CMAKE_MAJOR_VERSION=`cmake --version | head -1 | cut -d ' ' -f 3 | cut -d '.' -f 1`

# Debugger (set environment variable DBX)
module load TotalView/2023.4.16_linux_x86-64
export DBX="totalview"

# Compilers
export CC=gcc
export FC=gfortran
export CXX=g++

[ -x paraview-config ] && {
  # See ParaViewCatalystUsersGuide_v2.pdf Sec 3.7.2 Linking with Python ...
  export PARAVIEW_MAJOR_VERSION=`paraview --version | cut -d '.' -f 1 | cut -d ' ' -f 3`
  if [ $CMAKE_MAJOR_VERSION -gt 2 ]; then
    # Avoid a naming clash
    unset BOOST_ROOT
    if [ $PARAVIEW_MAJOR_VERSION -lt 6 ]; then
      module switch CMake/3.18.4
      export LD_CATALYST=`paraview-config --ldflags -c PythonCatalyst -v CommonDataModel`
      module switch CMake/3.27.6-GCCcore-13.2.0
      export PARAVIEW_INCLUDE=`paraview-config --cppflags`
    else
      # Wrap cmake to suppress spurious CMake 4.x warnings when calling paraview-config
      _pv_tmpdir=`mktemp -d`
      _pv_cmake=`which cmake`
      # Write a cmake include file that pre-finds external deps so that
      # -c PythonCatalyst succeeds (requires MPI, X11, Boost, catalyst targets).
      printf 'find_package(MPI)\nfind_package(X11)\nfind_package(Boost QUIET)\n' > ${_pv_tmpdir}/_inject.cmake
      printf 'if (DEFINED ENV{EBROOTPARAVIEWMINCATALYST})\n' >> ${_pv_tmpdir}/_inject.cmake
      printf '  find_package(catalyst HINTS "$ENV{EBROOTPARAVIEWMINCATALYST}/lib/cmake/catalyst-2.0" NO_DEFAULT_PATH)\n' >> ${_pv_tmpdir}/_inject.cmake
      printf 'endif()\n' >> ${_pv_tmpdir}/_inject.cmake
      printf '#!/bin/sh\n' > ${_pv_tmpdir}/cmake
      echo 'case " $* " in' >> ${_pv_tmpdir}/cmake
      echo '  *" --build "*) exec '"${_pv_cmake}"' "$@" ;;' >> ${_pv_tmpdir}/cmake
      echo '  *) exec '"${_pv_cmake}"' -DCMAKE_WARN_DEPRECATED=OFF -DCMAKE_POLICY_DEFAULT_CMP0167=NEW -DCMAKE_PROJECT_INCLUDE='"${_pv_tmpdir}"'/_inject.cmake "$@" ;;' >> ${_pv_tmpdir}/cmake
      echo 'esac' >> ${_pv_tmpdir}/cmake
      chmod +x ${_pv_tmpdir}/cmake
      _pv_saved_path="$PATH"
      export PATH="${_pv_tmpdir}:${PATH}"
      export LD_CATALYST=`paraview-config --ldflags -c PythonCatalyst -v CommonDataModel`
      export PARAVIEW_INCLUDE=`paraview-config --cppflags`
      # Restore PATH and clean up cmake wrapper
      export PATH="${_pv_saved_path}"
      rm -rf ${_pv_tmpdir}
      unset _pv_tmpdir _pv_cmake _pv_saved_path
    fi
    export BOOST_ROOT=${EBROOTBOOST}
  else
    export PARAVIEW_LIB=`paraview-config --libs --python | sed s/-L//`
    export PARAVIEW_INCLUDE=`paraview-config --include`
    export LD_LIBRARY_PATH="${PARAVIEW_LIB}:${LD_LIBRARY_PATH}"
    export PYTHONPATH="${PARAVIEW_LIB}/site-packages/vtk:${PYTHONPATH}"
    export PYTHONPATH="${PARAVIEW_LIB}/site-packages:${PYTHONPATH}"
    export LD_CATALYST=`paraview-config --libs vtkPVPythonCatalyst`
  fi
  export LD_CATALYST="${LD_CATALYST} -lstdc++"
} || {
  echo "Warning: paraview-config not found. ParaView with Catalyst will not be compiled-in!"
}

# Other environment variables
unset MPLBACKEND
export LD_LIBRARY_PATH="${LD_LIBRARY_PATH}:/usr/lib64"
export SOLPSWORK="/work/projects/solps-iter/${USER}"

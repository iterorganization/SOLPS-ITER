if ($?SOLPS_PATH) then
  # Check whether HOST_NAME and COMPILER are defined
  if (! $?HOST_NAME) then
    echo "HOST_NAME not defined. Exiting."
    exit 1
  endif
  if (! $?COMPILER) then
    echo "COMPILER not defined. Exiting."
    exit 1
  endif
  
  # Pragmatic approach: assume only Eirene, B2.5 and B25Eirene will require mpi-versions
  setenv   OLD_SOLPS_PATH   $SOLPS_PATH
  setenv   SOLPS_PATH `echo $SOLPS_PATH | sed 's|.mpi||g'` # remove .mpi if already present
  setenv   SOLPS_PATH `echo $SOLPS_PATH | sed "s|standalone.${HOST_NAME}.${COMPILER}|standalone.${HOST_NAME}.${COMPILER}.mpi|g"`
  setenv   SOLPS_PATH `echo $SOLPS_PATH | sed "s|couple_SOLPS-ITER.${HOST_NAME}.${COMPILER}|couple_SOLPS-ITER.${HOST_NAME}.${COMPILER}.mpi|g"`
  setenv   PATH `echo $PATH | sed "s|${OLD_SOLPS_PATH}|${SOLPS_PATH}|"`
  setenv   SOLPS_MPI yes
  unsetenv OLD_SOLPS_PATH
  echo "SOLPS-ITER MPI mode turned on"
else
  echo "SOLPS_PATH not set. Exiting."
endif


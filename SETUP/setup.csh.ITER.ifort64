# General
if ( -d $HOME/privatemodules ) then
  module use $HOME/privatemodules
endif
module use /work/imas/etc/modules/all

# Modules needed by SOLPS-ITER
set nodename=`hostname`
if (`grep -m1 NAME /etc/os-release | cut -d '"' -f 2 | cut -d ' ' -f 1` == "CentOS") then
  module load IMAS-AL-Fortran/5.2.1-intel-2020b-DD-3.41.0
  module load IMAS-AL-Python/5.2.1-intel-2020b-DD-3.41.0
  module load IDStools/1.14.1-intel-2020b
  module load GGD/1.11.0-intel-2020b-DD-3.41.0
  module load AMNS/1.5.0-intel-2020b-DD-3.41.0
  module load Viz/2.8.0-intel-2020b
  module load CMake/3.20.1-GCCcore-10.2.0
  module load xarray/0.16.2-intel-2020b
  module load makedepend/1.0.6-GCCcore-10.2.0
  module load MSCL/1.2.2-intel-2020b
  module load GR/0.0.94-GCCcore-10.2.0
  module load GLI/4.5.31-GCCcore-10.2.0
  module load NCL/6.6.2-intel-2020b
  module load NAG/26-intel-2020b
  module load Ghostscript/9.53.3-GCCcore-10.2.0
  module load Doxygen/1.8.20-GCCcore-10.2.0
  module load ParaView/5.10.0-intel-2020b-mpi
  module load PyQt5/5.15.1-GCCcore-10.2.0
  module load motif/2.3.8-intel-2020b
  module load gnuplot/5.4.1-GCCcore-10.2.0
  module load texlive/20210216-GCCcore-10.2.0
  module load libtirpc/1.3.1-GCCcore-10.2.0
  module load SimDB/0.7.1-intel-2020b
  module load ToFu/1.5.1-intel-2020b
  module load netcdf4-python/1.5.5.1-intel-2020b
  module load json-fortran/8.3.0-iccifort-2020.4.304
# module load MATLAB/2020b-GCCcore-10.2.0-Java-11
  setenv SYSNAME amd64_sles15
  setenv QTDIR ${EBROOTQT5}
  setenv GKSDIR /work/imas/opt/EasyBuild/software/GR/0.56.0-GCCcore-10.2.0
else
  # RHEL9: select the EasyBuild toolchain generation. Default is 2023b
  # (existing production toolchain). Set SOLPS_TOOLCHAIN_VERSION=2025b
  # before sourcing setup.csh to opt-in to the foss/intel 2025b stack.
  if (! $?SOLPS_TOOLCHAIN_VERSION) setenv SOLPS_TOOLCHAIN_VERSION 2023b
  echo Loading modules for $SOLPS_TOOLCHAIN_VERSION toolchain
  echo Use the SOLPS_TOOLCHAIN_VERSION environment variable to change this choice,
  echo delete the SETUP/setup.csh.ITER.ifort64.env.local.$USER file,
  echo and restart the session
  if ("$SOLPS_TOOLCHAIN_VERSION" == "2025b") then
    module use /work/imas/etc/modules-2025b/all
    module load git/2.54.0-GCCcore-14.3.0
    module load IMAS-Fortran/5.6.0-intel-2025b-DD-4.1.1
    module load IDStools/2.4.0-intel-2025b
    module load GGD/1.14.0-intel-2025b-DD-4.1.1
    module load AMNS/1.6.0-intel-2025b-DD-4.1.1
    module load CMake/4.0.3-GCCcore-14.3.0
    module load makedepend/1.0.9-GCCcore-14.3.0
    module load MSCL/1.2.5-GCCcore-14.3.0
    module load GR/0.0.94-GCCcore-14.3.0
    module load GLI/4.5.31-GCCcore-14.3.0
    module load NCL/6.6.2-intel-2025b
    module load netCDF/4.9.3-iimpi-2025b
    module load netCDF-Fortran/4.6.2-iimpi-2025b
    module load netcdf4-python/1.7.2-intel-2025b
    module load motif/2.3.8-GCCcore-14.3.0
    module load libtirpc/1.3.6-GCCcore-14.3.0
    module load Ghostscript/10.05.1-GCCcore-14.3.0
    module load Doxygen/1.14.0-GCCcore-14.3.0
    module load texlive/20250308-intel-compilers-2025.2.0
    module load SimDB/0.15.1-intel-2025b
    module load json-fortran/9.2.1-intel-compilers-2025.2.0
    module load IMAS-ParaView/2.3.0-intel-2025b
    setenv GKSDIR /work/imas/opt/EasyBuild/software/GR/0.73.6-intel-compilers-2025.2.0
  else
    module load IMAS-Fortran/5.5.0-intel-2023b-DD-4.1.0
    module load IDStools/2.4.0-intel-2023b
    module load GGD/1.14.0-intel-2023b-DD-4.1.0
    module load AMNS/1.6.0-intel-2023b-DD-4.1.0
    module load IMAS-ParaView/2.3.0-intel-2023b
    module load Viz/2.8.0-intel-2023b
    module load CMake/3.27.6-GCCcore-13.2.0
    module load xarray/2024.5.0-iimkl-2023b
    module load makedepend/1.0.9-GCCcore-13.2.0
    module load MSCL/1.2.4-iimkl-2023b
    module load GR/0.0.94-GCCcore-13.2.0
    module load GLI/4.5.31-GCCcore-13.2.0
    module load NCL/6.6.2-intel-2023b
    module load netCDF/4.9.2-iimpi-2023b
    module load netCDF-Fortran/4.6.1-iimpi-2023b
    module load NAG/26-intel-compilers-2023.2.1
    module load Ghostscript/10.02.1-GCCcore-13.2.0
    module load Doxygen/1.9.8-GCCcore-13.2.0
    module load motif/2.3.8-GCCcore-13.2.0
    module load texlive/20230313-intel-compilers-2023.2.1
    module load libtirpc/1.3.4-GCCcore-13.2.0
    module load SimDB/0.14.1-intel-2023b
    module load ToFu/1.7.9-iimkl-2023b
    module load netcdf4-python/1.7.1.post2-intel-2023b
    module load json-fortran/8.5.2-intel-compilers-2023.2.1
    setenv GKSDIR /work/imas/opt/EasyBuild/software/GR/0.73.6-GCCcore-13.2.0
  endif
  setenv SYSNAME x86_64_rhel9
  setenv QTDIR ${EBROOTQT6}
endif
module load Fundamental-Constants/0.2.0

setenv GGD_VERSION `pkg-config ggd --modversion`
setenv GLI_HOME ${EBROOTGLI}
setenv NCDIR ${EBROOTNETCDFMINFORTRAN}
setenv MPDIR ${EBROOTIMPI}
if ($?GKSDIR) then
  setenv LD_LIBRARY_PATH ${GKSDIR}/lib:${LD_LIBRARY_PATH}
else
  echo GKSDIR not defined!
  echo Graphic executables may not compile nor execute
endif

# Debugger (set environment variable DBX)
module load TotalView/2023.4.16_linux_x86-64
setenv DBX totalview

# Compilers
# intel-compilers/2023.2.1 still ships ifort; intel-compilers/2025.2.0 ships
# ifx only. Detect at runtime so this file stays backwards-compatible.
which ifort >& /dev/null
if ($status == 0) then
  setenv FC ifort
  setenv MPI_FC mpiifort
  setenv CXX icpc
  setenv CC icc
else
  setenv FC ifx
  setenv MPI_FC mpiifx
  setenv CXX icpx
  setenv CC icx
endif

if (`where paraview-config` == "") then
  echo "Warning: paraview-config not found. ParaView with Catalyst will not be compiled-in!"
else if ("$SOLPS_TOOLCHAIN_VERSION" == "2025b") then
  echo "Warning: Catalyst engine not yet functional in 2025b toolchain"
  echo "due to CMake incompatibilities"
else
  # See ParaViewCatalystUsersGuide_v2.pdf Sec 3.7.2 Linking with Python ...
  setenv PARAVIEW_MAJOR_VERSION `paraview --version | cut -d '.' -f 1 | cut -d ' ' -f 3`
  setenv CMAKE_MAJOR_VERSION `cmake --version | head -1 | cut -d ' ' -f 3 | cut -d '.' -f 1`
  if (${CMAKE_MAJOR_VERSION} > 2) then
    module switch CMake/3.18.4
    setenv LD_CATALYST `paraview-config --ldflags -c PythonCatalyst -v CommonDataModel`
    module switch CMake/3.27.6-GCCcore-13.2.0
    # Avoid a naming clash
    unsetenv BOOST_ROOT
    setenv PARAVIEW_INCLUDE `paraview-config --cppflags`
    setenv BOOST_ROOT ${EBROOTBOOST}
  else
#   setenv PARAVIEW_LIB `paraview-config --libs --python | sed s/-L//`
#   setenv LD_LIBRARY_PATH "${PARAVIEW_LIB}:${LD_LIBRARY_PATH}"
#   setenv PYTHONPATH "${PARAVIEW_LIB}/site-packages/vtk:${PYTHONPATH}"
#   setenv PYTHONPATH "${PARAVIEW_LIB}/site-packages:${PYTHONPATH}"
    setenv LD_CATALYST `paraview-config --libs vtkPVPythonCatalyst`
    setenv PARAVIEW_INCLUDE `paraview-config --include`
  endif
  setenv LD_CATALYST "-shared-intel ${LD_CATALYST} -lstdc++"
endif

# Try to load SOLPS GUI locally (for developers)
if (! $?SOLPS_GUI_PREFIX) then
  foreach dir (${HOME}/solps-gui ${HOME}/SOLPS-GUI ${SOLPSTOP}/modules/solps-gui)
    if ( -d ${dir} ) setenv SOLPS_GUI_PREFIX ${dir}
  end
endif
if ($?SOLPS_GUI_PREFIX) then
  setenv QT_API PySide6
  setenv PYTHONPATH "${SOLPS_GUI_PREFIX}/src/actors:${PYTHONPATH}"
  setenv PYTHONPATH "${SOLPS_GUI_PREFIX}/src/gui:${PYTHONPATH}"
  setenv PYQTDESIGNERPATH "${SOLPS_GUI_PREFIX}/src/plugins/designer"
  setenv PYSIDE_DESIGNER_PLUGINS "${SOLPS_GUI_PREFIX}/src/plugins/pyside6-designer"
  setenv SOLPSGUI "${SOLPS_GUI_PREFIX}/src/gui"
  alias solps 'python3 ${SOLPS_GUI_PREFIX}/src/gui/solps.py'
  alias solps5 'env PYTHONPATH=${SOLPS_GUI_PREFIX}/src/widgets:${PYTHONPATH} python3 ${SOLPS_GUI_PREFIX}/src/gui/solps5.py'
  alias designer "env PYTHONPATH=${SOLPS_GUI_PREFIX}/src/widgets:${PYTHONPATH} ${QTDIR}/bin/designer"
  alias solps_doc 'env --unset LD_LIBRARY_PATH firefox ${SOLPS_GUI_PREFIX}/doc/build/html/index.html'
  alias eirene 'python3 ${SOLPS_GUI_PREFIX}/src/actors/eirene.py'
  alias b2 'python3 ${SOLPS_GUI_PREFIX}/src/actors/b2.py'
else
  if `module is-avail SOLPS-GUI` then
    module load SOLPS-GUI
  endif
endif

# Other environment variables
setenv SOLPSWORK /work/projects/solps-iter/$USER
setenv SCRATCH_DIR /scratch/users/$USER

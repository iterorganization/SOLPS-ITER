echo setup.ksh.local
export SOLPS_CPP="$SOLPS_CPP -DTRIANG"
if [ ! $?EIRENE_DEFINES ] ; then
  export EIRENE_DEFINES="-DNO_FORT10 -DNO_SHORT_CYCLE"
else
  export EIRENE_DEFINES="$EIRENE_DEFINES -DNO_FORT10 -DNO_SHORT_CYCLE"
fi

export B2PLOT_DEV=ps

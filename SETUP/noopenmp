if ($?SOLPS_PATH) then
  setenv   OLD_SOLPS_PATH $SOLPS_PATH
  if ($?OLD_COMPILER) then
    setenv FC $OLD_COMPILER
  endif
  if ($?OLD_MPI_COMPILER) then
    setenv MPI_FC "$OLD_MPI_COMPILER"
  endif
  setenv   PATH `echo $PATH | sed "s|${SOLPS_PATH}:||"`
  setenv   SOLPS_PATH `echo $SOLPS_PATH | sed 's|\.openmp||g'`
  setenv   PATH "${SOLPS_PATH}:${OLD_PATH}"
  unsetenv OLD_SOLPS_PATH SOLPS_OPENMP USE_OPENMP
  setenv   OMP_DISPLAY_AFFINITY false
  setenv   OMP_DISPLAY_ENV false
  unsetenv OMP_PROC_BIND
  unsetenv OMP_PLACES
  rehash
  echo "SOLPS-ITER OpenMP mode turned off"
else
  echo "SOLPS_PATH not set. Exiting."
endif


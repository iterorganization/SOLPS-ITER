# General

# Modules needed by SOLPS-ITER
module load intel/2021a
module load git/2.32.0-GCCcore-10.3.0-nodocs
module load makedepend/1.0.6-GCCcore-10.3.0
module load netCDF/4.8.0-iimpi-2021a
module load netCDF-Fortran/4.5.3-iimpi-2021a
module load NCL/6.6.2-intel-2021a
module load Doxygen/1.9.1-GCCcore-10.3.0
module load libxml2/2.9.10-GCCcore-10.3.0
module load matplotlib/3.4.2-intel-2021a
module load motif/2.3.8-GCCcore-10.3.0
module load Pango/1.48.5-GCCcore-10.3.0
module load PETSc/3.15.1-intel-2021a
module load ArmForge/22.1.2
module load gnuplot/5.4.2-GCCcore-10.3.0
module load MATLAB/2023a-r7
# module load cluster/genius/batch

# Debugger env var
setenv DBX ddt
# Compiler env var
setenv FC ifort

# Other environment variables
setenv STGDIR /staging/leuven/stg_00030/SOLPS/lib/LEUVEN-WICE.ifort64
setenv ALLINEA_NO_MPI_AUTODETECT false
setenv TAPENADEDIR  /staging/leuven/stg_00030/tapenade
#module load Java/1.8.0_192
# setenv PETSC_DIR /staging/leuven/stg_00030/petsc_wice # set this only if using local PETCs installation
# setenv PETSC_ARCH arch-linux-c-debug # set this only if using local PETCs installation
if ($?PETSC_DIR) then
  setenv LD_LIBRARY_PATH ${LD_LIBRARY_PATH}:${PETSC_DIR}/lib
  setenv PETSC_VERSION_MAJOR `grep -i PETSC_VERSION_MAJOR $PETSC_DIR/include/petscversion.h | head -n 1 | awk '{print $3}'`
  setenv PETSC_VERSION_MINOR `grep -i PETSC_VERSION_MINOR $PETSC_DIR/include/petscversion.h | head -n 1 | awk '{print $3}'`
  setenv PETSC_VERSION $PETSC_VERSION_MAJOR$PETSC_VERSION_MINOR
  unsetenv PETSC_VERSION_MAJOR PETSC_VERSION_MINOR
  if ($PETSC_VERSION > 316) then
    setenv TAO_NEW yes
  endif
endif
alias set_d 'source $SOLPSTOP/scripts/diff_d'
alias set_b 'source $SOLPSTOP/scripts/diff_b'

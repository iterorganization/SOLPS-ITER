#
# Specify paths to root-directories of following libraries on your system
#
# Special notes:
#
# If you have NCAR version 3 on your system:
# Remove -DNCAR4 from SOLPS_CPP
#
# If you do not have NAG on your system:
# Use LD_NAG to link to the BLASLAPACK library instead
# Add -DNO_NAG to SOLPS_CPP
#
# If you have NAG Mark 17 or greater on your system:
# Add -DNO_F01AAF to SOLPS_CPP
#
# If you have NAG Mark 22 or greater on your system:
# Add -DNAG22 to SOLPS_CPP
#
# If your compiler does not support Fortran 2003 features:
# Add -DLEGACYCOMP to SOLPS_CPP
#

NO_MANUAL = 1

#       NCDIR = `nf-config --cflags`
   MSCL_ROOT ?= ${SOLPSTOP}/../${COMPILER}/mscl
       H5DIR ?= ${SOLPSLIB}
     GR_ROOT ?= ${SOLPSTOP}/../${COMPILER}/gr
    GLI_HOME ?= ${SOLPSTOP}/../${COMPILER}/gks
  NCARG_ROOT ?= ${SOLPSTOP}/../${COMPILER}/NCARG
      NAGDIR ?= ${SOLPSTOP}/../${COMPILER}/nag
 MDSPLUS_DIR ?= ${SOLPSTOP}/../${COMPILER}/MDSPLUS
  CAIRO_ROOT ?= ${SOLPSTOP}/../${COMPILER}/cairo
FREE_TYPE_ROOT ?= ${SOLPSTOP}/../${COMPILER}/free_type

       MPDIR ?=

#
# Variables for linking
#

LD_NETCDF  = `nf-config --flibs`
LD_MSCL    = -L${MSCL_ROOT}/lib -lmscl
LD_GR      = -L${GR_ROOT}/lib -lgr
LD_GKS     = -L${GLI_HOME}/lib -lgks
LD_CAIRO   = -L${CAIRO_ROOT}/lib -lcairo
LD_NCARG   = -L${NCARG_ROOT}/lib -lncarg -lncarg_gks -lncarg_c -L/usr/lib64 -lX11 -lxcb -lm -L${FREETYPE_ROOT}/lib -lfreetype ${LD_CAIRO}
LD_NAG     = -L${NAGDIR}/lib -lnag_nag
LD_MDSPLUS = -L${MDSPLUS_DIR}/lib -lMdsLib_client -lMdsShr -lMdsIpShr -lTdiShr -lTreeShr
LD_SONNET  = -L${SOLPSLIB}/lib -lsonnet -lstdc++
LD_MPI     = -L${MPDIR}/lib -lmpi

LIBGKS     = ${GLI_HOME}/lib/libgks.a
LIBGRS     = ${GR_ROOT}/lib/libgr.a
LIBX11     = /usr/lib64/libX11.so
LIBXT      = /usr/lib64/libXt.so
LIBZ       = /usr/lib64/libz.so

#
# Provide compiler
#

MPI_FC    ?= mpiifort
ifdef SOLPS_MPI
FC         = ${MPI_FC}
endif

#
# Preprocessor options
#

SOLPS_CPP      = -DNO_NAG -DNCAR4
B25_DEFINES    =
CARRE_DEFINES  =
EIRENE_DEFINES =
FFLAGSEXTRA    =
MPI_CPP        = -I${MPDIR}/include


#!!!Local Variables:
#!!! mode: Makefile
#!!! End:


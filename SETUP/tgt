if ($?SOLPS_PATH) then
  # Check whether HOST_NAME and COMPILER are defined
  if (! $?HOST_NAME) then
    echo "HOST_NAME not defined. Exiting."
    exit 1
  endif
  if (! $?COMPILER) then
    echo "COMPILER not defined. Exiting."
    exit 1
  endif

  # Pragmatic approach: assume for now only B2.5 has tangent version
  setenv   OLD_SOLPS_PATH   $SOLPS_PATH
  setenv   PATH `echo $PATH | sed "s|${SOLPS_PATH}:||"`
  setenv   SOLPS_PATH `echo $SOLPS_PATH | sed 's|\.tgt||g'` # remove .tgt if already present
  setenv   SOLPS_PATH `echo $SOLPS_PATH | sed "s|B2.5/builds/standalone.${HOST_NAME}.${COMPILER}|B2.5/builds/standalone.${HOST_NAME}.${COMPILER}.tgt|g"`
  setenv   PATH ${SOLPS_PATH}:${OLD_PATH}
  setenv   SOLPS_TGT yes
  unsetenv OLD_SOLPS_PATH SOLPS_ADJ
  rehash
  echo "SOLPS-ITER TGT mode turned on"
else
  echo "SOLPS_PATH not set. Exiting."
endif

# General
if ( -d $HOME/privatemodules ) then
  module use $HOME/privatemodules
endif
module use /work/imas/etc/modules/all

# Modules needed by SOLPS-ITER
module load NAGfor/6.2.14
set nodename=`hostname`
if (`grep -m1 NAME /etc/os-release | cut -d '"' -f 2 | cut -d ' ' -f 1` == "CentOS") then
  module load makedepend/1.0.6-GCCcore-10.2.0
  module load MSCL/1.2.3-GCCcore-10.2.0
  module load GR/0.0.94-GCCcore-10.2.0
  module load GLI/4.5.31-GCCcore-10.2.0
  module load flex/2.6.4-GCCcore-10.2.0
  module load netCDF-Fortran/4.5.3-gompi-2020b
  module load Ghostscript/9.53.3-GCCcore-10.2.0
  module load OpenBLAS/0.3.12-GCC-10.2.0
  module load motif/2.3.8-GCCcore-10.2.0
  module load gnuplot/5.4.1-GCCcore-10.2.0
  module load texlive/20210216-GCCcore-10.2.0
# module load MATLAB/2020b-GCCcore-10.2.0-Java-11
  module load PyYAML/5.3.1-GCCcore-10.2.0
  module load matplotlib/3.3.3-foss-2020b
  module load xarray/0.16.2-foss-2020b
  module load CMake/3.20.1-GCCcore-10.2.0
# module load ParaView/5.10.0-foss-2020b-mpi
  module load PyQt5/5.15.1-GCCcore-10.2.0
  module load Doxygen/1.8.20-GCCcore-10.2.0
  module load libtirpc/1.3.1-GCCcore-10.2.0
  module load SimDB/0.7.1-foss-2020b
  setenv SYSNAME amd64_sles15
  setenv GKSDIR /work/imas/opt/EasyBuild/software/GR/0.56.0-GCCcore-10.2.0
else
  module load makedepend/1.0.9-GCCcore-13.2.0
  module load MSCL/1.2.5-GCCcore-13.2.0
  module load GR/0.0.94-GCCcore-13.2.0
  module load GLI/4.5.31-GCCcore-13.2.0
  module load NCL/6.6.2-foss-2023b
  module load flex/2.6.4-GCCcore-13.2.0
  module load netCDF-Fortran/4.6.1-gompi-2023b
  module load Ghostscript/10.02.1-GCCcore-13.2.0
  module load OpenBLAS/0.3.24-GCC-13.2.0
  module load motif/2.3.8-GCCcore-13.2.0
  module load texlive/20230313-GCC-13.2.0
  module load xarray/2024.5.0-gfbf-2023b
  module load CMake/3.27.6-GCCcore-13.2.0
# module load ParaView/5.12.0-foss-2023b
  module load Qt5/5.15.13-GCCcore-13.2.0
  module load Doxygen/1.9.8-GCCcore-13.2.0
  module load libtirpc/1.3.4-GCCcore-13.2.0
  module load SimDB/0.11.0-gfbf-2023b
  module load netcdf4-python/1.6.5-foss-2023b
  setenv SYSNAME x86_64_rhel9
  setenv GKSDIR /work/imas/opt/EasyBuild/software/GR/0.73.6-GCCcore-13.2.0
endif
module load Fundamental-Constants/0.1.1

setenv GLI_HOME ${EBROOTGLI}
setenv NCDIR ${EBROOTNETCDFMINFORTRAN}
setenv QTDIR ${EBROOTQT5}

# Debugger (set environment variable DBX)
module load TotalView/2023.4.16_linux_x86-64
setenv DBX totalview

# Compilers
setenv CC gcc
setenv FC nagfor
setenv CXX g++

if (`where paraview-config` == "") then
  echo "Warning: paraview-config not found. ParaView with Catalyst will not be compiled-in!"
else
  # See ParaViewCatalystUsersGuide_v2.pdf Sec 3.7.2 Linking with Python ...
  setenv PARAVIEW_MAJOR_VERSION `paraview --version | cut -d '.' -f 1 | cut -d ' ' -f 3`
  setenv CMAKE_MAJOR_VERSION `cmake --version | head -1 | cut -d ' ' -f 3 | cut -d '.' -f 1`
  if (${CMAKE_MAJOR_VERSION} > 2) then
    setenv LD_CATALYST `paraview-config --ldflags -c PythonCatalyst -v CommonDataModel`
    setenv PARAVIEW_INCLUDE `paraview-config --cppflags`
  else
#   setenv PARAVIEW_LIB `paraview-config --libs --python | sed s/-L//`
#   setenv LD_LIBRARY_PATH "${PARAVIEW_LIB}:${LD_LIBRARY_PATH}"
#   setenv PYTHONPATH "${PARAVIEW_LIB}/site-packages/vtk:${PYTHONPATH}"
#   setenv PYTHONPATH "${PARAVIEW_LIB}/site-packages:${PYTHONPATH}"
    setenv LD_CATALYST `paraview-config --libs vtkPVPythonCatalyst`
    setenv PARAVIEW_INCLUDE `paraview-config --include`
  endif
  setenv LD_CATALYST "${LD_CATALYST} -lstdc++"
endif

# Other environment variables
unsetenv MPLBACKEND
setenv LD_LIBRARY_PATH ${LD_LIBRARY_PATH}:/usr/lib64
setenv SOLPSWORK /work/projects/solps-iter/$USER
setenv SCRATCH_DIR /scratch/users/$USER
setenv PYTHONPATH "/work/imas/opt/SOLPS-GUI/1.5/src/widgets:${PYTHONPATH}"
setenv PYQTDESIGNERPATH "/work/imas/opt/SOLPS-GUI/1.5/src/plugins/designer"
setenv SOLPSGUI "/work/imas/opt/SOLPS-GUI/1.5/src/gui"
alias solps 'python3 /work/imas/opt/SOLPS-GUI/1.5/src/gui/solps.py'
alias solps_doc 'xdg-open /work/imas/opt/SOLPS-GUI/1.5/doc/build/html/index.html'
alias solps_help 'assistant -collectionFile /work/imas/opt/SOLPS-GUI/1.5/doc/build/qthelp/SOLPSGUI.qhc'
alias eirene 'python3 /work/imas/opt/SOLPS-GUI/1.5/src/widgets/eirene.py'
alias b2 'python3 /work/imas/opt/SOLPS-GUI/1.5/src/widgets/b2.py'

alias GVS='ghostview $GV_OPT B2save_1/trc.ps &'
alias GVT='ghostview $GV_OPT -geometry +700+650 trc.ps &'
#alias GVT='ghostview $GV_OPT -geometry +188+237 trc.ps &'
alias GV4='ghostview $GV_OPT trc4.ps &'
alias GG='GVT GVP'
alias G2='ghostview  -landscape -bg white -magstep 2 -geometry +500+500 ers-dps.ps &'

alias GT='grep "iteration number" b2.log | grep " 40 "'
alias GT1='grep "iteration number" b2.log | grep " 40 " | grep -e -00\*[01]'
alias GT2='grep "iteration number" b2.log | grep " 40 " | grep -e -00\*[012]'
alias GT4='grep "iteration number" b2.log | grep " 40 " | grep -e -00\*[0-4]'
alias GT6='grep "iteration number" b2.log | grep " 40 " | grep -e -00\*[0-6]'

alias TWC='time cat B2SDIAG B2SXDR fort.15 fort.30 fort.31 fort.44 *.dat last_2dir/* peak_power tracing/* trc* | wc -c'

alias RE='[ -r diag2.eir ] && nice -10 time eirobj diag2.eir >eir.log&'
alias NE='[ -r EXTRA.ers ] && nc EXTRA.ers'
alias PE='set -- C*.ers; [ $# = 1 ] && {
    C=$1; [ -s "$C" ] && {
      nc $C; [ -d ,Iterations ] || mkdir -p ,Iterations/00
      [ -d ,Iterations ] && {
        N=XXX
        D=${PWD##*/}
        [ "${D%-C}" = "$D" ] && {
          [ -r VarID ] && {
            set -- `cat VarID | tr \#_ "  "`
            [ -n "$2" ] && N=$2
          }
        } || {
          N=${D%-C}
        }
        i=`ls ,Iterations | tail -1`
        i=${i#0}
        [ $i -ge 0 ] && let i=i+1
        plot_set -t $N-$i er-dp.cms && {
          ghostview  -landscape -bg white -magstep 2 -geometry +500+500 ers-dps.ps &
        }
      }
      true
    }
  } || {
    echo "No unique erosion data file: C*.ers"
  }'
[ "$B2E_SLAVE" = yes ] && {
  alias TR='[ -f B2SXDR ] && (
    rm -r tmp 2>/dev/null; saveb2 -a tmp; cd tmp && { 
      rm -r trc4.ps param.dg traces_all 2>/dev/null; set -- ../*.tgz; [ "$#" = 1 ] && [ -f "$1" ] && {
        tar czf "$1" *; true
      } || {
        echo "Enter the filename for tgz or Ctrl-c to quit"
        read u; u=${u%.tgz}.tgz; u=${u#../}; [ "${u#/}" = "$u" ] && u="../$u"
        echo "$u"; pwd; tar czf "$u" *
      }
    }
  )'
  alias TE='(set -- *.ers; [ -f "$1" ] && {
      c=${PWD##*/}; c=${c%/}
      rm -r ,Iterations/* 2>/dev/null; saveb2 -e; cd ,Iterations/00 && {
        rm b2.parameters diag2.eir fort.31 gli.eps gm_test.dat fort.44
        tar czf "../../$c.tgz" *; true
      }
    }
  )'   
  true
} || {
  [ -s ~/.pacherpc ] && p=`cat ~/.pacherpc` || p=207.162.24.163
  alias GHR="(d=\${PWD%/}; d=\${d##*/}; 
      set -- *.tgz; [ \"\$#\" = 1 ] && [ -f \"\$1\" ] && {
      time sscp pacher@$p:/arch/B2E/solps4.0/src/B2Eirene/\$d/\$1 .
      true
    } || {
      echo \"Enter the filename for tgz or Ctrl-c to quit\"
      read u; u=\"\${u%.tgz}.tgz\"
      time sscp pacher@$p:/arch/B2E/solps4.0/src/B2Eirene/\$d/\$u .
    }
  )" 
  alias PHR="d=\${PWD%/}; d=\${d##*/}; echo \$d 
    [ \"\$d\" = \"\${PWD#\$SOLPSTOP/src/B2Eirene/}\" ] && {
    [ -s last_2d_vfile_case ] || touch last_2d_vfile_case
    time sscp b2.parameters input.eir param.dg RES last_2d_vfile_case pacher@$p:/arch/B2E/solps4.0/src/B2Eirene/\$d
    true
  } || {
    echo \"This alias only works in a first-level subdirectory of \$SOLPSTOP/src/B2Eirene\"
  }"
  alias GHE="c=\${PWD##*/}; 
    time sscp pacher@$p:/arch/B2E/solps4.0/src/B2Eirene/\$c/\$c.tgz ."
  alias PHE="sscp diag2.eir pacher@$p:/arch/B2E/solps4.0/src/B2Eirene/\${PWD##*/}"
  alias PHF="c=\${PWD##*/}; rm -r tmp 2>/dev/null; mkdir tmp && {
    cp diag2.eir fort.3[01] VarID Label tmp; (cd tmp && tar czf "../\$c.tgz" *)
    time sscp "\$c.tgz" pacher@$p:/arch/B2E/solps4.0/src/B2Eirene/\$c
    rm -r tmp
  }"
  alias PHS="d=\${PWD%/}; d=\${d##*/}; echo \$d
    c=; set -- *.tgz; [ \"\$#\" = 1 ] && [ -f \"\$1\" ] && c=\${1%.tgz}
    u=; [ -n \"\$c\" ] && u=\"(\$c)\"
    echo \"Enter the filename for tgz \$u or Ctrl-c to quit\"
    read u
    [ -n \"\$u\" ] && c=\$u
    rm -r tmp 2>/dev/null; mkdir tmp && {
      cp B2SXDR Label RES VarID B2E.version b2.parameters box.b2p flx_blnc.log fort.13 fort.15 fort.3[01] input.eir mesh.extra param.dg last_2d_vfile_case tmp
      . triang.conf
      unset u l
      for x in \$TRIAFTN; do {
        [ -s fort.\$x ] && l=\"\$l fort.\$x\" || u=n
      }; done
      [ -z \"\$u\" ] && tar cf - \$l | (cd tmp && tar xf -)
      (cd tmp && tar czf \"../\$c.tgz\" *)
      time sscp \"\$c.tgz\" pacher@$p:/arch/B2E/solps4.0/src/B2Eirene/\$d
      rm -r tmp
    }"
  alias PHZ="(set -- *.tgz; [ \"\$#\" = 1 ] && [ -f \"\$1\" ] && {
      s=\${SOLPSTOP%/*}; dd=\${PWD%/}; d=\${dd#\$s/}; [ \"\$dd\" = \"\$d\" ] || dd=/arch/B2E/\$d
      echo \"\$d ==> pacher@$p:\$dd\"
      time sscp \"\$1\" pacher@$p:\$dd
      true
    } || {
      echo \"No unique *.tgz file\"
    }
  )"
}

alias XR='(set -- *.tgz; [ "$#" = 1 ] && [ -f "$1" ] && {
    ll "$1"; tar xzf "$1" && { rm "$1"; touch "$1"; }
  }
)'

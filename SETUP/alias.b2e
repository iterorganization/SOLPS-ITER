export em=~/em/solps4.0
export XGKSFontDir=$SOLPSTOP/lib/xgks/lib/xgksfonts
export COLUMNS
export GV_OPT='-landscape -bg white -magstep -2 -geometry +5+5'
#export GV_OPT='-landscape -bg white -magstep -1 -geometry +5+5'
alias lz='ls -l --color=none *.tgz'
alias CF="upd_trc -V"
alias CR='cat RES'
alias CT='[ -s \#TAU ] && cat \#TAU'
alias EO='echo $OBJECTCODE'
alias GC="upd_trc -v"
alias GSM='(cd $SOLPSTOP/data/Summary_plots/summary/SERIES && {
    for f in */series_map.ps */op_wndw.ps */dt_sprd.ps; do
      GV $f &
    done; } )'
alias LL='ls -l B*/B2SXDR B2SXDR trc.ps b2.log time_dep/tmp3d.ps tracing last_2dir'
alias LB='ls -l B2save_1'
alias SLD='last_2d_setup'

#alias G='time getstuff -n'
alias G='time getstuff -n; VL'
alias GF='time getstuff -n -t'
alias GL='time getstuff -l'
alias GTST='time getstuff'
alias LF25='ln -s $SOLPSTOP/data/STRAHL fort.25'

#alias LW='last_2d_write > LW.log 2>&1 & sleep 3; tail -f LW.log'
alias LW='(last_2d_write; echo; echo "  Done!"; echo) > LW.log 2>&1 & sleep 3; tail -f LW.log'
alias MBS='mv b2.parameters b2.parameters.src; [ -a input.eir~ ] && rm input.eir~'
alias MD='make depend'
alias MI='make install'
alias MJ='make -j2  > make.log 2> make.err; cat make.err'
alias MM='make -j2 mods > make.mods.log 2> make.mods.err; cat make.mods.err'
alias MT='mkdir TRASH'
alias NB='nc b2.parameters'
alias NF='[ -s flx_blnc.log ] && nc flx_blnc.log'
alias NI='nc b2.parameters b2.parameters.src input.eir'
alias NLL='nc last_2dir/last_2d_out'
#alias NL='u=last_2dir/last_2d_outavgint_f; [ -s $u ] || u=last_2dir/last_2d_outvar; [ -s $u ] || u=last_2dir/last_2d_out;  nc $u'
alias NL='u=last_2dir/last_2d_outavgint_f; for f in outvar_f outvar out; do [ -s $u ] || u=last_2dir/last_2d_$f; done;  nc $u'
alias NR='nc RES'
alias NT='nc \#TAU'
alias NTU='nc tracing/user.trc'
alias NTS='nc tracing/seldom.trc'
alias S15='setnice 15'
alias SB='saveb2 ='
alias SE='saveb2 -e'
alias RME='rm -r `saveb2 -e`'
alias RDG='[ -s Active_runs ] && for i in `cat Active_runs`; do dg $i.dg; sleep 5; done'
alias SL='[ -s Local_Copy ] && { c=`cut -f1 -d: Local_Copy`;
            dd=`cut -f2 -d: Local_Copy`; d=${dd#/local/}
            [ -n "$d" ] && [ ! "$d" = "$dd" ] && cd "/scratch/$c/$d"
          } || cd `cat /tmp/B2_Eirene`; ST'
alias WC='wc -l time_dep/traces'
alias WWC='wc -l */time_dep/traces'

alias WWW='[ -r ~/.active_WS ] && (
              l=
              for d in `cat ~/.active_WS`; do {
                f="/scratch/$d/B2E/solps4.0/src/B2Eirene/*/time_dep/traces"
                set $f
                [ -s $1 ] && l="$l $f"
              }; done
              l=$l
              [ -n "$l" ] && for d in $l; do {
                set -- `wc -l $d`
                l=$1
                while [ "${#l}" -lt 6 ]; do l=" $l"; done
                set -- `ls -gG $d`
                shift 3
                echo "$l $*"
              }; done
              unset l d
              true
            ) || (
              f="/scratch/[epn]*/B2E/solps4.0/src/B2Eirene/*/time_dep/traces"
              set $f
              [ -s $1 ] && wc -l $f
            )'

alias CLA='export DEVICE=aug'
alias CLB='export DEVICE=blob'
alias CLC='export DEVICE=cmod'
alias CLD='export DEVICE=d3d'
alias CLE='export DEVICE=jet'
alias CLH='export DEVICE=ht7u'
alias CLI='export DEVICE=iter'
alias CLM='export DEVICE=iterm'
alias CLO='export DEVICE=demo'

alias BPL='rm -f b2p.log > /dev/null 2>&1; nohup b2pl > b2p.log 2>&1 &'
alias BPLP='rm -f b2p.log > /dev/null 2>&1; nohup b2pl -ps > b2p.log 2>&1 &'
alias BPP='rm -f b2p.log > /dev/null 2>&1; nohup b2pp > b2p.log 2>&1 &'
alias BPPP='rm -f b2p.log > /dev/null 2>&1; nohup b2pp -ps > b2p.log 2>&1 &'
alias FT='grep " F_tot_" last_2dir/last_2d_out'
alias GE='grep ERROR b2.log | grep -v STATISTICAL'
alias GH='ghostview $GV_OPT time_dep/*3d.ps &'
alias GHS='ghostview $GV_OPT B2save_1/time_dep/*3d.ps &'
alias GT='grep "iteration number" b2.log'
alias GVB='ghostview $GV_OPT part_blnc.ps &'
alias GVP='if [ -s traces_all/trcp.ps ]; then
              ghostview $GV_OPT -geometry +700+25 traces_all/trcp.ps &
              true
            else
              ghostview $GV_OPT -geometry +700+25 trc.ps &
            fi'

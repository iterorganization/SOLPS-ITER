if ($?SOLPS_PATH) then
  # Check whether HOST_NAME and COMPILER are defined
  if (! $?HOST_NAME) then
    echo "HOST_NAME not defined. Exiting."
    exit 1
  endif
  if (! $?COMPILER) then
    echo "COMPILER not defined. Exiting."
    exit 1
  endif

  unsetenv TAO
  setenv OPT ipopt
  setenv IPOPT yes
  echo "Ipopt compilation and optimization turned on"
else
  echo "SOLPS_PATH not set. Exiting."
endif


# General
if ( -d $HOME/privatemodules ) then
  module use $HOME/privatemodules
endif
if ( -d ${PWD}/easybuild.local/modules/all ) then
  module use ${PWD}/easybuild.local/modules/all
endif
if ( -d  ${PWD}/easybuild.local/modules/all ) then
  module use ${PWD}/easybuild.local/modules/all
endif

# Use the same configs as ITER
setenv HOST_NAME ITER

# Modules needed by SOLPS-ITER
  module load IMAS-AL-Fortran/5.4.0-intel-2023b-DD-4.0.0
  module load IMAS-AL-Python/5.4.0-intel-2023b-DD-4.0.0
  module load IDStools/2.0.0-iimkl-2023b
  module load GGD/1.13.0-intel-2023b-DD-4.0.0
  module load AMNS/1.6.0-intel-2023b-DD-4.0.0
  module load Viz/2.8.0-intel-2023b
  module load CMake/3.20.1-GCCcore-13.2.0
  module load xarray/2024.5.0-iimkl-2023b
  module load makedepend/1.0.9-GCCcore-13.2.0
  module load MSCL/1.2.4-iimkl-2023b
  module load GR/0.0.94-GCCcore-13.2.0
  module load GLI/4.5.31-GCCcore-13.2.0
  module load NCL/6.6.2-intel-2023b
  module load netCDF/4.9.2-iimpi-2023b
  module load netCDF-Fortran/4.6.1-iimpi-2023b
# module load NAG/26-intel-compilers-2023.2.1
  module load Ghostscript/10.02.1-GCCcore-13.2.0
  module load Doxygen/1.9.8-GCCcore-13.2.0
#  module load ParaView/5.12.0-foss-2023b-Qt5
  module load Qt5/5.15.13-GCCcore-13.2.0
  module load motif/2.3.8-GCCcore-13.2.0
  module load texlive/20230313-intel-compilers-2023.2.1
  module load libtirpc/1.3.4-GCCcore-13.2.0
  module load SimDB/0.11.0-iimkl-2023b
  module load ToFu/1.7.9-iimkl-2023b
  module load netcdf4-python/1.6.5-intel-2023b
  module load json-fortran/8.5.2-intel-compilers-2023.2.1
  setenv SYSNAME x86_64_rhel9
  setenv GKSDIR `(module show GR/0.73.6-GCCcore-13.2.0)|& grep EBROOTGR|grep -o '/[^"]*'`

module load Fundamental-Constants/0.1.1

#module load OpenBLAS/0.3.24-GCC-13.2.0

setenv GGD_VERSION `pkg-config ggd --modversion`
setenv GLI_HOME ${EBROOTGLI}
#setenv QTDIR ${EBROOTQT5}
setenv NCDIR ${EBROOTNETCDFMINFORTRAN}
setenv MPDIR ${EBROOTIMPI}

# Debugger (set environment variable DBX)
#module load TotalView/2023.4.16_linux_x86-64
setenv DBX gdb

# Compilers
  setenv FC ifx
  setenv MPI_FC "mpiifort -fc=mpiifx"
  setenv CXX icpx
  setenv CC icx

if (`where paraview-config` == "") then
  echo "Warning: paraview-config not found. ParaView with Catalyst will not be compiled-in!"
else
  # See ParaViewCatalystUsersGuide_v2.pdf Sec 3.7.2 Linking with Python ...
  setenv PARAVIEW_MAJOR_VERSION `paraview --version | cut -d '.' -f 1 | cut -d ' ' -f 3`
  setenv CMAKE_MAJOR_VERSION `cmake --version | head -1 | cut -d ' ' -f 3 | cut -d '.' -f 1`
  if (${CMAKE_MAJOR_VERSION} > 2) then
    setenv LD_CATALYST `paraview-config --ldflags -c PythonCatalyst -v CommonDataModel`
    setenv PARAVIEW_INCLUDE `paraview-config --cppflags`
  else
#   setenv PARAVIEW_LIB `paraview-config --libs --python | sed s/-L//`
#   setenv LD_LIBRARY_PATH "${PARAVIEW_LIB}:${LD_LIBRARY_PATH}"
#   setenv PYTHONPATH "${PARAVIEW_LIB}/site-packages/vtk:${PYTHONPATH}"
#   setenv PYTHONPATH "${PARAVIEW_LIB}/site-packages:${PYTHONPATH}"
    setenv LD_CATALYST `paraview-config --libs vtkPVPythonCatalyst`
    setenv PARAVIEW_INCLUDE `paraview-config --include`
  endif
  setenv LD_CATALYST "-shared-intel ${LD_CATALYST} -lstdc++"
endif

# Try to load SOLPS GUI locally (for developers)
if (! $?SOLPS_GUI_PREFIX) then
  foreach dir (${HOME}/solps-gui ${HOME}/SOLPS-GUI ${SOLPSTOP}/modules/solps-gui)
    if ( -d ${dir} ) setenv SOLPS_GUI_PREFIX ${dir}
  end
endif
if ($?SOLPS_GUI_PREFIX) then
  module load PySide6/6.6.2-GCCcore-13.2.0
  module load matplotlib/3.8.2-iimkl-2023b
  setenv QT_API PySide6
  setenv PYTHONPATH "${SOLPS_GUI_PREFIX}/src/actors:${PYTHONPATH}"
  setenv PYTHONPATH "${SOLPS_GUI_PREFIX}/src/gui:${PYTHONPATH}"
  setenv PYQTDESIGNERPATH "${SOLPS_GUI_PREFIX}/src/plugins/designer"
  setenv PYSIDE_DESIGNER_PLUGINS "${SOLPS_GUI_PREFIX}/src/plugins/pyside6-designer"
  setenv SOLPSGUI "${SOLPS_GUI_PREFIX}/src/gui"
  alias solps 'python3 ${SOLPS_GUI_PREFIX}/src/gui/solps.py'
  alias solps5 'env PYTHONPATH=${SOLPS_GUI_PREFIX}/src/widgets:${PYTHONPATH} python3 ${SOLPS_GUI_PREFIX}/src/gui/solps5.py'
  alias designer "env PYTHONPATH=${SOLPS_GUI_PREFIX}/src/widgets:${PYTHONPATH} ${EBROOTQT5}/bin/designer"
  alias solps_doc 'env --unset LD_LIBRARY_PATH firefox ${SOLPS_GUI_PREFIX}/doc/build/html/index.html'
  alias eirene 'python3 ${SOLPS_GUI_PREFIX}/src/actors/eirene.py'
  alias b2 'python3 ${SOLPS_GUI_PREFIX}/src/actors/b2.py'
else
  if `module is-avail SOLPS-GUI` then
    module load SOLPS-GUI
  endif
endif

# Other environment variables


	-Wl,-rpath,${PARAVIEW_DIR}/lib/paraview-${PARAVIEW_MAJOR_VERSION} \
	-Wl,-rpath-link,${PARAVIEW_DIR}/lib/paraview-${PARAVIEW_MAJOR_VERSION}

#
# Preprocessor options
#

SOLPS_CPP      = -DNCAR4 -DMDSPLUS -DIMAS -DNO_F01AAF -DCDF_MOVIE -DNETCDF4_3 -DCATALYST
B25_DEFINES    =
EIRENE_DEFINES =
MPI_CPP        = `pkg-config mpich2-ch3 --cflags`


#
# Export for use in sub-makefiles
#

export NCDIR
export MSCL_ROOT
export H5DIR
export GR_ROOT
export GLI_HOME
export NCARG_ROOT
export NAGDIR
export MDSPLUS_DIR
export PARAVIEW_DIR

export LD_NETCDF
export LD_MSCL
export LD_GR
export LD_GKS
export LD_NCARG
export LD_NAG
export LD_MDSPLUS
export LD_SONNET
export LD_MPI
export LD_UAL

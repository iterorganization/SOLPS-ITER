# Load modules
module load lapack
module load gnuplot
module load blas
module load globus
module load hdf5/1.8.9
module load MUMPS
module load netcdf
module load NAG
module load scalapack


# Environment variables
setenv DEVICE jet
setenv GLI_HOME /common/SOLPS-ITER/OBJECTCODE/pgf90/gks
if(! $?SIMDIR) then
  setenv SIMDIR /u/sim
endif
if(! $?FLUSH) then
  setenv FLUSH $SIMDIR/flush
endif

# Debugger
setenv DBX totalview

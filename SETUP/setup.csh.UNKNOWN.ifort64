alias gmake make
setenv PATH ${PATH}:/opt/intel/bin/
if ($?LD_LIBRARY_PATH) then
  setenv LD_LIBRARY_PATH ${LD_LIBRARY_PATH}:/opt/intel/composer_xe_2013_sp1.2.144/compiler/lib/intel64/
else
  setenv LD_LIBRARY_PATH /opt/intel/composer_xe_2013_sp1.2.144/compiler/lib/intel64/
endif
unsetenv NCARG_ROOT 

# General
# module use /work/imas/etc/modulefiles
# module load git

# Modules needed by SOLPS-ITER
# module load intel/12.0.2
# module load makedepend/1.0.0
# module load mscl/1.0.0-intel-12.0.2
# module load netcdf/4.3.3.1
# module load netcdf-fortran/4.4.2-intel-12.0.2
# module load gr/0.0.94
# module load gks/4.4.74
# module load ncl/6.2.1
# module load nag/15
# module load hdf5/1.8.15
# module load flex
# module load doxygen
# module load texlive
# module load ghostscript
# module load libxml2
# module load fontconfig
# module load cairo
# module load mdsplus/3.0.2
# module load make
# module load imas
# module load python/2.7/9

# mpi-library
# module load mpich2/3.1.3-intel
# module unload mpich2
# module load mvapich2/1.3.2-intel

# Debugger (set environment variable DBX)
setenv DBX idb

# Compiler
setenv FC ifort

if (`where paraview-config` == "") then
  echo "Warning: paraview-config not found. ParaView with Catalyst will not be compiled-in!"
else
  # See ParaViewCatalystUsersGuide_v2.pdf Sec 3.7.2 Linking with Python ...
  setenv PARAVIEW_MAJOR_VERSION `paraview --version | cut -d '.' -f 1 | cut -d ' ' -f 3`
  setenv CMAKE_MAJOR_VERSION `cmake --version | head -1 | cut -d ' ' -f 3 | cut -d '.' -f 1`
  if (${CMAKE_MAJOR_VERSION} > 2) then
    setenv LD_CATALYST `paraview-config --ldflags -c PythonCatalyst -v CommonDataModel`
    setenv PARAVIEW_INCLUDE `paraview-config --cppflags`
  else
    setenv PARAVIEW_LIB `paraview-config --libs --python | sed s/-L//`
    setenv LD_CATALYST `paraview-config --libs vtkPVPythonCatalyst`
    setenv PARAVIEW_INCLUDE `paraview-config --include`
    setenv LD_LIBRARY_PATH "${PARAVIEW_LIB}:${LD_LIBRARY_PATH}"
    setenv PYTHONPATH "${PARAVIEW_LIB}/site-packages/vtk:${PYTHONPATH}"
    setenv PYTHONPATH "${PARAVIEW_LIB}/site-packages:${PYTHONPATH}"
  endif
endif


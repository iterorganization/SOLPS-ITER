#! /bin/tcsh

#SBATCH --nodes=#NODES#
#SBATCH --ntasks-per-node=#PROCS#
#SBATCH --cpus-per-task=#CPUS#
#SBATCH --time=#HOURS#:00:00
#SBATCH --mail-user=#EMAIL#
#SBATCH --mail-type=END,FAIL
#SBATCH --job-name=#JOBNAME#
#SBATCH --partition=#PART#
#SBATCH --account=MISONIC
#SBATCH --no-requeue

echo Using SOLPSTOP = #SOLPSTOP#

echo Using COMPILER = ${COMPILER}
switch (${COMPILER})
  case "ifort64":
    module load PrgEnv-intel
    breaksw
  case "gfortran":
    module load PrgEnv-gnu
    breaksw
  default
    module load PrgEnv-cray
    breaksw
endsw
module load gdb4hpc
module load cray-netcdf/4.6.1.3
module load cray-parallel-netcdf/1.8.1.4
module list

set STANDALONE_ARG="#STANDALONE_ARG#"
set COUPLED_SUFFIX="#COUPLED_SUFFIX#"
set COMPRESS_ARG="#COMPRESS_ARG#"
set COMPRESS_SUFFIX="#COMPRESS_SUFFIX#"

set USE_MPI=""
if ($?SOLPS_MPI) then
  set MPI_EXEC=srun
  set MPI_OPTS=#MPIOPTS#
  set TIME="srun"
  set USE_MPI="-m ${MPI_EXEC} ${MPI_OPTS}"
  set USE_MPI=`echo $USE_MPI | sed -e 's:-m :-m ''":' -e 's:$:"'':'`
endif

set USE_OMP=""
if ($?SOLPS_OPENMP) then
  set OMP_OPTS=#THREADS#
  set USE_OMP="-t ${OMP_OPTS}"
endif

if ($?SOLPS_DEBUG) then
  setenv ATP_ENABLED 1
  ulimit -c unlimited
endif

update_solps_run_status "Using SOLPSTOP = #SOLPSTOP#"
update_solps_run_status "Started on `hostname` at `date`"

set STANDALONE=${STANDALONE_ARG}

time b2run ${STANDALONE} ${USE_MPI} ${USE_OMP} b2mn #COMPRESS_ARG# >! run.log${COMPRESS_SUFFIX}

QSUB.postprocess${COUPLED_SUFFIX}

preserve_scratch_to_work

update_solps_run_status "Finished on `hostname` at `date`"
b2fstate_OK_bool

#! /bin/tcsh

#SBATCH --nodes=#NODES#
#SBATCH --ntasks-per-node=#TASKS#
#SBATCH --cpus-per-task=#THREADS#
#SBATCH -p cclake
#SBATCH -A #ACCOUNT#
#SBATCH --time=#HOURS#:00:00
#SBATCH --mem=#MEM#
#SBATCH --job-name=#JOBNAME#
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=#EMAIL#
#SBATCH -o SLURM-%j.out
#SBATCH -e SLURM-%j.err
#SBATCH  --no-requeue

### This script submits the job, which launches the SOLPS-ITER code, to the CSD3 cluster,
### and resubmits the job again after successful finish of SOLPS-ITER in a loop manner.
###
### Successful finish means that either the prescribed (by 'b2mndr_ntim') number of steps is reached
### or the prescribed (by 'b2mndr_cpu' or 'b2mndr_elapsed') time of run is elapsed.
###
### If the .quit (or _quit) is seen, or end time (specified by 'b2mndr_etim') is reached, then
### the loop breaks, i.e. the job is not resubmitted again.
###
### Usage: 
###   Submit the job:     `csd3submit -T 48 SLURM.csd3_coupled_loop`
###               or      `csd3submit -m "-np 36" -j "JobName" -T 48 -M 24G SLURM.csd3_coupled_loop`
###   Stop the run:       `touch b2mn.exe.dir/.quit`

echo Using SOLPSTOP = #SOLPSTOP#

set USE_MPI=""
if ($?SOLPS_MPI) then
  module load intelmpi
  set MPI_EXEC=mpirun
  set MPI_OPTS=#MPIOPTS#
  set MPI_PREFLAGS="--mpi=mpi2"
  set USE_MPI="-m ${MPI_EXEC} ${MPI_OPTS}"
  set USE_MPI=`echo $USE_MPI | sed -e 's:-m :-m ''":' -e 's:$:"'':'`
  setenv I_MPI_PIN_PROCESSOR_LIST 0-47
else
  set MPI_PREFLAGS=""
endif
set TIME="time srun ${MPI_PREFLAGS}"

set USE_OMP=""
if ($?SOLPS_OPENMP) then
  set OMP_OPTS = #THREADS#
  set USE_OMP = "-t ${OMP_OPTS}"
endif

update_solps_run_status "Using SOLPSTOP = #SOLPSTOP#"
update_solps_run_status "Started on `hostname` at `date`"

rm -f run.KAPUTT

b2run ${USE_MPI} ${USE_OMP} b2mn >& run.log

QSUB.postprocess_coupled

preserve_scratch_to_work

update_solps_run_status "Finished on `hostname` at `date`"

set Break_loop = "no"
if (`grep "stopping because" run.log.last10` == "") then
  update_solps_run_status "run KAPUTT at `date`"
  echo KAPUTT > run.KAPUTT
  set Break_loop = "yes"
endif
#set NORMAL_FINISH=`grep "stopping because .quit" run.log.last10`
if (`grep "stopping because .quit" run.log.last10` != "") then
  update_solps_run_status "Breaking the loop by .quit at `date`"
  set Break_loop = "yes"
endif
#set NORMAL_FINISH=`grep "stopping because _quit" run.log.last10`
if (`grep "stopping because _quit" run.log.last10` != "") then
  update_solps_run_status "Breaking the loop by _quit at `date`"
  set Break_loop = "yes"
endif
#set NORMAL_FINISH=`grep "stopping because tim >= etim" run.log.last10`
if (`grep "stopping because tim >= etim" run.log.last10` != "") then
  update_solps_run_status "Breaking the loop because the end time is reached at `date`"
  set Break_loop = "yes"
endif
#set NORMAL_FINISH=`grep "stopping because min_residual" run.log.last10`
if (`grep "stopping because min_residual" run.log.last10` != "") then
  update_solps_run_status "Breaking the loop because required residual is reached at `date`"
  set Break_loop = "yes"
endif

if ("$Break_loop" == "no") then
  set End_by_ntim = `grep "stopping because itim" run.log.last10`
  set End_by_cputime = `grep "stopping because cpu" run.log.last10`
  set End_by_walltime = `grep "stopping because elapsed" run.log.last10`

#  echo $End_by_ntim
#  echo $End_by_cputime
#  echo $End_by_walltime

  if ("$End_by_ntim" != "" || "$End_by_cputime" != "" || "$End_by_walltime" != "") then
    update_solps_run_status "Resubmitting inside the loop at `date`"
    rm -f run.log* b2mn.prt b2.log*;
    set NOW = `date +"%d.%m.%Y_%T"`  
    mv b2fstati b2fstati_$NOW
    if (-e fort.13.i) mv fort.13.i fort.13.i_$NOW
    if (-e fort.14.i) mv fort.14.i fort.14.i_$NOW
    if (-e fort.15.i) mv fort.15.i fort.15.i_$NOW
    if (-e fort.44.i) mv fort.44.i fort.44.i_$NOW
    if (-e fort.46.i) mv fort.46.i fort.46.i_$NOW
    if (-e fort.44_aver.i) mv fort.44_aver.i fort.44_aver.i_$NOW
    if (-e fort.46_aver.i) mv fort.46_aver.i fort.46_aver.i_$NOW
    if (-e conbe.dat.i) mv conbe.dat.i conbe.dat_$NOW
    mv b2fstate b2fstati
    if (-s b2faveri) mv b2faveri b2faveri_$NOW
    if (-s b2favere) mv b2favere b2faveri
    echo csd3submit #LOOPOPTS# SLURM.csd3_coupled_loop
    csd3submit #LOOPOPTS# SLURM.csd3_coupled_loop
  endif
endif

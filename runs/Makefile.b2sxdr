	-cd b2sx.exe.dir ; ln -s ../HYDHEL ../AMJUEL ../METHANE ../SPUTER ../H2VIBR ../AMMONX ../ftn21 ../ftn22 . ; ln -s ../input.dat ftn1 ; [ -e ../ftn15 ] && cp -p ../ftn15 . || echo > /dev/null ; [ -e ../ftn14 ] && cp -p ../ftn14 . || echo > /dev/null ; [ -e ../ftn13 ] && cp -p ../ftn13 . || echo > /dev/null ; [ -e ../ftn12 ] && cp -p ../ftn12 . || echo > /dev/null ; [ -e ../ftn11 ] && cp -p ../ftn11 . || echo > /dev/null ; [ -e ../ftn10 ] && cp -p ../ftn10 . || echo > /dev/null ; [ -e ../ftn44 ] && cp -p ../ftn44 . || echo > /dev/null

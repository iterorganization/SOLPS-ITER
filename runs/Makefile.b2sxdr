# GNU Makefile for B2 to B2.5 converter; part 2--execution.
# Please see the general comments in the companion Makefile, part 1,
# which controls compile and load.
#-----------------------------------------------------------------------
# Variables.

SHELL = /bin/bash
TIME = time
RUN_OPTIONS =
nil =

# Default debugger
DBX ?= dbx

# Extensions for object directories when various options are used
ifdef SOLPS_OPENMP
EXT_OPENMP = .openmp
endif
ifdef SOLPS_MPI
EXT_MPI = .mpi
endif
ifdef USE_IMPGYRO
EXT_IMPGYRO = .ig
endif
ifdef SOLPS_DEBUG
EXT_DEBUG = .debug
endif

TOOL_CHAIN = ${HOST_NAME}.${COMPILER}${EXT_DEBUG}

S45DBG = ${SOLPSTOP}/modules/solps4-5/builds/${HOST_NAME}.${COMPILER}.debug
ifndef STAND_ALONE
B2OBJ  = ${SOLPSTOP}/modules/B2.5/builds/couple_SOLPS-ITER.${HOST_NAME}.${COMPILER}${EXT_OPENMP}${EXT_MPI}${EXT_IMPGYRO}${EXT_DEBUG}
EIROBJ = ${SOLPSTOP}/modules/Eirene/builds/couple_SOLPS-ITER.${HOST_NAME}.${COMPILER}${EXT_MPI}${EXT_IMPGYRO}${EXT_DEBUG}
DBGOBJ = ${SOLPSTOP}/modules/B2.5/builds/couple_SOLPS-ITER.${HOST_NAME}.${COMPILER}${EXT_OPENMP}${EXT_MPI}${EXT_IMPGYRO}.debug
EDBOBJ = ${SOLPSTOP}/modules/Eirene/builds/couple_SOLPS-ITER.${HOST_NAME}.${COMPILER}${EXT_MPI}${EXT_IMPGYRO}.debug
ifneq (${DBX},totalview)
INC = -I ${DBGOBJ} -I ${EDGOBJ} -I ${S45DBG}
endif
else
B2OBJ  = ${SOLPSTOP}/modules/B2.5/builds/standalone.${HOST_NAME}.${COMPILER}${EXT_OPENMP}${EXT_MPI}${EXT_IMPGYRO}${EXT_DEBUG}
DBGOBJ = ${SOLPSTOP}/modules/B2.5/builds/standalone.${HOST_NAME}.${COMPILER}${EXT_OPENMP}${EXT_MPI}${EXT_IMPGYRO}.debug
ifneq (${DBX},totalview)
INC = -I ${DBGOBJ} -I ${S45DBG}
endif
endif

prints = b2sxdr.prt

target_sx = b2sxdr.prt b2fgmtry b2fstati b2fparam b2fplasma b2ag.dat b2ag.prt b2ah.dat b2ai.dat b2ai.prt b2ar.dat b2yg.dat b2yh.dat b2yi.dat b2ym.dat b2yn.dat b2yp.dat b2yq.dat b2yr.dat b2yt.dat b2.boundary.parameters.4 b2.boundary.parameters.5 b2mn.dat.4 b2mn.dat.5 b2.neutrals.parameters b2.numerics.parameters b2.transport.parameters.4 b2.transport.parameters.5 b2.user.parameters b2.feedback_control.parameters b2.parameters.out

scandir := $(shell cd .. ; pwd)
projdir := $(shell cd ../.. ; pwd)
baserundir := $(shell cd $(scandir)/baserun ; pwd)

echo:
	@echo scandir=${scandir} projdir=${projdir} baserundir=${baserundir}

#-----------------------------------------------------------------------
# Directives.

vpath %.dat .:$(baserundir)
vpath b2fgmtry .:$(baserundir)
vpath b2fstati .:$(baserundir)

#-----------------------------------------------------------------------
# Rules.

default : b2sxdr.prt
all : $(prints)
prt : $(prints)

.PHONY : default all prt clean realclean testvars
.PRECIOUS : $(prints)
.SUFFIXES : $(nil)

ifndef STAND_ALONE
$(target_sx) : B2SXDR b2.parameters.src input.dat
else
$(target_sx) : B2SXDR b2.parameters.src
endif
	rm -rf b2sx.exe.dir >& /dev/null ; mkdir b2sx.exe.dir ; cp $^ b2sx.exe.dir
	rm -f $(target_sx)
ifndef STAND_ALONE
ifneq (${COMPILER},HP)
	-cd b2sx.exe.dir ; ln -s ../HYDHEL ../AMJUEL ../METHANE ../SPUTER ../H2VIBR ../AMMONX ../fort.21 ../fort.22 . ; ln -s ../input.dat fort.1 ; [ -e ../fort.15 ] && cp -p ../fort.15 . || echo > /dev/null ; [ -e ../fort.14 ] && cp -p ../fort.14 . || echo > /dev/null ; [ -e ../fort.13 ] && cp -p ../fort.13 . || echo > /dev/null ; [ -e ../fort.12 ] && cp -p ../fort.12 . || echo > /dev/null ; [ -e ../fort.11 ] && cp -p ../fort.11 . || echo > /dev/null ; [ -e ../fort.10 ] && cp -p ../fort.10 . || echo > /dev/null ; [ -e ../fort.44 ] && cp -p ../fort.44 . || echo > /dev/null
	cd b2sx.exe.dir ; [ -e ../fort.33 ] && cp -p ../fort.33 . || echo > /dev/null ; [ -e ../fort.34 ] && cp -p ../fort.34 . || echo > /dev/null ; [ -e ../fort.35 ] && cp -p ../fort.35 . || echo > /dev/null
else
	-cd b2sx.exe.dir ; ln -s ../HYDHEL ../AMJUEL ../METHANE ../SPUTER ../H2VIBR ../AMMONX ../ftn21 ../ftn22 . ; ln -s ../input.dat ftn1 ; [ -e ../ftn15 ] && cp -p ../ftn15 . || echo > /dev/null ; [ -e ../ftn14 ] && cp -p ../ftn14 . || echo > /dev/null ; [ -e ../ftn13 ] && cp -p ../ftn13 . || echo > /dev/null ; [ -e ../ftn12 ] && cp -p ../ftn12 . || echo > /dev/null ; [ -e ../ftn11 ] && cp -p ../ftn11 . || echo > /dev/null ; [ -e ../ftn10 ] && cp -p ../ftn10 . || echo > /dev/null ; [ -e ../ftn44 ] && cp -p ../ftn44 . || echo > /dev/null
	cd b2sx.exe.dir ; [ -e ../ftn33 ] && cp -p ../ftn33 . || echo > /dev/null ; [ -e ../ftn34 ] && cp -p ../ftn34 . || echo > /dev/null ; [ -e ../ftn35 ] && cp -p ../ftn35 . || echo > /dev/null
endif
endif
ifneq (${COMPILER},HP)
	cd b2sx.exe.dir ; [ -e ../fort.30 ] && cp -p ../fort.30 . || echo > /dev/null ; [ -e ../fort.31 ] && cp -p ../fort.31 . || echo > /dev/null ; ${TIME} ${SOLPSTOP}/modules/solps4-5/builds/${TOOL_CHAIN}/b2sxdr.exe ${RUN_OPTIONS} ; mv $(target_sx) .. >& /dev/null ; [ -e ../fort.30 ] && rm fort.30 || mv fort.30 .. ; [ -e ../fort.31 ] && rm fort.31 || mv fort.31 .. ; rm -f $(notdir $^) >& /dev/null
ifndef STAND_ALONE 
	-[ -e b2sx.exe.dir/fort.10 ] && mv b2sx.exe.dir/fort.10 . || echo > /dev/null
	-[ -e b2sx.exe.dir/fort.11 ] && mv b2sx.exe.dir/fort.11 . || echo > /dev/null
	-[ -e b2sx.exe.dir/fort.12 ] && mv b2sx.exe.dir/fort.12 . || echo > /dev/null
	-[ -e b2sx.exe.dir/fort.13 ] && mv b2sx.exe.dir/fort.13 . || echo > /dev/null
	-[ -e b2sx.exe.dir/fort.14 ] && mv b2sx.exe.dir/fort.14 . || echo > /dev/null
	-[ -e b2sx.exe.dir/fort.15 ] && mv b2sx.exe.dir/fort.15 . || echo > /dev/null
	-[ -e b2sx.exe.dir/fort.33 ] && mv b2sx.exe.dir/fort.33 . || echo > /dev/null
	-[ -e b2sx.exe.dir/fort.34 ] && mv b2sx.exe.dir/fort.34 . || echo > /dev/null
	-[ -e b2sx.exe.dir/fort.35 ] && mv b2sx.exe.dir/fort.35 . || echo > /dev/null
	-[ -e b2sx.exe.dir/fort.44 ] && mv b2sx.exe.dir/fort.44 . || echo > /dev/null
	-cd b2sx.exe.dir ; rm -f HYDHEL AMJUEL METHANE SPUTER H2VIBR AMMONX fort.21 fort.22 fort.85 fort.1 fort.29 fort.37 fort.55 fort.78 vtk.out
endif
else
	cd b2sx.exe.dir ; [ -e ../ftn30 ] && cp -p ../ftn30 . || echo > /dev/null ; [ -e ../ftn31 ] && cp -p ../ftn31 . || echo > /dev/null ; ${TIME} ${SOLPSTOP}/modules/solps4-5/builds/${TOOL_CHAIN}/b2sxdr.exe ${RUN_OPTIONS} ; mv $(target_sx) .. >& /dev/null ; [ -e ../ftn30 ] && rm ftn30 || mv ftn30 .. ; [ -e ../ftn31 ] && rm ftn31 || mv ftn31 .. ; rm -f $(notdir $^) >& /dev/null
ifndef STAND_ALONE
	-[ -e b2sx.exe.dir/ftn10 ] && mv b2sx.exe.dir/ftn10 . || echo > /dev/null
	-[ -e b2sx.exe.dir/ftn11 ] && mv b2sx.exe.dir/ftn11 . || echo > /dev/null
	-[ -e b2sx.exe.dir/ftn12 ] && mv b2sx.exe.dir/ftn12 . || echo > /dev/null
	-[ -e b2sx.exe.dir/ftn13 ] && mv b2sx.exe.dir/ftn13 . || echo > /dev/null
	-[ -e b2sx.exe.dir/ftn14 ] && mv b2sx.exe.dir/ftn14 . || echo > /dev/null
	-[ -e b2sx.exe.dir/ftn15 ] && mv b2sx.exe.dir/ftn15 . || echo > /dev/null
	-[ -e b2sx.exe.dir/ftn33 ] && mv b2sx.exe.dir/ftn33 . || echo > /dev/null
	-[ -e b2sx.exe.dir/ftn34 ] && mv b2sx.exe.dir/ftn34 . || echo > /dev/null
	-[ -e b2sx.exe.dir/ftn35 ] && mv b2sx.exe.dir/ftn35 . || echo > /dev/null
	-[ -e b2sx.exe.dir/ftn44 ] && mv b2sx.exe.dir/ftn44 . || echo > /dev/null
	-cd b2sx.exe.dir ; rm -f HYDHEL AMJUEL METHANE SPUTER H2VIBR AMMONX ftn21 ftn22 ftn85 ftn1 ftn29 ftn37 ftn55 ftn78 vtk.out
endif
endif
	-rmdir b2sx.exe.dir

ifndef STAND_ALONE
dbx.b2sxdr : B2SXDR b2.parameters.src input.dat
else
dbx.b2sxdr : B2SXDR b2.parameters
endif
	rm -rf b2sx.exe.dir >& /dev/null ; mkdir b2sx.exe.dir ; cp $^ b2sx.exe.dir
	rm -f $(target_sx)
ifneq (${COMPILER},HP)
ifndef STAND_ALONE
	-cd b2sx.exe.dir ; ln -s ../HYDHEL ../AMJUEL ../METHANE ../SPUTER ../H2VIBR ../AMMONX ../fort.21 ../fort.22 . ; ln -s ../input.dat fort.1 ; [ -e ../fort.15 ] && cp -p ../fort.15 . || echo > /dev/null ; [ -e ../fort.14 ] && cp -p ../fort.14 . || echo > /dev/null ; [ -e ../fort.13 ] && cp -p ../fort.13 . || echo > /dev/null ; [ -e ../fort.12 ] && cp -p ../fort.12 . || echo > /dev/null ; [ -e ../fort.11 ] && cp -p ../fort.11 . || echo > /dev/null ; [ -e ../fort.10 ] && cp -p ../fort.10 . || echo > /dev/null ; [ -e ../fort.44 ] && cp -p ../fort.44 . || echo > /dev/null

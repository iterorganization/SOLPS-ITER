endif
	cd b2sx.exe.dir ; [ -e ../ftn30 ] && cp -p ../ftn30 . || echo > /dev/null ; [ -e ../ftn31 ] && cp -p ../ftn31 . || echo > /dev/null ; ${DBX} ${INC} ${S45DBG}/b2sxdr.exe ${RUN_OPTIONS} ; mv $(target_sx) .. >& /dev/null ; [ -e ../ftn30 ] && rm ftn30 || mv ftn30 .. ; [ -e ../ftn31 ] && rm ftn31 || mv ftn31 .. ; rm -f $(notdir $^) >& /dev/null

# Makefile for fetching large external data

# Shared asset directory is possible on ITER cluster
ITER_EXTERNALDIR=/work/imas/shared/external/assets/solps-iter/MD5
ifeq (${HOST_NAME},ITER) # On ITER cluster
	ASSETDIR ?= ${ITER_EXTERNALDIR}
	ASSETDIR_GROUP ?= fst-cluster-users
	EXTERNALDIR ?= ${ITER_EXTERNALDIR}
else
	ASSETDIR ?= ${HOME}/assets/MD5
	ITER_HPC_LOGIN_USERNAME ?= ${USER}
	EXTERNALDIR ?= ${ITER_HPC_LOGIN_USERNAME}@hpc-login.iter.org:${ITER_EXTERNALDIR}
endif
EXTERNALDATA ?= https://static.iter.org/imas/assets/solps-iter/MD5

HASHES := $(wildcard *.md5)
ASSETS = $(HASHES:%.md5=%)

# The shell in which to execute make rules.
SHELL = /bin/sh

.PRECIOUS: %.md5-stamp

CURL ?= /usr/bin/curl

all : $(ASSETS)

-include depend

% : %.tar.gz
	echo $@ $^
	mkdir $@.tmp ; tar -xhmzf $^ -C $@.tmp
	[ `echo $@.tmp/* | wc -w` -eq 1 ] && (mv $@.tmp/$@ . ; rm -Rf $@.tmp) || ( mv $@.tmp $@)

# If the asset already exists then we do not want to change its timestamp as
# this may impact other (re)builds. Therefore MD5 and timestamps need
# to be backdated in this case.
% : %.md5-stamp
	if test -f $(ASSETDIR)/$(shell cat $^); \
	then touch -r $(ASSETDIR)/$(shell cat $^) -d "-1 minute" $^; \
	     touch -r $^ -d "-1 minute" $(patsubst %.md5-stamp, %.md5, $^); \
	else make $(ASSETDIR)/$(shell cat $^); fi
	ln -sf $(ASSETDIR)/$(shell cat $^) $@

%.md5-stamp : %.md5
	cat $^ > $@


$(ASSETDIR)/% :
	if ! test -d $(ASSETDIR); \
           then mkdir -m 3775 -p $(ASSETDIR); \
	   if test "x$(ASSETDIR_GROUP)" != "x"; \
		then chgrp $(ASSETDIR_GROUP) $(ASSETDIR); \
	   fi; \
        fi
	$(CURL) --fail --output $(ASSETDIR)/$(@F) $(EXTERNALDATA)/$(@F)
	chmod g+w $(ASSETDIR)/$(@F)

depend: $(HASHES)
	@echo "# Do not edit this file as it is autogenerated!" > $@
	@for f in $(HASHES) ; do \
	  echo "$${f%.md5} : $${f}-stamp" >> $@; \
	  echo "$${f}-stamp : $${f}" >> $@; \
	  stamps="$${stamps} $${f}-stamp"; \
	done; \
	echo "STAMPS =$${stamps}" >> $@

clean:
	rm -f $(ASSETS) $(STAMPS) .*.md5-stamp depend

# Do not use unless really necessary
realclean: clean
	rm -rf $(ASSETDIR)

publish:
	if test -d "$(dir)" -a -d $(EXTERNALDIR); then \
		echo Publishing $(dir) ; \
		rm -f $(dir).tar.gz ; \
		tar czf $(dir).tar.gz $(dir) ; \
		md5=$$(md5sum $(dir).tar.gz | cut -c 1-32) ;\
		echo $${md5} > $(dir).tar.gz.md5 ;\
		scp $(dir).tar.gz $(EXTERNALDIR)/$${md5} ;\
		rm -f $(dir).tar.gz ;\
		git add $(dir).tar.gz.md5 ;\
		echo "Do not forget to commit and push $(dir).tar.gz.md5" ;\
	else \
		echo "Missing argument dir=yourdir or not ITER cluster" ;\
	fi

check : $(ASSETS)
	@for asset in $(ASSETS) ; \
	do hash=$$(cat $${asset}.md5); \
	   echo "$${hash}  $${asset}" | md5sum --check \
	   || (echo "Removing $$(readlink $${asset})"; \
	       rm -f $$(readlink $${asset});); \
	done


# The following target is for Makefile debugging
# Example: make query-ASSETS
query-%:
	@echo $($(*))

help :
	@echo
	@echo "The following tutorials are available:"
	@echo
	@for f in $(ASSETS:%.tar.gz=%) ; do \
		echo "    make $${f}"; \
	done
	@echo
	@echo "You can also: "
	@echo
	@echo "    make clean"
	@echo "    make publish dir=yourdir # on ITER cluster"
	@echo "    make check # to checksum tutorial archives"
	@echo
	@echo "or simply"
	@echo
	@echo "    make"
	@echo
	@echo "that will just fetch tutorials in tar.gz files."


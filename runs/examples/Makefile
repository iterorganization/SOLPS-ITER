ifeq ("$(wildcard /work/imas/shared/boundary/solps-iter)",\
		"/work/imas/shared/boundary/solps-iter")
	ASSETDIR := /work/imas/shared/boundary/solps-iter/assets/MD5
else
	ASSETDIR := /tmp/assets/MD5
endif
EXTERNALDATA = https://static.iter.org/imas/assets/solps-iter/MD5
EXTERNALDIR = /work/imas/shared/external/assets/solps-iter/MD5

SOURCES := $(wildcard *.md5)
ASSETS := $(SOURCES:%.md5=%)

# The shell in which to execute make rules.
SHELL = /bin/sh

.PRECIOUS: %.md5-stamp


all : $(ASSETS)

-include depend

% : %.tar.gz
	tar xmzf $^


% : %.md5-stamp

%.md5-stamp : %.md5
	make $(ASSETDIR)/$(shell cat $^)
	ln -sf $(ASSETDIR)/$(shell cat $^) $(patsubst %.md5-stamp, %, $@)

	cat $^ > $@


$(ASSETDIR)/% :
	test -d $(ASSETDIR) || install -m 777 -d $(ASSETDIR)
	curl --fail --output $(ASSETDIR)/$(@F) $(EXTERNALDATA)/$(@F)

depend:
	echo "AUTOGENERATED=1" > $@
	for f in $(SOURCES) ; do \
	  echo "$${f%.md5} : $${f}-stamp" >> $@; \
	  echo "$${f}-stamp : $${f}" >> $@; \
	done

clean:
	rm -f *.md5-stamp depend

# Do not use unless really necessary
realclean: clean
	rm -rf $(ASSETDIR) $(ASSETS)

publish:
	if test -d "$(dir)" -a -d $(EXTERNALDIR); then \
		echo Publishing $(dir); \
		tar czf $(dir).tar.gz $(dir); \
		md5=$$(md5sum $(dir).tar.gz | cut -c 1-32);\
		echo "$${md5} > $(dir).tar.gz.md5" ;\
		echo cp $(dir).tar.gz $(EXTERNALDIR)/$${md5} ;\
		rm -f $(dir).tar.gz ;\
		echo "Do not forget to git add $(dir).tar.gz.md5" ;\
	else \
		echo "Missing argument dir=yourdir or not ITER cluster";\
	fi

query-%:
	@echo $($(*))

help :
	@echo
	@echo "The following tutorials are available:"
	@echo
	@for f in $(ASSETS:%.tar.gz=%) ; do \
		echo "    make $${f}"; \
	done
	@echo
	@echo "You can also: "
	@echo
	@echo "    make clean"
	@echo "    make publish dir=yourdir # on ITER cluster"
	@echo
	@echo "or simply"
	@echo
	@echo "    make"
	@echo
	@echo "that will just fetch tutorials in tar.gz files."


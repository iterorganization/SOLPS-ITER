#! /bin/csh -f
set hostname=`hostname`
set fullhost=`nslookup $hostname |& awk '/Name:/{print $2}' | tr 'A-Z' 'a-z'`
switch ($fullhost)
case "*.iter.org":
  echo ITER
  breaksw
case "*.iferc-csc.org":
  echo IFERC
  breaksw
case "*.itm.rzg.mpg.de":
case "*.efda-itm.eu":
  echo ITM
  breaksw
case "*.ipp-garching.mpg.de":
case "*.ipp.mpg.de":
case "*.rzg.mpg.de":
  echo IPP
  breaksw
case "*.ipp-hgw.mpg.de":
  echo IPP-HGW
  breaksw
case "*.pppl.gov":
  echo PPPL
  breaksw
case "*.ccfe.ac.uk"
  echo JET
  breaksw
case "*.gov":
case "*.edu":
  echo USA_UNKNOWN
  breaksw
case "*.de":
case "*.uk":
  echo EU_UNKNOWN
  breaksw
default:
  echo UNKNOWN
endsw

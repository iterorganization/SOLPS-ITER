#! /bin/csh -f
set text=`basename $0`
switch ($text)
  case "resmt_reg":
    set label="total momentum residual"
    breaksw
  case "reshe_reg":
    set label="electron heat residual"
    breaksw
  case "reshi_reg":
    set label="ion heat residual"
    breaksw
  case "respo_reg":
    set label="potential residual"
    breaksw
  default:
    echo invalid quantity $text
    exit
endsw
set nnreg=`pipe_run.log | grep ^nnreg | head -1`
set vreg=$nnreg[2]
set xreg=$nnreg[3]
set yreg=$nnreg[4]
if ("" == $vreg) set vreg=4
if ("" == $xreg) set xreg=6
if ("" == $yreg) set yreg=7
@ vregP = $vreg + 1
pipe_run.log | \
  grep -a "^$text " | \
  awk '{for (i=2;i<=NF;i++) printf "%s ",$i;printf "\n"}' | \
  nl | \
  plot x"$1"yplot$vregP `count 0 $vreg` iter "$label" $PWD

eval '(exit $?0)' && eval 'exec tcsh $0 ${1+"$@"}' && eval 'exec tcsh $0 $argv:q'
###! /bin/tcsh -f

if ($1 == "") then
  if (-e input.dat) then
    echo Assuming run with Eirene
    set QSUB=`climb_and_look_for QSUB.iter_coupled`
    if ($QSUB == "//QSUB.iter_coupled") set QSUB=""
  else
    echo Assuming standalone run
    set QSUB=`climb_and_look_for QSUB.iter`
    if ($QSUB == "//QSUB.iter") set QSUB=""
  endif
else if (-e $1) then
  set QSUB=$1
else
  set QSUB=`climb_and_look_for $1`
  if ($QSUB == "//$1) set QSUB=""
endif
if($QSUB == "") then
  echo No SGE submission file found
  exit
endif

echo Using submission file $QSUB
update_solps_run_status -n "Submitted at `date`"
qsub -S /usr/bin/tcsh $QSUB

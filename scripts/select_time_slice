#! /bin/csh -f
# arg1 is file name
# arg2 is start time
# arg3, if it exists, is number of slices to avaerage over
if($1 == "") then
  echo 1st argument should be the filename to analyse
  exit
else
  set filename=$1
endif
if($2 == "") then
  echo 2nd argument should be the start time
  exit
else
  if($2 == "list") then
    echo " COUNT     TIME"
    awk '{print $1}' $filename | uniq | egrep -v '^ *$' | nl
    exit
  else
    set starttime=$2
  endif
endif
if($3 == "") then
  set average=1
else
  set average=$3
endif
awk 'BEGIN{start=0}\
     NF==3&&$1*1.0>='$starttime'&&start==0{start=1;count=0}\
     NF==3&&start>=1&&start<='$average'{count++;pos[count]=$2;val[count]+=$3}\
     NF==0&&start>=1&&start<='$average'{if (count != 0){columns=count};count=0;start=start+1}\
     END{if (start > 1){for (i=1;i<=columns;i++){print pos[i],val[i]/(start-1)}}}' $filename

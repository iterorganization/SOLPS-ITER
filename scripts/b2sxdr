eval '(exit $?0)' && eval 'exec tcsh $0 ${1+"$@"}' && eval 'exec tcsh $0 $argv:q'
###! /bin/tcsh -f

set solpstop=`climb_and_look_for SOLPSTOP`
if (-e $solpstop) then
  setenv SOLPSTOP "`cat $solpstop`"
  set RUNS=$SOLPSTOP/runs
else
  setenv SOLPSTOP "`echo $PWD | sed 's:/runs/.*::'`"
  set RUNS=$PWD
endif
echo Using SOLPSTOP = $SOLPSTOP

loop:
  if(-e $RUNS/Makefile.b2sxdr) goto endloop
  echo $RUNS
  if ("$RUNS" == "/") then
    echo Makefile.b2sxdr not found
    exit
  endif
  set RUNS=`dirname $RUNS`
  goto loop

endloop:
  set debug=""
  set TIME=time

argloop:
  if ("X${1}X" == "X-nX") then
    shift
    set debug="-n"
    goto argloop
  endif
  if ("X${1}X" == "X-sX") then
    shift
    setenv STAND_ALONE yes
    goto argloop
  endif
  if ("X${1}X" == "X-dX") then
    shift
    if (! $?SOLPS_DEBUG) then
      source $SOLPSTOP/SETUP/debug
      set DEBUG_SET=yes
    endif
    if ($1 == "") then
      set TIME="$DBX"
    else
      set TIME="$1"
      shift
    endif
    goto argloop
  endif
  if ("X${argv}X" == "XX") set argv="b2sxdr"
  set CMD=`echo $argv" " | sed -e 's: :.prt :g'`
  gmake $debug TIME="$TIME" -f $RUNS/Makefile.b2sxdr $CMD
  unsetenv STAND_ALONE
  if ($?DEBUG_SET) source $SOLPSTOP/SETUP/nodebug

#! /bin/ksh

# syntax for call: last_2d_v2_b iterations filename_in filename_out
# output is number of iterations
# usage e.g. iterout=`last_2d_v2_b 25 tracing/blnn.trc last_2dir/blnn.trc1`
# output files: in $tempdir/$header headerfile, 1 column per line
# in $tempdir/$data, all data for $iterations,  1 line per timestep

name=`basename $0`



iterations=$1
[ -z "$iterations" ] && { echo "$name: iterations not specified" >&2; exit 33; }
[ $iterations -lt 1 ] && { echo "$name: number of iterations=$iterations; < 1 !!!" >&2; exit 32; }
shift

filename=$1
shift
[ ! -r "$filename" ] && { echo "$name: filename=$filename does not exist!!!" >&2; exit 33; }

fileout=$1
shift
[ -z "$fileout" ]  && { echo "$name: filename=$fileout not specified!!!" >&2; exit 33; }
rm -f $fileout >&2
dir=`dirname $fileout`
if [ -n "$dir" ]; then
  if [ ! -d $dir ]; then
    mkdir  $dir
  fi
else
  dir=.
fi 

[ $filename = $fileout ] &&  { echo "$name: input and output filename are the same!!!" >&2; exit 33; }

#get number of headerline (last line with hash mark or first line)
# if there are no hash marks and filename is blnn.trc (old style), use second line
headerline=`cat $filename | grep "^#" | wc -l | awk '{print $1}'`
[ -z "$headerline" ] && headerline=1
if [ $headerline -eq 0 ]; then
  filebase=`basename $filename` 
  if [ "$filebase" = "blnn.trc" ]; then
    headerline=2
  else
    headerline=1
  fi
fi
[ $headerline -gt 0 ] || { echo "$name: headerline=$headerline; not correct" >&2; exit 33; }

lines=`wc -l $filename | awk '{ print $1}'`

temp0=$dir/temp0
temp1=$dir/temp1
temp2=$dir/temp2
temp3=$dir/temp3
rm -f  $temp0 $temp1 $temp2 $temp3 >&2


cat $filename | head -$headerline | tail -1 | sed s/^#//g > $temp0

let "datalines=lines - headerline"

tail -2 $filename > $temp1
head -1 $temp1 > $temp2
tail -1 $temp1 > $temp3

ncol2ndlast=`wc -w < $temp2 | awk '{print $1}'`
ncollast=`wc -w < $temp3 | awk '{print $1}'`

lasterror=
if [ $ncollast -lt $ncol2ndlast ]; then 
  lasterror=1
  let "iterations = iterations + 1"
fi
if [ $iterations -gt $datalines ]; then
  echo "$name: only $datalines datalines; iterations reduced from $iterations to $datalines" >&2
  iterations=$datalines
fi

cat  $filename | tail -$iterations > $temp2

if [ -n "$lasterror" ]; then
  let "iterations = iterations - 1"
  cat  $temp2 | head -$iterations > $temp1
else
  mv $temp2 $temp1
fi


#convert space runs to tabs and squeeze out leading tab if there is one

cat $temp0 $temp1 > $temp2
cat $temp2 | tr -s " " "@" | tr -s "\011 " "@"| sed s/^@//g | sed s/@$//g | tr '@' '\011' > $fileout

rm -f  $temp0 $temp1 $temp2 $temp3 >&2

echo $iterations

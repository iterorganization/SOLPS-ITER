# Set up SOLPS-ITER environment
. $(dirname $0)/SOLPS-ITER_CI_env

# Compile the code
echo "LDOPTS += -mcmodel=large -shared-intel" > ${SOLPSTOP}/modules/B2.5/config/config.ITER.ifort64.local
echo "FCOPTS += -mcmodel=large -shared-intel -diag-enable=error" >> ${SOLPSTOP}/modules/B2.5/config/config.ITER.ifort64.local
export NO_MANUAL="true"
make listobj_nox depend_nox
make divgeo_nox
make MAKE_OPTIONS=-j8 solps_nox b25_nox b25_tgt b25_adj b25_hess_tgt

# Run test cases

cd ${SOLPSTOP}/runs/examples
make COMPASS_16515_1150ms_D_drift_AFN
cd COMPASS_16515_1150ms_D_drift_AFN
export DEVICE=compass
correct_baserun_timestamps
mkdir run_kin_test
cd run_kin_test
cp ../run_kin_CI/b2.*.parameters .
cp ../run_kin_CI/b2mn.dat .
cp ../run_kin_CI/b2fstati .
cp ../run_kin_CI/b2time.nc.i b2time.nc
cp ../run_kin_CI/input.dat .
cp ../run_kin_CI/fort.11.i fort.11
cp ../run_kin_CI/fort.13.i fort.13
cp ../run_kin_CI/fort.44.i fort.44
cp ../run_kin_CI/fort.46.i fort.46
touch b2fstati
setup_baserun_eirene_links
b2run b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks_CI_coupled.sh ../run_kin_CI/ ./ || exit 1

# Special test to look for restart effects
cd ${SOLPSTOP}/modules/B2.5
cat src/utility/cfwure.F | sed -e "s:ifmt=1:ifmt=0:" > src.local/cfwure.F
touch src/modules/.new_modules
cd ${SOLPSTOP}
make listobj_nox b25_nox b25eirene_nox
cd ${SOLPSTOP}/runs/examples/COMPASS_16515_1150ms_D_drift_AFN

# First test the fluid neutral code
mkdir run_AFN_test_20
cd run_AFN_test_20
cp ../run_AFN_drift/b2fstati .
cp ../run_AFN_drift/b2mn.dat .
cp ../run_AFN_drift/b2.*.parameters .
cp ../run_AFN_drift/b2time.nc.i b2time.nc
cp ../run_AFN_drift/b2batch.nc.i b2batch.nc
touch b2fstati
setup_baserun_B25_links
echo "'b2mndr_ntim' '20'" >> b2mn.dat
b2run -s b2mn
cd ..
mkdir run_AFN_test_2x10
cd run_AFN_test_2x10
cp ../run_AFN_drift/b2fstati .
cp ../run_AFN_drift/b2mn.dat .
cp ../run_AFN_drift/b2.*.parameters .
cp ../run_AFN_drift/b2time.nc.i b2time.nc
cp ../run_AFN_drift/b2batch.nc.i b2batch.nc
touch b2fstati
setup_baserun_B25_links
echo "'b2mndr_ntim' '10'" >> b2mn.dat
b2run -s b2mn
rm b2mn.prt
mv b2fstate b2fstati
b2run b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks.sh ../run_AFN_test_20/ ./ || exit 2

# Now test the coupled code
mkdir run_CI_test_20
cd run_CI_test_20
cp ../run_kin_CI/b2.*.parameters .
cp ../run_kin_CI/b2mn.dat .
cp ../run_kin_CI/b2fstati .
cp ../run_kin_CI/input.dat .
cp ../run_kin_CI/fort.11.i fort.11
cp ../run_kin_CI/fort.13.i fort.13
cp ../run_kin_CI/fort.44.i fort.44
cp ../run_kin_CI/fort.46.i fort.46
touch b2fstati
setup_baserun_eirene_links
echo "'b2mndr_ntim' '20'" >> b2mn.dat
b2run b2mn
cd ..
mkdir run_CI_test_2x10
cd run_CI_test_2x10
cp ../run_kin_CI/b2.*.parameters .
cp ../run_kin_CI/b2mn.dat .
cp ../run_kin_CI/b2fstati .
cp ../run_kin_CI/input.dat .
cp ../run_kin_CI/fort.11.i fort.11
cp ../run_kin_CI/fort.13.i fort.13
cp ../run_kin_CI/fort.44.i fort.44
cp ../run_kin_CI/fort.46.i fort.46
touch b2fstati
setup_baserun_eirene_links
b2run b2mn
rm b2mn.prt
mv b2fstate b2fstati
echo "'eirene_repeat_first_call' '0'" >> b2mn.dat
b2run b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks_CI_coupled.sh ../run_CI_test_20/ ./ || exit 3

# Go back to normal settings
cd ${SOLPSTOP}/modules/B2.5
rm src.local/cfwure.F
touch src/utility/cfwure.F
touch src/modules/.new_modules
cd ${SOLPSTOP}
make b25_nox b25eirene_nox

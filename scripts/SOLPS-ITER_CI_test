# Set up SOLPS-ITER environment
. $(dirname $0)/SOLPS-ITER_CI_env

# Compile the code
echo "LDOPTS += -mcmodel large -shared-intel" > ${SOLPSTOP}/modules/B2.5/config/config.ITER.ifort64.local
echo "FCOPTS += -mcmodel large -shared-intel" >> ${SOLPSTOP}/modules/B2.5/config/config.ITER.ifort64.local
make listobj_nox depend_nox
make MAKE_OPTIONS=-j8 nox_build b25_nox

# Run test cases

cd ${SOLPSTOP}/runs/examples
make test_slab_ortho_standalone
cd test_slab_ortho_standalone
correct_baserun_timestamps
mkdir run_new
cd run_new
cp ../test/b2.*.parameters .
cp ../test/b2mn.dat .
cp ../test/b2fstati .
cp ../test/b2time.nc .
touch b2fstati
b2run -s b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks.sh ../test ./ || exit 1

cd ..
mkdir run_9-pt_new
cd run_9-pt_new
cp ../test_9-pt/b2.*.parameters .
cp ../test_9-pt/b2mn.dat .
cp ../test_9-pt/b2fstati .
cp ../test_9-pt/b2time.nc .
touch b2fstati
b2run -s b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks.sh ../test_9pt/ ./ || exit 2

cd ../..
make AUG_16151_D
cd AUG_16151_D
export DEVICE=upgrade
cd baserun
rm *.prt b2fgmtry b2fpardf b2fstati b2frates
b2run b2ag b2ah b2ai b2ar
cd ..
mkdir run_standalone_new
cd run_standalone_new
cp ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/b2.*.parameters .
cp ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/b2mn.dat .
cp ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/b2fstati .
cp ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/b2time.nc .
cp ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/b2tallies.nc .
touch b2fstati
setup_baserun_eirene_links
b2run b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks.sh ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/ ./ || exit 3

cd ../..
make ITER_2360_0.95He+0.05H_40MW
cd ITER_2360_0.95He+0.05H_40MW
export DEVICE=iter
correct_baserun_timestamps
mkdir run_CI_test
cd run_CI_test
cp ../run_restart/b2.*.parameters .
cp ../run_restart/b2mn.dat .
cp ../run_restart/b2fstati .
cp ../run_restart/b2time.nc .
touch b2fstati
setup_baserun_eirene_links
echo "'b2mndr_ntim' '10'" >> b2mn.dat
b2run b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks_CI_coupled.sh ../run_restart/ ./ || exit 4

cd ..
mkdir run_CI_test_9-pt
cd run_CI_test_9-pt
cp ../run_restart_9-pt/b2.*.parameters .
cp ../run_restart_9-pt/b2mn.dat .
cp ../run_restart_9-pt/b2fstati .
cp ../run_restart_9-pt/b2time.nc .
touch b2fstati
setup_baserun_eirene_links
echo "'b2mndr_ntim' '10'" >> b2mn.dat
b2run b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks_CI_coupled.sh ../run_restart_9-pt/ ./ || exit 5

cd ../..
make DIIID_3106_DN_D+C
cd DIIID_3106_DN_D+C
export DEVICE=d3d
correct_baserun_timestamps
mkdir run_CI_test
cd run_CI_test
cp ../P5MW_n3e19_Yc1pc/b2.*.parameters .
cp ../P5MW_n3e19_Yc1pc/b2mn.dat .
cp ../P5MW_n3e19_Yc1pc/b2fstati .
cp ../P5MW_n3e19_Yc1pc/b2time.nc .
touch b2fstati
setup_baserun_eirene_links
echo "'b2mndr_ntim' '10'" >> b2mn.dat
b2run b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks_CI_coupled.sh ../P5MW_n3e19_Yc1pc/ ./ || exit 6

cd ..
mkdir run_CI_test_9-pt
cd run_CI_test_9-pt
cp ../P5MW_n3e19_Yc1pc_9-pt/b2.*.parameters .
cp ../P5MW_n3e19_Yc1pc_9-pt/b2mn.dat .
cp ../P5MW_n3e19_Yc1pc_9-pt/b2fstati .
cp ../P5MW_n3e19_Yc1pc_9-pt/b2time.nc .
touch b2fstati
setup_baserun_eirene_links
echo "'b2mndr_ntim' '10'" >> b2mn.dat
b2run b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks_CI_coupled.sh ../P5MW_n3e19_Yc1pc_9-pt/ ./ || exit 7

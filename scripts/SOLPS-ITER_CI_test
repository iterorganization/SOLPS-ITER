# Set up SOLPS-ITER environment
. $(dirname $0)/SOLPS-ITER_CI_env

# Compile the code
echo "LDOPTS += -mcmodel=large -shared-intel" > ${SOLPSTOP}/modules/B2.5/config/config.ITER.ifort64.local
echo "FCOPTS += -mcmodel=large -shared-intel -diag-enable=error" >> ${SOLPSTOP}/modules/B2.5/config/config.ITER.ifort64.local
make listobj_nox depend_nox
make MAKE_OPTIONS=-j8 nox_build b25_nox

# Run test cases

cd ${SOLPSTOP}/runs/examples
make test_slab_ortho_standalone
cd test_slab_ortho_standalone
correct_baserun_timestamps
mkdir run_new
cd run_new
cp ../test/b2.*.parameters .
cp ../test/b2mn.dat .
cp ../test/b2fstati .
cp ../test/b2time.nc.i b2time.nc
cp ../test/b2batch.nc.i b2batch.nc
setup_baserun_eirene_links
touch b2fstati
b2run -s b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks.sh ../test/ ./ || exit 1

cd ..
mkdir run_9pt_new
cd run_9pt_new
cp ../test_9pt/b2.*.parameters .
cp ../test_9pt/b2mn.dat .
cp ../test_9pt/b2fstati .
cp ../test_9pt/b2time.nc.i b2time.nc
cp ../test_9pt/b2batch.nc.i b2batch.nc
setup_baserun_eirene_links
touch b2fstati
b2run -s b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks.sh ../test_9pt/ ./ || exit 2

cd ../..
make AUG_16151_D
cd AUG_16151_D
export DEVICE=upgrade
cd baserun
rm *.prt b2fgmtry b2fpardf b2fstati b2frates
b2run b2ag b2ah b2ai b2ar
cd ..
mkdir run_standalone_new
cd run_standalone_new
cp ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/b2.*.parameters .
cp ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/b2mn.dat .
cp ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/b2fstati .
cp ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/b2time.nc.i b2time.nc
cp ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/b2tallies.nc.i b2tallies.nc
touch b2fstati
setup_baserun_eirene_links
b2run b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks.sh ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/ ./ || exit 3

cd ../..
make ITER_2360_0.95He+0.05H_40MW
cd ITER_2360_0.95He+0.05H_40MW
export DEVICE=iter
correct_baserun_timestamps
mkdir run_CI_test
cd run_CI_test
cp ../ref_run_for_CI/b2.*.parameters .
cp ../ref_run_for_CI/b2.feedback_save.parameters.i b2.feedback_save.parameters
cp ../ref_run_for_CI/b2mn.dat .
cp ../ref_run_for_CI/b2fstati .
cp ../ref_run_for_CI/input.dat .
cp ../ref_run_for_CI/fort.10.i fort.10
cp ../ref_run_for_CI/fort.11.i fort.11
cp ../ref_run_for_CI/fort.13.i fort.13
cp ../ref_run_for_CI/fort.14.i fort.14
cp ../ref_run_for_CI/fort.15.i fort.15
cp ../ref_run_for_CI/fort.44.i fort.44
cp ../ref_run_for_CI/fort.46.i fort.46
cp ../ref_run_for_CI/b2time.nc.i b2time.nc
touch b2fstati
setup_baserun_eirene_links
b2run b2mn
../run_checks_ITER_2360_coupled.sh ../ref_run_for_CI/ ./ || exit 4

cd ..
mkdir run_CI_test_9-pt
cd run_CI_test_9-pt
cp ../ref_run_for_CI_9-pt/b2.*.parameters .
cp ../ref_run_for_CI_9-pt/b2.feedback_save.parameters.i b2.feedback_save.parameters
cp ../ref_run_for_CI_9-pt/b2mn.dat .
cp ../ref_run_for_CI_9-pt/b2fstati .
cp ../ref_run_for_CI_9-pt/input.dat .
cp ../ref_run_for_CI_9-pt/fort.11.i fort.11
cp ../ref_run_for_CI_9-pt/fort.13.i fort.13
cp ../ref_run_for_CI_9-pt/fort.15.i fort.15
cp ../ref_run_for_CI_9-pt/fort.44.i fort.44
cp ../ref_run_for_CI_9-pt/fort.46.i fort.46
cp ../ref_run_for_CI_9-pt/b2time.nc.i b2time.nc
touch b2fstati
setup_baserun_eirene_links
b2run b2mn
../run_checks_ITER_2360_coupled.sh ../ref_run_for_CI_9-pt/ ./ || exit 5

cd ../..
make DIIID_3106_DN_D+C
cd DIIID_3106_DN_D+C
export DEVICE=d3d
correct_baserun_timestamps
mkdir run_CI_test
cd run_CI_test
cp ../run_for_CI/b2.*.parameters .
cp ../run_for_CI/b2.wall_save.parameters.i b2.wall_save.parameters
cp ../run_for_CI/b2mn.dat .
cp ../run_for_CI/b2fstati .
cp ../run_for_CI/input.dat .
cp ../run_for_CI/fort.10.i fort.10
cp ../run_for_CI/fort.11.i fort.11
cp ../run_for_CI/fort.13.i fort.13
cp ../run_for_CI/fort.14.i fort.14
cp ../run_for_CI/fort.44.i fort.44
cp ../run_for_CI/fort.46.i fort.46
cp ../run_for_CI/b2time.nc.i b2time.nc
cp ../run_for_CI/b2tallies.nc.i b2tallies.nc
touch b2fstati
setup_baserun_eirene_links
b2run b2mn
../run_checks_DIIID_3106_coupled.sh ../run_for_CI/ ./ || exit 6

cd ..
mkdir run_CI_test_9-pt
cd run_CI_test_9-pt
cp ../run_for_CI_9-pt/b2.*.parameters .
cp ../run_for_CI_9-pt/b2.wall_save.parameters.i b2.wall_save.parameters
cp ../run_for_CI_9-pt/b2mn.dat .
cp ../run_for_CI_9-pt/b2fstati .
cp ../run_for_CI_9-pt/input.dat .
cp ../run_for_CI_9-pt/fort.10.i fort.10
cp ../run_for_CI_9-pt/fort.11.i fort.11
cp ../run_for_CI_9-pt/fort.13.i fort.13
cp ../run_for_CI_9-pt/fort.14.i fort.14
cp ../run_for_CI_9-pt/fort.44.i fort.44
cp ../run_for_CI_9-pt/fort.46.i fort.46
cp ../run_for_CI/b2time.nc.i b2time.nc
cp ../run_for_CI/b2tallies.nc.i b2tallies.nc
touch b2fstati
setup_baserun_eirene_links
b2run b2mn
../run_checks_DIIID_3106_coupled.sh ../run_for_CI_9-pt/ ./ || exit 7

# Special test to look for restart effects
cd ${SOLPSTOP}/modules/B2.5
cat src/utility/cfwure.F | sed -e "s:ifmt=1:ifmt=0:" > src.local/cfwure.F
touch src/modules/.new_modules
cd ${SOLPSTOP}
make b25eirene_nox
cd ${SOLPSTOP}/runs/examples/DIIID_3106_DN_D+C
mkdir run_CI_test_9-pt_20
cd run_CI_test_9-pt_20
cp ../run_for_CI_9-pt/b2.*.parameters .
cp ../run_for_CI_9-pt/b2mn.dat .
cp ../run_for_CI_9-pt/b2fstati .
cp ../run_for_CI_9-pt/input.dat .
cp ../run_for_CI_9-pt/fort.10.i fort.10
cp ../run_for_CI_9-pt/fort.11.i fort.11
cp ../run_for_CI_9-pt/fort.13.i fort.13
cp ../run_for_CI_9-pt/fort.14.i fort.14
cp ../run_for_CI_9-pt/fort.44.i fort.44
cp ../run_for_CI_9-pt/fort.46.i fort.46
cp ../run_for_CI_9-pt/b2time.nc.i b2time.nc
cp ../run_for_CI_9-pt/b2tallies.nc.i b2tallies.nc
touch b2fstati
setup_baserun_eirene_links
echo "'b2mndr_ntim' '20'" >> b2mn.dat
b2run b2mn
cd ..
mkdir run_CI_test_9-pt_2x10
cd run_CI_test_9-pt_2x10
cp ../run_for_CI_9-pt/b2.*.parameters .
cp ../run_for_CI_9-pt/b2mn.dat .
cp ../run_for_CI_9-pt/b2fstati .
cp ../run_for_CI_9-pt/input.dat .
cp ../run_for_CI_9-pt/fort.10.i fort.10
cp ../run_for_CI_9-pt/fort.11.i fort.11
cp ../run_for_CI_9-pt/fort.13.i fort.13
cp ../run_for_CI_9-pt/fort.14.i fort.14
cp ../run_for_CI_9-pt/fort.44.i fort.44
cp ../run_for_CI_9-pt/fort.46.i fort.46
cp ../run_for_CI_9-pt/b2time.nc.i b2time.nc
cp ../run_for_CI_9-pt/b2tallies.nc.i b2tallies.nc
touch b2fstati
setup_baserun_eirene_links
b2run b2mn
rm b2mn.prt
mv b2fstate b2fstati
echo "'eirene_repeat_first_call' '0'" >> b2mn.dat
b2run b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks_CI_coupled.sh ../run_CI_test_9-pt_20/ ./ || exit 8

# Go back to normal settings
cd ${SOLPSTOP}/modules/B2.5
rm src.local/cfwure.F
touch src/utility/cfwure.F
touch src/modules/.new_modules
cd ${SOLPSTOP}
make b25eirene_nox

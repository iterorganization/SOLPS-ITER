# Set up SOLPS-ITER environment
. $(dirname $0)/SOLPS-ITER_CI_env

# Compile the code
echo "LDOPTS += -mcmodel large -shared-intel" > ${SOLPSTOP}/modules/B2.5/config/config.ITER.ifort64.local
echo "FCOPTS += -mcmodel large -shared-intel" >> ${SOLPSTOP}/modules/B2.5/config/config.ITER.ifort64.local
make listobj_nox depend_nox
make MAKE_OPTIONS=-j8 nox_build b25_nox

# Run test cases

cd ${SOLPSTOP}/runs/examples
make COMPASS_16515_1150ms_D_drift_AFN
cd COMPASS_16515_1150ms_D_drift_AFN
export DEVICE=compass
correct_baserun_timestamps
mkdir convert
cd convert
cp ../convert_orig/b2mn.dat .
cp ../convert_orig/b2.neutrals.parameters .
cp ../convert_orig/b2.boundary.parameters .
cp ../convert_orig/b2.numerics.parameters .
cp ../convert_orig/b2.transport.parameters .
cp ../convert_orig/input.dat .
cp ../convert_orig/b2fgmtry .
cp ../convert_orig/b2fpardf .
cp ../convert_orig/b2fstati .
cp ../convert_orig/fort.* .
b2run b2us
${SOLPSTOP}/modules/B2.5/src/test/convert_checks.sh ../convert_orig/ ./ || exit 1
cd ..

cd baserun
# rm *.prt b2fgmtry b2fpardf b2fstati b2frates
# b2run b2ag b2ah b2ai b2ar
rm b2ar.prt b2frates
b2run b2ar
cd ..

mkdir run_AFN_drift_new
cd run_AFN_drift_new
import_files_from_convert_wg
cp ../run_AFN_drift/b2fstati .
cp ../run_AFN_drift/b2mn.dat .
cp ../run_AFN_drift/b2*.nc .
touch b2fstati
setup_baserun_eirene_links
echo "'b2mndr_ntim' '10'" >> b2mn.dat
b2run -s b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks.sh ../run_AFN_drift/ ./ || exit 1
cd ..

mkdir run_kin_test
cd run_kin_test
import_files_from_convert_wg
cp ../run_kin_CI/b2.*.parameters .
cp ../run_kin_CI/b2mn.dat .
cp ../run_kin_CI/b2fstati .
cp ../run_kin_CI/b2time.nc.i b2time.nc
cp ../run_kin_CI/input.dat .
cp ../run_kin_CI/fort.11.i fort.11
cp ../run_kin_CI/fort.13.i fort.13
cp ../run_kin_CI/fort.15.i fort.15
cp ../run_kin_CI/fort.44.i fort.44
cp ../run_kin_CI/fort.46.i fort.46
touch b2fstati
setup_baserun_eirene_links
echo "'b2mndr_ntim' '10'" >> b2mn.dat
b2run b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks_CI_coupled.sh ../run_kin_CI/ ./ || exit 2

#! /bin/csh -f
set nnreg=`pipe_run.log | grep ^nnreg | head -1`
set vreg=$nnreg[2]
set xreg=$nnreg[3]
set yreg=$nnreg[4]
if ("" == $vreg) set vreg=4
if ("" == $xreg) set xreg=6
if ("" == $yreg) set yreg=7
@ vregP = $vreg + 1
if($?GNUPLOT_TMP) then
    set tmpdir="$GNUPLOT_TMP/"
else
    set tmpdir=""
endif
setenv PLOT_FROM_FILE "gnuplot.temp"
pipe_run.log | \
  egrep -a '^tireg '\|'^nireg '\|'^volreg ' | \
  awk '/tireg/{for (i=2;i<=NF;i++) {ti[i]=$i}}\
       /nireg/{for (i=2;i<=NF;i++) {ni[i]=$i}}\
       /volreg/{for (i=2;i<=NF;i++) printf "%s ",ti[i]/ni[i]/1.6021766028e-19;printf "\n"}' | \
  nl >! ${tmpdir}PLOT_FROM_FILE
  plot x"$1"yplot$vregP `count 0 $vreg` iter "ave Ti" $PWD

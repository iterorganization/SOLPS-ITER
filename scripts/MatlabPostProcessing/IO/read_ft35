function necke = read_ft34(file)
% necke = read_ft34(file)
%
% Read fort.34-files (triangle data). 
%
%



[fid,msg] = fopen(file);
if (fid == -1)
   error(msg);
end



%% Read data

% number of triangels
ntria = fscanf(fid,'%d',1);

necke = zeros(ntria,3);

for i = 1:ntria
    data = fscanf(fid,'%d',4);
    necke(i,:) = data(2:end);
end

% close file
fclose(fid);
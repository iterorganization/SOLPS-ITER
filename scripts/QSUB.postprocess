#! /bin/tcsh -f

echo ""
echo "This file can be used for post-processing commands after a standalone batch job."
echo ""
echo "Copy this file ( $0 ) to $SOLPSTOP/scripts.local/ and make any modifications you want."
echo ""

tar_important_files

[ -s tracing/blne.trc ] && [ -s tracing/blnn_SPb.trc ] && summarize_run_tracing || summarize_run

[ -e run.log ] && gzip -9 -f run.log

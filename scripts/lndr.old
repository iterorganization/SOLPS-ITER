#! /bin/ksh

#  VERSION : 21.11.94 20:41

##   Modification by A.S.Kukushkin
##   Purpose: to keep local links local,
##   and to avoid getting lost in symbolically linked directories

# lndir - create shadow link tree
#
# $XConsortium: lndir.sh,v 1.8 91/04/15 17:55:03 rws Exp $
#
# Used to create a copy of the a directory tree that has links for all
# non- directories (except those named RCS or SCCS).  If you are
# building the distribution on more than one machine, you should use
# this script.
#
# If your master sources are located in /usr/local/src/X and you would like
# your link tree to be in /usr/local/src/new-X, do the following:
#
#       %  mkdir /usr/local/src/new-X
#       %  cd /usr/local/src/new-X
#       %  lndir ../X

##>>
USAGE="Usage: `basename $0` [-f] fromdir [todir]"

[ $1 = '-f' ] && { FolSymLin='y'; export FolSymLin; shift; }
##<<

if [ $# -lt 1 -o $# -gt 2 ]
then
        echo "$USAGE"
        exit 1
fi

DIRFROM=$1
if [ $# -eq 2 ];
then
        DIRTO=$2
else
        DIRTO=.
fi

if [ ! -d $DIRTO ]
then
        echo "`basename $0`: $DIRTO is not a directory"
        echo "$USAGE"
        exit 2
fi

cd $DIRTO

if [ ! -d $DIRFROM ]
then
        echo "`basename $0`: $DIRFROM must be ABSOLUTE pathname of a DIRECTORY"
        echo "$USAGE"
        exit 2
fi

pwd=`pwd`

##>>
[ "$DRFRLN" = '' ] && { DRFRLN=`(cd $DIRFROM; pwd)`
     [ -L $DIRFROM ] && [ "$FolSymLin" = '' ] && {
             echo "`basename $0`: $DIRFROM is a symbolic link. Specify -f to proceed"
             exit 2; }
}
[ "$DRTOLN" = '' ] && DRTOLN="$pwd"
export DRFRLN DRTOLN
case "$DRTOLN" in
     "$DRFRLN"/* | "$DRFRLN" ) echo `basename $0`":  Cannot create a shadow tree inside the original!!!"
                               exit 2 ;;
     * )  ;;
esac
##<<

if [ `(cd $DIRFROM; pwd)` = $pwd ]
then
        echo "$pwd: FROM and TO are identical!"
        exit 1
fi

##>>
          act=n

for file in `ls -af $DIRFROM`
do
    [ ! -d $DIRFROM/$file ] && { act=f; true; } || { \
            [ $file != RCS -a $file != SCCS -a $file != . -a $file != .. ] && { act=d;
                    [ -L $DIRFROM/$file ] && [ ! -s "$FolSymLin" ] && act=f; }
    }

    if [ $act = f ]
    then
        lnk=`ls -l $DIRFROM/$file | grep \>` && {
             set `echo $lnk | cut -f2 -d\>`; lnk=$1
             case $lnk in
                  "$DRFRLN"/* ) ln -s "$DRTOLN"/`echo $lnk | sed "s;$DRFRLN/;;"` $file ;;
                  /*          ) ln -s $DIRFROM/$file . ;;
                  ../*        ) cd $DIRFROM; cd `dirname $lnk`; tpwd=`pwd`; cd $pwd
                                case $tpwd in
                                    "$DRFRLN"/* | "$DRFRLN" ) ln -s $lnk $file ;;
                                    *           ) ln -s $DIRFROM/$file . ;;
                                esac;;
                  *           ) ln -s $lnk $file ;;
             esac; true
        } || ln -s $DIRFROM/$file .
    else
            if [ "$act" = d ]
            then
                    echo $file:
                    mkdir $file
                    (cd $file
                     pwd=`pwd`
                     case "$DIRFROM" in
                             /*) ;;
                             *)  DIRFROM=../$DIRFROM ;;
                     esac
                     if [ `(cd $DIRFROM/$file; pwd)` = $pwd ]
                     then
                            echo "$pwd: FROM and TO are identical!"
                            exit 1
                     fi
                     $0 $DIRFROM/$file
                    )
            fi
    fi
##<<
done

#! /usr/bin/env tcsh

if ( ! $?RESTART_SOLPS ) set RESTART_SOLPS = 0
if ( ! $?MISSING_DEPENDENCY ) set MISSING_DEPENDENCY = 0
if ( ! $?MISSING_TEX ) set MISSING_TEX = 0

# Create local setup and configuration files, if they do not already exist, where to append the new library paths

# General
if (! -e "${SOLPSTOP}/SETUP/setup.csh.${HOST_NAME}.${COMPILER}.local") then
  touch ${SOLPSTOP}/SETUP/setup.csh.${HOST_NAME}.${COMPILER}.local
else
  cp ${SOLPSTOP}/SETUP/setup.csh.${HOST_NAME}.${COMPILER}.local ${SOLPSTOP}/SETUP/setup.csh.${HOST_NAME}.${COMPILER}.local.bak
endif
if (! -e "${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local") then
  touch ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
else
  cp ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local.bak
endif

# B2.5
if (! -e "${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local") then
  touch ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
else
  cp ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local.bak
endif

# Eirene
if (! -e "${SOLPSTOP}/modules/Eirene/config/config.${HOST_NAME}.${COMPILER}.local") then
  touch ${SOLPSTOP}/modules/Eirene/config/config.${HOST_NAME}.${COMPILER}.local
else
  cp ${SOLPSTOP}/modules/Eirene/config/config.${HOST_NAME}.${COMPILER}.local ${SOLPSTOP}/modules/Eirene/config/config.${HOST_NAME}.${COMPILER}.local.bak
endif

# DivGeo/convert
if (! -e "${SOLPSTOP}/modules/DivGeo/convert/config/config.${HOST_NAME}.${COMPILER}.local") then
  touch ${SOLPSTOP}/modules/DivGeo/convert/config/config.${HOST_NAME}.${COMPILER}.local
else
  cp ${SOLPSTOP}/modules/DivGeo/convert/config/config.${HOST_NAME}.${COMPILER}.local ${SOLPSTOP}/modules/DivGeo/convert/config/config.${HOST_NAME}.${COMPILER}.local.bak
endif

# DivGeo/equtrn
if (! -e "${SOLPSTOP}/modules/DivGeo/equtrn/config/config.${HOST_NAME}.${COMPILER}.local") then
  touch ${SOLPSTOP}//modules/DivGeo/equtrn/config/config.${HOST_NAME}.${COMPILER}.local
else
  cp ${SOLPSTOP}//modules/DivGeo/equtrn/config/config.${HOST_NAME}.${COMPILER}.local ${SOLPSTOP}//modules/DivGeo/equtrn/config/config.${HOST_NAME}.${COMPILER}.local.bak
endif

# Carre
if (! -e "${SOLPSTOP}/modules/Carre/config/config.${HOST_NAME}.${COMPILER}.local") then
  touch ${SOLPSTOP}/modules/Carre/config/config.${HOST_NAME}.${COMPILER}.local
else
  cp ${SOLPSTOP}/modules/Carre/config/config.${HOST_NAME}.${COMPILER}.local ${SOLPSTOP}/modules/Carre/config/config.${HOST_NAME}.${COMPILER}.local.bak
endif

# Carre2
if (-d "${SOLPSTOP}/modules/Carre2") then
 if (! -e "${SOLPSTOP}/modules/Carre2/config/config.${HOST_NAME}.${COMPILER}.local") then
  touch ${SOLPSTOP}/modules/Carre2/config/config.${HOST_NAME}.${COMPILER}.local
 else
  cp ${SOLPSTOP}/modules/Carre2/config/config.${HOST_NAME}.${COMPILER}.local ${SOLPSTOP}/modules/Carre2/config/config.${HOST_NAME}.${COMPILER}.local.bak
 endif
endif

# Triang
if (! -e "${SOLPSTOP}/modules/Triang/config/config.${HOST_NAME}.${COMPILER}.local") then
  touch ${SOLPSTOP}/modules/Triang/config/config.${HOST_NAME}.${COMPILER}.local
else
  cp ${SOLPSTOP}/modules/Triang/config/config.${HOST_NAME}.${COMPILER}.local ${SOLPSTOP}/modules/Triang/config/config.${HOST_NAME}.${COMPILER}.local.bak
endif

# Uinp
if (! -e "${SOLPSTOP}/modules/Uinp/config/config.${HOST_NAME}.${COMPILER}.local") then
  touch ${SOLPSTOP}/modules/Uinp/config/config.${HOST_NAME}.${COMPILER}.local
else
  cp ${SOLPSTOP}/modules/Uinp/config/config.${HOST_NAME}.${COMPILER}.local ${SOLPSTOP}/modules/Uinp/config/config.${HOST_NAME}.${COMPILER}.local.bak
endif

# solps4-5
if (! -e "${SOLPSTOP}/modules/solps4-5/config/config.${HOST_NAME}.${COMPILER}.local") then
  touch ${SOLPSTOP}/modules/solps4-5/config/config.${HOST_NAME}.${COMPILER}.local
else
  cp ${SOLPSTOP}/modules/solps4-5/config/config.${HOST_NAME}.${COMPILER}.local ${SOLPSTOP}/modules/solps4-5/config/config.${HOST_NAME}.${COMPILER}.local.bak
endif

# fxdr
if (! -e "${SOLPSTOP}/modules/fxdr/config/config.${HOST_NAME}.${COMPILER}.local") then
  touch ${SOLPSTOP}/modules/fxdr/config/config.${HOST_NAME}.${COMPILER}.local
else
  cp ${SOLPSTOP}/modules/fxdr/config/config.${HOST_NAME}.${COMPILER}.local ${SOLPSTOP}/modules/fxdr/config/config.${HOST_NAME}.${COMPILER}.local.bak
endif

# Check if the required package managers are installed

if ("$OSTYPE" == "linux") then

  if ("$HOST_NAME" == "LINUX") then   # Local machine

    set CONDA_ROOT = "$SOLPSTOP/lib/${HOST_NAME}.${COMPILER}/miniforge3"
    if (! -d "${CONDA_ROOT}" ) then
      echo
      echo "Warning: miniforge installation not found."
      echo -n "Do you wish to install it? (y/n) [y] "
      set MINIFORGE_INSTALL = $<

      if ( "$MINIFORGE_INSTALL" == "" ) then
        set MINIFORGE_INSTALL = "y"
      endif

      if ( "$MINIFORGE_INSTALL" == "y" ) then
        install_miniforge
        echo "Close your shell, re-open it, start a new SOLPS-ITER"
        echo "and relaunch the install_dependencies script."
        exit 1
      else
        set MISSING_DEPENDENCY = 1
        sleep 1
      endif
    endif

  else   # HPC cluster

    set CONDA_ROOT = "$SOLPSTOP/lib/${HOST_NAME}.${COMPILER}/miniforge3"
    if (! -d "${CONDA_ROOT}" ) then
      echo
      echo "Warning: miniforge installation not found."
      echo "This will be needed to locally, install the Blas/Lapack, NetCDF and NCARG libraries,"
      echo "if any of these is not present in your cluster."
      echo -n "Do you wish to install it? (y/n) [n] "
      set MINIFORGE_INSTALL = $<

      if ( "$MINIFORGE_INSTALL" == "" ) then
        set MINIFORGE_INSTALL = "n"
      endif

      if ( "$MINIFORGE_INSTALL" == "y" ) then
        install_miniforge
        echo set CONDA_ROOT    = \$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/miniforge3 >> ${SOLPSTOP}/SETUP/setup.csh.${HOST_NAME}.${COMPILER}.local
        echo setenv CONDA_CHANGEPS1 no >> ${SOLPSTOP}/SETUP/setup.csh.${HOST_NAME}.${COMPILER}.local
        echo 'source ${CONDA_ROOT}/etc/profile.d/conda.csh >& /dev/null' >> ${SOLPSTOP}/SETUP/setup.csh.${HOST_NAME}.${COMPILER}.local
        echo 'if ( ! $?CONDA_PREFIX ) setenv CONDA_PREFIX ""' >> ${SOLPSTOP}/SETUP/setup.csh.${HOST_NAME}.${COMPILER}.local
        echo 'if ( $?CONDA_PREFIX ) setenv LD_LIBRARY_PATH ${CONDA_PREFIX}/lib:${LD_LIBRARY_PATH}' >> ${SOLPSTOP}/SETUP/setup.csh.${HOST_NAME}.${COMPILER}.local
        echo "Close your shell, re-open it, start a new SOLPS-ITER"
        echo "and relaunch the install_dependencies script."
        exit 1
      else
        set MISSING_DEPENDENCY = 1
        sleep 1
      endif
    endif

  endif

else if ("$OSTYPE" == "darwin") then

  set XQUARTZ_HOME = "/opt/X11"
  if ( ! -d "$XQUARTZ_HOME" ) then
    echo
    echo "Warning: XQuartz installation not found. Install it from https://www.xquartz.org/."
    echo "After that, relaunch the install_dependencies script."
    exit 1
  endif

  if ( `which brew >& /dev/null; echo $status` != 0 ) then
    echo
    echo "Warning: Homebrew installation not found. Install it from https://brew.sh/."
    echo "After that, relaunch the install_dependencies script."
    exit 1
  endif

  if ( `which port >& /dev/null; echo $status` != 0 ) then
    echo
    echo "Warning: MacPorts installation not found. Install it from https://ports.macports.org/."
    echo "After that, relaunch the install_dependencies script."
    exit 1
  endif

endif

# Create lib folder for locally compiled libraries if it does not exist

if (! -d "${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}" ) then
  mkdir -p "${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}"
endif

# Install X11 development library

if ("$OSTYPE" == "linux" && "$HOST_NAME" == "LINUX") then   # Only for Linux; for MacOS to be replaced by manual installation of XQuartz

  set pkg_check = `dpkg -l | grep -w xorg-dev`
  if ("$pkg_check" == "") then   # Check if the library is already installed

    echo
    echo X11 development library not locally installed.
    echo -n "Do you wish to install it? The apt package manager will be used. (y/n) [y] "
    set XORG_INSTALL = $<

    if ( "$XORG_INSTALL" == "" ) then
      set XORG_INSTALL = "y"
    endif

    if ( "$XORG_INSTALL" == "y" ) then
      sudo apt-get install -y xorg-dev
      echo X11 development library successfully installed.
      sleep 1
    else
      set MISSING_DEPENDENCY = 1
      sleep 1
    endif

  else
    echo
    echo X11 development library already locally installed.
    sleep 1

  endif

endif

# Install relevant compilers

if ("$OSTYPE" == "linux" && "$HOST_NAME" == "LINUX") then

  set pkg_check = `dpkg -l | grep -w gcc`
  if ("$pkg_check" == "") then   # Check if the compiler is already installed

    echo
    echo gcc compiler not locally installed.
    echo -n "Do you wish to install it? The apt package manager will be used. (y/n) [y] "
    set GCC_INSTALL = $<

    if ( "$GCC_INSTALL" == "" ) then
      set GCC_INSTALL = "y"
    endif

    if ( "$GCC_INSTALL" == "y" ) then
      sudo apt-get install -y gcc
      echo gcc compiler successfully installed.
      sleep 1
    else
      set MISSING_DEPENDENCY = 1
      sleep 1
    endif

  else
    echo
    echo gcc compiler already locally installed.
    sleep 1

  endif

  set pkg_check = `dpkg -l | grep -w g++`
  if ("$pkg_check" == "") then   # Check if the compiler is already installed

    echo
    echo g++ compiler not locally installed.
    echo -n "Do you wish to install it? The apt package manager will be used. (y/n) [y] "
    set GPP_INSTALL = $<

    if ( "$GPP_INSTALL" == "" ) then
        set GPP_INSTALL = "y"
    endif

    if ( "$GPP_INSTALL" == "y" ) then
      sudo apt-get install -y g++
      echo g++ compiler successfully installed.
      sleep 1
    else
      set MISSING_DEPENDENCY = 1
      sleep 1
    endif

  else
    echo
    echo g++ compiler already locally installed.
    sleep 1

  endif

  set pkg_check = `dpkg -l | grep -w gfortran`
  if ("$pkg_check" == "") then   # Check if the compiler is already installed

    echo
    echo gfortran compiler not locally installed.
    echo -n "Do you wish to install it? The apt package manager will be used. (y/n) [y] "
    set GFORTRAN_INSTALL = $<

    if ( "$GFORTRAN_INSTALL" == "" ) then
        set GFORTRAN_INSTALL = "y"
    endif

    if ( "$GFORTRAN_INSTALL" == "y" ) then
      sudo apt-get install -y gfortran
      echo gfortran compiler successfully installed.
      sleep 1
    else
      set MISSING_DEPENDENCY = 1
      sleep 1
    endif

  else
    echo
    echo gfortran compiler already locally installed.
    sleep 1

  endif

else if ("$OSTYPE" == "darwin") then

  if ( `brew list | grep -c '^gcc$'` == 0 ) then   # Check if the library is already installed

    echo
    echo gcc library not locally installed.
    echo -n "Do you wish to install it? The brew package manager will be used. (y/n) [y] "
    set GCC_INSTALL = $<

    if ( "$GCC_INSTALL" == "" ) then
      set GCC_INSTALL = "y"
    endif

    if ( "$GCC_INSTALL" == "y" ) then
      brew install gcc
      echo gcc library successfully installed.
      sleep 1
    else
      set MISSING_DEPENDENCY = 1
      sleep 1
    endif

  else
    echo
    echo gcc library already locally installed.
    sleep 1

  endif

endif


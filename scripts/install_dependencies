# Clond and compile JSON-Fortran library

if ("$OSTYPE" == "linux") then

  if ( ! -e "${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2/lib/libjsonfortran.a" ) then   # Check if the compiled library already exists locally

    echo
    echo JSON-Fortran library not locally installed.
    echo -n "Do you wish to install it? It will be cloned and locally compiled in SOLPSLIB. (y/n) [y] "
    set JSON_INSTALL = $<

    if ( "$JSON_INSTALL" == "" ) then
        set JSON_INSTALL = "y"
    endif

    if ( "$JSON_INSTALL" == "y" ) then
      define_compilers
      set RESTART_SOLPS = 1
      cd $SOLPSTOP/lib/${HOST_NAME}.${COMPILER}
      if ( -d "${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2" ) then
        rm -rf "${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2"
      endif
      wget https://github.com/jacobwilliams/json-fortran/archive/refs/tags/9.0.2.tar.gz
      tar xvf 9.0.2.tar.gz
      cd "${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2"
      mkdir -p build
      cmake -S ${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2 ${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2/build
      cd build
      make
      mkdir -p ${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2/lib
      mkdir -p ${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2/include
      cp ${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2/build/lib/libjsonfortran.a ${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2/lib/
      cp ${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2/build/*.mod ${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2/include/
      rm $SOLPSTOP/lib/${HOST_NAME}.${COMPILER}/9.0.2.tar.gz
      echo LIBJSON  = \$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2/lib >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
      echo LIBJSON  \?= \$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2/lib >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
      echo LDLIBES  += -L\$\{LIBJSON\} -ljsonfortran >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
      echo LIBJSON  \?= \$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/json-fortran-9.0.2/lib >> ${SOLPSTOP}/modules/Eirene/config/config.${HOST_NAME}.${COMPILER}.local
      cd $SOLPSTOP
      echo JSON-Fortran library successfully installed.
      sleep 1
    else
      set MISSING_DEPENDENCY = 1
      sleep 1
    endif

  else
    echo
    echo JSON-Fortran library already locally installed.
    sleep 1

  endif

else if ("$OSTYPE" == "darwin") then

  if ( ! -e /opt/local/lib/libjsonfortran.a ) then   # Check if the library is already installed

    echo
    echo JSON-Fortran library not locally installed.
    echo -n "Do you wish to install it? The port package manager will be used. (y/n) [y] "
    set JSON_INSTALL = $<

    if ( "$JSON_INSTALL" == "" ) then
      set JSON_INSTALL = "y"
    endif

    if ( "$JSON_INSTALL" == "y" ) then
      sudo port install fortran-json
      echo JSON-Fortran library successfully installed.
      sleep 1
    else
      set MISSING_DEPENDENCY = 1
      sleep 1
    endif

  else
    echo
    echo JSON-Fortran library already locally installed.
    sleep 1

  endif

endif

# Install NCARG/Cairo libraries

if ("$OSTYPE" == "linux") then

  if ("$HOST_NAME" == "LINUX") then   # Local machine

    set CONDA_BASE = `conda info --base`
    if ( ! -d "$CONDA_BASE/envs/solps_ncl_env" ) then   # Check if the environment with the library is already existing

      echo
      echo NCARG library not locally installed.
      echo -n "Do you wish to install it? The environment solps_ncl_env will be created with conda. (y/n) [y] "
      set NCARG_INSTALL = $<

      if ( "$NCARG_INSTALL" == "" ) then
        set NCARG_INSTALL = "y"
      endif

      if ( "$NCARG_INSTALL" == "y" ) then
        set RESTART_SOLPS = 1
        setenv CONDA_CHANGEPS1 no
        set CONDA_BASE = `conda info --base`
        $CONDA_BASE/bin/conda create -n solps_ncl_env -c conda-forge -y ncl
        conda activate solps_ncl_env
        echo NCARG library successfully installed.
        sleep 1
      else
        set MISSING_DEPENDENCY = 1
        sleep 1
      endif

    else
      echo
      echo NCARG library already locally installed.
      sleep 1

    endif

    set pkg_check = `dpkg -l | grep -w libcairo2-dev`
    if ("$pkg_check" == "") then   # Check if the library is already installed

      echo
      echo Cairo library not locally installed.
      echo -n "Do you wish to install it? The apt package manager will be used. (y/n) [y] "
      set CAIRO_INSTALL = $<

      if ( "$CAIRO_INSTALL" == "" ) then
        set CAIRO_INSTALL = "y"
      endif

      if ( "$CAIRO_INSTALL" == "y" ) then
        sudo apt-get install -y libcairo2-dev
        echo Cairo library successfully installed.
        sleep 1
      else
        set MISSING_DEPENDENCY = 1
        sleep 1
      endif

    else
      echo
      echo Cairo library already locally installed.
      sleep 1

    endif

  else   # HPC cluster

    if ("$COMPILER" == "gfortran") then

      echo
      echo -n "Do you wish to locally install the NCARG library? The conda package manager will be used. (y/n) [n] "
      set NCARG_INSTALL = $<

      if ( "$NCARG_INSTALL" == "" ) then
        set NCARG_INSTALL = "n"
      endif

      if ( "$NCARG_INSTALL" == "y" ) then
        set CONDA_ROOT = "$SOLPSTOP/lib/${HOST_NAME}.${COMPILER}/miniforge3"
        if (! -d "${CONDA_ROOT}" ) then
          echo
          echo "Warning: miniforge installation still not found."
          echo "Restart the install_dependencies script and choose the option to install it."
          sleep 1
        else
          set CONDA_BASE = `conda info --base`
          if ( ! -d "$CONDA_BASE/envs/solps_env" ) then
            set RESTART_SOLPS = 1
            $CONDA_BASE/bin/conda create -n solps_env -c conda-forge -y ncl cairo fontconfig freetype bzip2
            conda activate solps_env
            echo conda activate solps_env >> ${SOLPSTOP}/SETUP/setup.csh.${HOST_NAME}.${COMPILER}.local
            echo NCARG_DIR  = \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
            echo LD_NCARG  = -L\$\{NCARG_DIR\} -lncarg -lncarg_gks -lncarg_c -lm -lX11 -lXext \`pkg-config --libs cairo\` -lfontconfig -lfreetype -lpthread -lXrender -lbz2 >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
            echo NCARG_DIR  \?= \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
            echo LD_NCARG  \?= -L\$\{NCARG_DIR\} -lncarg -lncarg_gks -lncarg_c -lm -lX11 -lXext \`pkg-config --libs cairo\` -lfontconfig -lfreetype -lpthread -lXrender -lbz2 >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
            echo NCARG library successfully locally installed.
            sleep 1
          else
            conda activate solps_env
            set ncarg_installed = `$CONDA_BASE/bin/conda list -n solps_env | awk '{print $1}' | grep -w ncl`
            if ("$ncarg_installed" != "") then
                echo NCARG library library already locally installed.
            else
                set RESTART_SOLPS = 1
                $CONDA_BASE/bin/conda install -c conda-forge -y ncl cairo fontconfig freetype bzip2
                echo NCARG_DIR  = \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
                echo LD_NCARG  = -L\$\{NCARG_DIR\} -lncarg -lncarg_gks -lncarg_c -lm -lX11 -lXext \`pkg-config --libs cairo\` -lfontconfig -lfreetype -lpthread -lXrender -lbz2 >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
                echo NCARG_DIR  \?= \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
                echo LD_NCARG  \?= -L\$\{NCARG_DIR\} -lncarg -lncarg_gks -lncarg_c -lm -lX11 -lXext \`pkg-config --libs cairo\` -lfontconfig -lfreetype -lpthread -lXrender -lbz2 >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
                echo NCARG library library successfully locally installed.
            endif
            sleep 1
          endif
        endif
      else
        sleep 1
      endif

    endif

  endif

else if ("$OSTYPE" == "darwin") then

  if ( ! -e /opt/local/lib/libncarg.a ) then   # Check if the library is already installed

    echo
    echo NCARG library not locally installed.

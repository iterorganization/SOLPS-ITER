  sleep 1

endif

# Clone and compile GR library

if ( ! -e "${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/gr/libgr.a" ) then   # Check if the compiled library already exists locally

  echo
  echo GR library not locally installed.
  echo -n "Do you wish to install it? It will be cloned and locally compiled in SOLPSLIB. (y/n) [y] "
  set GR_INSTALL = $<

  if ( "$GR_INSTALL" == "" ) then
      set GR_INSTALL = "y"
  endif

  if ( "$GR_INSTALL" == "y" ) then
    define_compilers
    set RESTART_SOLPS = 1
    cd $SOLPSTOP/lib/${HOST_NAME}.${COMPILER}
    if ( -d "${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/gr" ) then
      rm -rf "${SOLPSTOP}/lib/${HOST_NAME}.${COMPILER}/gr"
    endif
    git clone https://github.com/iterorganization/GR-Software.git gr
    cd gr
    if ("$OSTYPE" == "linux") then
      sed -i 's/^all: libgr.a install$/all: libgr.a/' Makefile
      sed -i '/^install: libgr.a$/,/^  cp libgr.a $(SOLPS_LIB)$/d' Makefile
      if ("$COMPILER" == "gfortran") then
        cat <<EOF >> Makefile
linux.gfortran:
	@make all F77="gfortran" \\
	CFLAGS="-Wno-implicit-int -Wno-implicit-function-declaration" \\
	F77FLAGS="-O3 -std=legacy -fdefault-real-8 -fno-range-check -fallow-argument-mismatch -ffree-line-length-0" \\
	F90="gfortran" \\
	F90FLAGS="-O3 -std=legacy -fdefault-real-8 -fno-range-check -fallow-argument-mismatch -ffree-line-length-0" \\
	F90OBJS="" \\
	RANLIB="echo" \\
	BLDFLAG="ar cr"
EOF
        make linux.gfortran
      else
        make linux.${COMPILER}
      endif
    else if ("$OSTYPE" == "darwin") then
      sed -i '' 's/^all: libgr.a install$/all: libgr.a/' Makefile
      sed -i '' '/^install: libgr.a$/,/^  cp libgr.a $(SOLPS_LIB)$/d' Makefile
      cat <<EOF >> Makefile
darwin.gfortran:
	@make all F77="gfortran" \\
	CFLAGS="-Wno-implicit-int -Wno-implicit-function-declaration" \\
	F77FLAGS="-O3 -std=legacy -fdefault-real-8 -fno-range-check -fallow-argument-mismatch -ffree-line-length-0" \\
	F90="gfortran" \\
	F90FLAGS="-O3 -std=legacy -fdefault-real-8 -fno-range-check -fallow-argument-mismatch -ffree-line-length-0" \\
	F90OBJS="" \\
	RANLIB="echo" \\
	BLDFLAG="ar cr"
EOF
      make darwin.gfortran
    endif
    echo GR_ROOT    = \$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/gr >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
    echo LD_GR      = -L\$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/gr -lgr >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
    echo GR_ROOT   \?= \$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/gr >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
    echo LD_GR     \?= -L\$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/gr -lgr >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
    echo GR_ROOT   \?= \$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/gr >> ${SOLPSTOP}/modules/Eirene/config/config.${HOST_NAME}.${COMPILER}.local
    echo LD_GR     \?= -L\$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/gr -lgr >> ${SOLPSTOP}/modules/Eirene/config/config.${HOST_NAME}.${COMPILER}.local
    echo GR_ROOT   \?= \$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/gr >> ${SOLPSTOP}/modules/Carre/config/config.${HOST_NAME}.${COMPILER}.local
    echo LD_GR     \?= -L\$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/gr -lgr >> ${SOLPSTOP}/modules/Carre/config/config.${HOST_NAME}.${COMPILER}.local
    if (-d "${SOLPSTOP}/modules/Carre2") then
      echo GR_ROOT   \?= \$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/gr >> ${SOLPSTOP}/modules/Carre2/config/config.${HOST_NAME}.${COMPILER}.local
      echo LD_GR     \?= -L\$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/gr -lgr >> ${SOLPSTOP}/modules/Carre2/config/config.${HOST_NAME}.${COMPILER}.local
    endif
    echo GR_ROOT   \?= \$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/gr >> ${SOLPSTOP}/modules/Triang/config/config.${HOST_NAME}.${COMPILER}.local
    echo LD_GR     \?= -L\$\{SOLPSTOP\}/lib/${HOST_NAME}.${COMPILER}/gr -lgr >> ${SOLPSTOP}/modules/Triang/config/config.${HOST_NAME}.${COMPILER}.local
    cd $SOLPSTOP
    echo GR library successfully installed.
    sleep 1
  else
    set MISSING_DEPENDENCY = 1
    sleep 1
  endif

else
  echo
  echo GR library already locally installed.
  sleep 1

endif

# Install TeXlive library

if ("$OSTYPE" == "linux" && "$HOST_NAME" == "LINUX") then

  set pkg_check = `dpkg -l | grep -w texlive-full`
  if ("$pkg_check" == "") then   # Check if the library is already installed

    echo
    echo TeXlive library not locally installed.
    echo -n "Do you wish to install it? The apt package manager will be used. (y/n) [y] "
    set TEXLIVE_INSTALL = $<

    if ( "$TEXLIVE_INSTALL" == "" ) then
      set TEXLIVE_INSTALL = "y"
    endif

    if ( "$TEXLIVE_INSTALL" == "y" ) then
      sudo apt-get install -y texlive-full
      echo TeXlive library successfully installed.
      sleep 1
    else
      set MISSING_TEX = 1
      sleep 1
    endif

  else
    echo
    echo TeXlive library already locally installed.
    sleep 1

  endif

else if ("$OSTYPE" == "darwin") then

  if ( `brew list | grep -c '^texlive$'` == 0 ) then   # Check if the library is already installed

    echo
    echo TeXlive library not locally installed.
    echo -n "Do you wish to install it? The brew package manager will be used. (y/n) [y] "
    set TEXLIVE_INSTALL = $<

    if ( "$TEXLIVE_INSTALL" == "" ) then
      set TEXLIVE_INSTALL = "y"
    endif

    if ( "$TEXLIVE_INSTALL" == "y" ) then
      brew install texlive
      echo TeXlive library successfully installed.
      sleep 1
    else
      set MISSING_TEX = 1
      sleep 1
    endif

  else
    echo
    echo TeXlive library already locally installed.
    sleep 1

  endif

endif

if ( $?MISSING_DEPENDENCY && "$MISSING_DEPENDENCY" == "1" ) then

  echo
  echo Warning: some dependencies are still missing.
  echo SOLPS-ITER compilation may fail, or the code may not run properly.

else

  echo
  echo All dependencies are correctly installed.
  echo You are ready to compile and use SOLPS-ITER.

endif

if ( $?MISSING_TEX && "$MISSING_TEX" == "1" ) then

  echo Warning: A full LaTeX installation is still missing.
  echo The manuals may not be correctly generated.

endif

# If at least one of the libraries was absent and was locally compiled within SOLPSLIB, then warn the user to restart the session to re-initialize variables
# in order to avoid clashes with the shortcuts to compiler variables

if ( $?RESTART_SOLPS && "$RESTART_SOLPS" == "1" ) then

  echo The variables linking some locally compiled libraries have been
  echo written to \$\{SOLPSTOP\}/SETUP/config.${HOST_NAME}.${COMPILER}.local.
  echo Please close your SOLPS-ITER session and your shell and restart them.

endif

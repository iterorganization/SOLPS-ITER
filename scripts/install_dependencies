# Install Blas/Lapack libraries

if ("$OSTYPE" == "linux") then

  if ("$HOST_NAME" == "LINUX") then   # Local machine

    set pkg_check = `dpkg -l | grep -w libblas-dev`
    if ("$pkg_check" == "") then   # Check if the library is already installed

      echo
      echo Blas library not locally installed.
      echo -n "Do you wish to install it? The apt package manager will be used. (y/n) [y] "
      set BLAS_INSTALL = $<

      if ( "$BLAS_INSTALL" == "" ) then
        set BLAS_INSTALL = "y"
      endif

      if ( "$BLAS_INSTALL" == "y" ) then
        sudo apt-get install -y libblas-dev
        echo Blas library successfully installed.
        sleep 1
      else
        set MISSING_DEPENDENCY = 1
        sleep 1
      endif

    else
      echo
      echo Blas library already locally installed.
      sleep 1

    endif

    set pkg_check = `dpkg -l | grep -w liblapack-dev`
    if ("$pkg_check" == "") then   # Check if the library is already installed

      echo
      echo Lapack library not locally installed.
      echo -n "Do you wish to install it? The apt package manager will be used. (y/n) [y] "
      set LAPACK_INSTALL = $<

      if ( "$LAPACK_INSTALL" == "" ) then
        set LAPACK_INSTALL = "y"
      endif

      if ( "$LAPACK_INSTALL" == "y" ) then
        sudo apt-get install -y liblapack-dev
        echo Lapack library successfully installed.
        sleep 1
      else
        set MISSING_DEPENDENCY = 1
        sleep 1
      endif

    else
      echo
      echo Lapack library already locally installed.
      sleep 1

    endif

  else   # HPC cluster

    echo
    echo -n "Do you wish to locally install the Blas/Lapack library? The conda package manager will be used. (y/n) [n] "
    set BLASLAPACK_INSTALL = $<

    if ( "$BLASLAPACK_INSTALL" == "" ) then
      set BLASLAPACK_INSTALL = "n"
    endif

    if ( "$BLASLAPACK_INSTALL" == "y" ) then
      set CONDA_ROOT = "$SOLPSTOP/lib/${HOST_NAME}.${COMPILER}/miniforge3"
      if (! -d "${CONDA_ROOT}" ) then
        echo
        echo "Warning: miniforge installation still not found."
        echo "Restart the install_dependencies script and choose the option to install it."
        sleep 1
      else
        set CONDA_BASE = `conda info --base`
        if ( ! -d "$CONDA_BASE/envs/solps_env" ) then
          set RESTART_SOLPS = 1
          $CONDA_BASE/bin/conda create -n solps_env -c conda-forge -y blas lapack
          conda activate solps_env
          echo conda activate solps_env >> ${SOLPSTOP}/SETUP/setup.csh.${HOST_NAME}.${COMPILER}.local
          echo LAPACK_LIB_DIR  = \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
          echo BLAS_LIB_DIR  = \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
          echo LD_NAG  = -L\$\{LAPACK_LIB_DIR\} -llapack -L\$\{BLAS_LIB_DIR\} -lblas >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
          echo SOLPS_CPP      = -DNCAR4 -DNO_NAG >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
          echo LAPACK_LIB_DIR  \?= \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
          echo BLAS_LIB_DIR  \?= \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
          echo LD_NAG  \?= -L\$\{LAPACK_LIB_DIR\} -llapack -L\$\{BLAS_LIB_DIR\} -lblas >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
          echo LAPACK_LIB_DIR  \?= \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/modules/Eirene/config/config.${HOST_NAME}.${COMPILER}.local
          echo BLAS_LIB_DIR  \?= \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/modules/Eirene/config/config.${HOST_NAME}.${COMPILER}.local
          echo LD_NAG  \?= -L\$\{LAPACK_LIB_DIR\} -llapack -L\$\{BLAS_LIB_DIR\} -lblas >> ${SOLPSTOP}/modules/Eirene/config/config.${HOST_NAME}.${COMPILER}.local
          echo Blas/Lapack library successfully locally installed.
          sleep 1
        else
          conda activate solps_env
          set blas_installed = `$CONDA_BASE/bin/conda list -n solps_env | awk '{print $1}' | grep -w blas`
          set lapack_installed = `$CONDA_BASE/bin/conda list -n solps_env | awk '{print $1}' | grep -w lapack`
          if ("$blas_installed" != "" && "$lapack_installed" != "") then
              echo Blas/Lapack library already locally installed.
          else
              set RESTART_SOLPS = 1
              $CONDA_BASE/bin/conda install -c conda-forge -y blas lapack
              echo LAPACK_LIB_DIR  = \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
              echo BLAS_LIB_DIR  = \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
              echo LD_NAG  = -L\$\{LAPACK_LIB_DIR\} -llapack -L\$\{BLAS_LIB_DIR\} -lblas >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
              echo SOLPS_CPP      = -DNCAR4 -DNO_NAG >> ${SOLPSTOP}/SETUP/config.${HOST_NAME}.${COMPILER}.local
              echo LAPACK_LIB_DIR  \?= \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
              echo BLAS_LIB_DIR  \?= \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
              echo LD_NAG  \?= -L\$\{LAPACK_LIB_DIR\} -llapack -L\$\{BLAS_LIB_DIR\} -lblas >> ${SOLPSTOP}/modules/B2.5/config/config.${HOST_NAME}.${COMPILER}.local
              echo LAPACK_LIB_DIR  \?= \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/modules/Eirene/config/config.${HOST_NAME}.${COMPILER}.local
              echo BLAS_LIB_DIR  \?= \$\{CONDA_PREFIX\}/lib >> ${SOLPSTOP}/modules/Eirene/config/config.${HOST_NAME}.${COMPILER}.local
              echo LD_NAG  \?= -L\$\{LAPACK_LIB_DIR\} -llapack -L\$\{BLAS_LIB_DIR\} -lblas >> ${SOLPSTOP}/modules/Eirene/config/config.${HOST_NAME}.${COMPILER}.local
              echo Blas/Lapack library successfully locally installed.
          endif
          sleep 1
        endif
      endif
    else
      sleep 1
    endif

  endif

else if ("$OSTYPE" == "darwin") then

  if ( `brew list | grep -c '^lapack$'` == 0 ) then   # Check if the library is already installed

    echo
    echo Blas/Lapack library not locally installed.
    echo -n "Do you wish to install it? The brew package manager will be used. (y/n) [y] "

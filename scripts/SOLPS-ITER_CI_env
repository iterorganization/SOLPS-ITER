# Set up environment for SOLPS-ITER compilation and test runs

set -v

export OS=`grep -m1 NAME /etc/os-release | cut -d '"' -f 2 | cut -d ' ' -f 1`
[ $OS = "CentOS" ] && {
  . /usr/share/Modules/init/sh
} || {
  . /etc/profile.d/modules.sh
}

export MAKE=/usr/bin/gmake
export LMOD_SH_DBG_ON=1
echo "export HOST_NAME=ITER" > $(dirname $0)/../SETUP/setup.ksh.HOST_NAME.local
. $(dirname $0)/../setup.ksh ifort64
module list
make local

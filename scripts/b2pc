#      echo "ne\t$im" >> ${LK}_${L}m.ps.legend
#      echo "dab2 1 zsel 'LIF-$d-$v.00$i' chvl drop" >> mono.${LK}
#      echo "nHe0\t$im" >> ${LK}_${L}m.ps.legend
#      echo "na 3 zsel 'LIF-$d-$v.00$i' chvl drop" >> mono.${LK}
#      echo "nHe+\t$im" >> ${LK}_${L}m.ps.legend

# Set up SOLPS-ITER environment
. $(dirname $0)/SOLPS-ITER_CI_env

# Compile the code with MPI options activated
echo "LDOPTS += -mcmodel=large -shared-intel" > ${SOLPSTOP}/modules/B2.5/config/config.ITER.ifort64.local
echo "FCOPTS += -mcmodel=large -shared-intel -diag-enable=error" >> ${SOLPSTOP}/modules/B2.5/config/config.ITER.ifort64.local
export NO_MANUAL="true"
make VERSION_nox
make listobj_nox depend_nox
make divgeo_nox
make MAKE_OPTIONS=-j8 solps_nox_mpi

# Run test case
. ${SOLPSTOP}/SETUP/mpi.ksh
cd ${SOLPSTOP}/runs/examples
make ITER_2360_0.95He+0.05H_40MW
cd ITER_2360_0.95He+0.05H_40MW
export DEVICE=iter
correct_baserun_timestamps
mkdir run_CI_MPI_test
cd run_CI_MPI_test
cp ../ref_run_for_MPI_CI/b2.*.parameters .
cp ../ref_run_for_MPI_CI/b2.feedback_save.parameters.i b2.feedback_save.parameters
cp ../ref_run_for_MPI_CI/b2mn.dat .
cp ../ref_run_for_MPI_CI/b2fstati .
cp ../ref_run_for_MPI_CI/input.dat .
cp ../ref_run_for_MPI_CI/fort.11.i fort.11
cp ../ref_run_for_MPI_CI/fort.13.i fort.13
cp ../ref_run_for_MPI_CI/fort.44.i fort.44
cp ../ref_run_for_MPI_CI/fort.46.i fort.46
cp ../ref_run_for_MPI_CI/b2time.nc.i b2time.nc
touch b2fstati
setup_baserun_eirene_links
b2run -m \"mpiexec -np 4\" b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks_MPI_CI_coupled.sh ../ref_run_for_MPI_CI/ ./ || exit 1

cd ..
mkdir run_CI_MPI_test_9-pt
cd run_CI_MPI_test_9-pt
cp ../ref_run_for_MPI_CI_9-pt/b2.*.parameters .
cp ../ref_run_for_MPI_CI_9-pt/b2.feedback_save.parameters.i b2.feedback_save.parameters
cp ../ref_run_for_MPI_CI_9-pt/b2mn.dat .
cp ../ref_run_for_MPI_CI_9-pt/b2fstati .
cp ../ref_run_for_MPI_CI_9-pt/input.dat .
cp ../ref_run_for_MPI_CI_9-pt/fort.11.i fort.11
cp ../ref_run_for_MPI_CI_9-pt/fort.13.i fort.13
cp ../ref_run_for_MPI_CI_9-pt/fort.44.i fort.44
cp ../ref_run_for_MPI_CI_9-pt/fort.46.i fort.46
cp ../ref_run_for_MPI_CI_9-pt/b2time.nc.i b2time.nc
touch b2fstati
setup_baserun_eirene_links
b2run -m \"mpiexec -np 4\" b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks_MPI_CI_coupled.sh ../ref_run_for_MPI_CI_9-pt/ ./ || exit 2

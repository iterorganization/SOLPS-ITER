# Set up SOLPS-ITER environment
. $(dirname $0)/SOLPS-ITER_CI_env

# Compile the code with MPI options activated
echo "LDOPTS += -mcmodel=large -shared-intel" > ${SOLPSTOP}/modules/B2.5/config/config.ITER.ifort64.local
echo "FCOPTS += -mcmodel=large -shared-intel -diag-enable=error" >> ${SOLPSTOP}/modules/B2.5/config/config.ITER.ifort64.local
export NO_MANUAL="true"
make listobj_nox depend_nox
make divgeo_nox
make MAKE_OPTIONS=-j8 solps_nox_mpi

# Run test case
. ${SOLPSTOP}/SETUP/mpi.ksh
cd ${SOLPSTOP}/runs/examples
make COMPASS_16515_1150ms_D_drift_AFN
cd COMPASS_16515_1150ms_D_drift_AFN
export DEVICE=compass
correct_baserun_timestamps
# cd baserun
# rm *.prt b2fgmtry b2fpardf b2fstati b2frates
# b2run b2ag b2ah b2ai b2ar
# cd ..

# Important note! We assume the case run_kin_mpi has been run with 4 processes. If this is not the case, the test will likely fail.
mkdir run_kin_mpi_test
cd run_kin_mpi_test
cp ../run_kin_mpi/b2.*.parameters .
cp ../run_kin_mpi/b2mn.dat .
cp ../run_kin_mpi/input.dat .
cp ../run_kin_mpi/b2fstati .
cp ../run_kin_mpi/b2time.nc.i b2time.nc
cp ../run_kin_mpi/fort.11.i fort.11
cp ../run_kin_mpi/fort.13.i fort.13
cp ../run_kin_mpi/fort.15.i fort.15
cp ../run_kin_mpi/fort.44.i fort.44
cp ../run_kin_mpi/fort.46.i fort.46
touch b2fstati
setup_baserun_eirene_links
b2run -m \"mpiexec -np 4\" b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks_MPI_CI_coupled.sh ../run_kin_mpi/ ./ || exit 1

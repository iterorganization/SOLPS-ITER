# Start the debug build from clean build dirs.  The CI agent workspace is
# persistent across builds; a stale/partial CMake build tree left by an earlier
# (possibly interrupted) build makes the coupled-Eirene cmake configure emit no
# Makefile ("No targets specified and no makefile found").  Note that
# "make clean_*" does NOT help here: the clean_*eirene* targets clean via the
# legacy config/Makefile and never touch the CMake builds/ trees.  Remove the
# debug build dirs explicitly.  Compiler-agnostic: matches *.ifort64.debug,
# *.gfortran.debug and any .openmp/.mpi debug variant (no-op if none exist).
rm -rf ${SOLPSTOP}/modules/Eirene/builds/*.debug \
       ${SOLPSTOP}/modules/B2.5/builds/*.debug

# Compile the code with debug options activated
echo "FCOPTS += -diag-enable=error" >> ${SOLPSTOP}/modules/B2.5/config/config.ITER.ifort64.local
export NO_MANUAL="true"
make prereqs_nox_debug
make divgeo_nox_debug
make -j${SLURM_CPUS_PER_TASK:-$(nproc)} solps_nox_debug b25_nox_debug

# Run test case
. ${SOLPSTOP}/SETUP/debug.ksh
cd ${SOLPSTOP}/runs/examples
make AUG_16151_D+C+He
cd AUG_16151_D+C+He
export DEVICE=upgrade
cd baserun
rm *.prt
b2run b2ag b2ah b2ai b2ar
cd ..
mkdir run_standalone_debug_new
cd run_standalone_debug_new
cp ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/b2.*.parameters .
cp ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/b2mn.dat .
cp ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone/b2fstati .
touch b2fstati
setup_baserun_B25_links
echo "'b2mndr_ntim' '10'" >> b2mn.dat
b2run -s b2mn
${SOLPSTOP}/modules/B2.5/src/test/run_checks.sh ../16151_1.6MW_2.0e19_D=0.4_chi=1.6_standalone ./

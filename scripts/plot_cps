### eval '(exit $?0)' && eval 'exec tcsh $0 ${1+"$@"}' && eval 'exec tcsh $0 $argv:q'
#! /usr/bin/env tcsh

if($?GNUPLOT_TMP) then
    set tmpdir="$GNUPLOT_TMP/"
else
    set tmpdir=""
endif
if($?GNUPLOT_CMD) then
    set cfilename=${tmpdir}$GNUPLOT_CMD
else
    set cfilename=${tmpdir}gnuplot.cmd
endif
if($1 == "") then
  set filename=${tmpdir}out.ps
else
  set filename=${tmpdir}$1
endif
if (! $?PS_SIZE) setenv PS_SIZE
if (`uname -s` == Linux) then
  (/bin/echo -e 'set term postscript color solid '$PS_SIZE'\nset out "'$filename'"' ;\
 egrep -v '^pause |^set term ' $cfilename ) > ! ${tmpdir}gnuplot_cps.cmd
else
  (/bin/echo 'set term postscript color solid '$PS_SIZE'\nset out "'$filename'"' ;\
 egrep -v '^pause |^set term ' $cfilename ) > ! ${tmpdir}gnuplot_cps.cmd
endif
gnuplot ${tmpdir}gnuplot_cps.cmd

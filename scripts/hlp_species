#! /bin/ksh

#syntax for call: hlp_species filename searchstring; output is species list
# e.g.  specieslist=`hlp_species tracing/sources.trc srcni00i_`

name=`basename $0`

filename=$1
[ ! -r "$filename" ] && { echo "$name: filename=$filename does not exist!!!" >&2; exit 33; }
shift

#get number of headerline (last line with hash mark
#headerline=`cat $filename | grep "^#" | wc -l | awk '{print $1}'`
headerline=`cut -c1 $filename | grep "^#" | wc -l | awk '{print $1}'`
[ -z "$headerline" ] && { echo "$name: headerline not specified" >&2; exit 32; }
[ $headerline -gt 0 ] || { echo "$name: headerline=$headerline; not correct" >&2; exit 32; }

searchstring=$1
[ -z "$searchstring" ] && { echo "$name: searchstring not specified" >&2; exit 32; }

# Check the "$searchstring" for occurence of '/'.
# If yes, then select another separator for sed
case "$searchstring" in
    */* )   d=; for d in \% \. \, \+  \= \@ \~ \: \? \!; do
                case "$searchstring" in
                    *$d*    )   ;;
                    *       )   d=$d; break;;
                esac;
            done; [ -z "$d" ] && { echo "$name: Too complicated search pattern" >&2; exit 4; };;
    *   )   d='/';;
esac; echo "$name: d = $d" >&2
species=`cat $filename | head -$headerline | tail -1 \
| tr '\011' '\012' \
| sed s/^#//g \
| grep "^$searchstring" \
| sed s$d"$searchstring"$d${d}g \
`

echo $species

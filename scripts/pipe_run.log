#! /bin/csh -f
if ($?LAST10) then
  set FILE=run.log.last10
else
  if (-s run.log.gz) then
    set FILE=run.log.gz
  else
    set FILE=run.log
  endif
endif
if (-X zcat) then
  set ZCAT="zcat --force"
else
  set ZCAT="gzip --decompress --force --stdout"
endif
if (`$ZCAT $FILE | sed -e '1,/Start tallies by region/d' -e '/End tallies by region/,$d' | grep -c ^+` == "0") then
  $ZCAT $FILE
else
  $ZCAT $FILE | awk 'NR==1{line=$0}/^[^+]/&&NR>1{print line;line=$0}/^[+]/&&NR>1{line=line $0}'
endif

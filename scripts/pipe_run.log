#! /bin/csh -f
if ($?LAST10) then
  set FILE=run.log.last10
else
  set FILE=run.log
endif
if (-X zcat) then
    set ZCAT=zcat
else
    set ZCAT="gzip --decompress --force --stdout"
endif
if (`$ZCAT -f $FILE | sed -e '1,/Start tallies by region/d' -e '/End tallies by region/,$d' | grep -c ^+` == "0") then
  $ZCAT -f $FILE
else
  $ZCAT -f $FILE | awk 'NR==1{line=$0}/^[^+]/&&NR>1{print line;line=$0}/^[+]/&&NR>1{line=line $0}'
endif

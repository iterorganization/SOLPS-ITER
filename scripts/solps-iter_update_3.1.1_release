#! /usr/bin/env tcsh

cd $SOLPSTOP
echo "Switching to SOLPS-ITER rc/3.1.1 branch"
set repo="SOLPS-ITER"
git fetch --prune
git checkout release/3.1.1 && echo "Checked out SOLPS-ITER 3.1.1 release branch" || goto branch
git pull && goto b25 || goto local

b25:
  git submodule update
  echo "Updating B2.5"
  cd $SOLPSTOP/modules/B2.5
  set repo="B2.5"
  git fetch --prune
  git checkout release/3.1.1 && echo "Checked out B2.5 3.1.1 release branch" || goto branch
  git pull && goto Eirene || goto local

Eirene:
  echo "Updating Eirene"
  cd $SOLPSTOP/modules/Eirene
  set repo="Eirene"
  git fetch --prune
  git checkout rc/3.1.1 && echo "Checked out Eirene 3.1.1 release candidate branch" || goto branch
  git pull && goto Carre || goto local

Carre:
  echo "Updating Carre"
  cd $SOLPSTOP/modules/Carre
  set repo="Carre"
  git fetch --prune
  git checkout develop && echo "Checked out Carre develop branch" || goto branch
  git pull && goto DivGeo || goto local

DivGeo:
  echo "Updating DivGeo"
  cd $SOLPSTOP/modules/DivGeo
  set repo="DivGeo"
  git fetch --prune
  git checkout release/3.1.1 && echo "Checked out DivGeo 3.1.1 release branch" || goto branch
  git pull && goto ADAS || goto local

ADAS:
  echo "Updating ADAS"
  cd $SOLPSTOP/modules/adas
  set repo="ADAS"
  git fetch --prune
  git checkout develop && echo "Checked out ADAS develop branch" || goto branch
  git pull && goto compile || goto local

branch:
  echo "You are not on the 3.1.1 release candidate branch."

local:
  echo "In your "$repo" copy:"
  echo "You have local files under version control which"
  echo "would cause a conflict during the update."
  echo "Please modify, delete, rename, stash these files or"
  echo "commit them to a local branch before proceeding with the update."
  git status
  exit

compile:
  cd $SOLPSTOP
  rehash
  ${MAKE} VERSION
  ${MAKE} listobj listobj_debug
  ${MAKE} depend depend_debug
  ${MAKE} tags
  ${MAKE} solps MAKE_OPTIONS=-j8


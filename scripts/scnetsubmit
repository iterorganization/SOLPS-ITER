#! /usr/bin/env tcsh

set NAME=/tmp/.run.$$.$USER.`date +%Y%m%d%H%M%S`
set EMAIL=`get_git_email`
set JOB_NAME="SOLPS-ITER"
set PROCS=64
set NODES=1
set THREADS=1
set hours=72
set mem=64
set chain="unset"
set part="tyhcnormal"
set job_count=0
echo Your email is $EMAIL

set compress_arg=""
set compress_suffix=""
set MPIOPTS=""
set standalone_arg=""
set coupled_suffix="_coupled"
set LOOP_OPTS=""
set OPTOPTS=""
setenv SOLPS_OPT ""
set exclusive=""
set DO_MONITOR=0
set STEP=4

setenv SOLPSTOP "`determine_SOLPSTOP`"
if ($SOLPSTOP == "") then
  setenv SOLPSTOP "`echo $PWD | sed 's:/runs/.*::'`"
endif

argloop:
  if ("X${1}X" == "X-hX") then
    cat <<EOF

Help for $0

This script is used to submit SOLPS-ITER jobs to the SLURM batch system on the Chinese SCNET system.

Usage:

  `basename $0` {options} {<<SCRIPT>>}

where the optional <<SCRIPT>> is the SLURM submission file to be used

Available options are:
  -j <<JOB NAME>>          set the job name (default $JOB_NAME)
  -z                       compress run.log using gzip
  -x                       requests an exclusive job allocation
  -s                       specify a standalone B2.5 run
  -tgt                     specify a standalone B2.5 run with tangent AD derivatives
  -adj                     specify a standalone B2.5 run with adjoint AD derivatives
  -opt_tgt <<OPT_OPTIONS>> specify a standalone B2.5 optimization run with tangent AD derivatives
  -opt_adj <<OPT_OPTIONS>> specify a standalone B2.5 optimization run with adjoint AD derivatives
  -c <<JOB_ID>>            job ID of the previous job in a chain submission
  -m <<MPI OPTIONS>>       use the MPI options specified (default serial version)
  -t <<THREADS>>           use OpenMP parallelization with <<THREADS>> threads (default $THREADS)
  -T <<HOURS>>             number of elapsed hours requested (default $hours)
  -M <<MEM_SIZE>>          memory size per CPU in MB (default $mem)
  -N <<NODES>>             number of nodes requested (default $NODES)
  -Q <<PARTITION>>         partition on which to submit the job (default "sirius")
  -p <<STEP>>              activates making the output in Lisa Kaveeva style "on the fly" from plasmastates with a provided step (default $STEP)  - to be added

EOF
    exit
  endif
  if ("X${1}X" == "X-jX") then
    shift
    set JOB_NAME="$1"
    echo Job name is ${JOB_NAME}
    shift
    set HELP_STRING=\"${JOB_NAME}\"
#    echo $HELP_STRING
    set LOOP_OPTS="-j ${HELP_STRING} ${LOOP_OPTS}"
    goto argloop
  endif
  if ("X${1}X" == "X-zX") then
    set compress_arg="| gzip -9"
    set compress_suffix=".gz"
    echo run.log will be compressed
    shift
    set LOOP_OPTS="-z ${LOOP_OPTS}"
    goto argloop
  endif
  if ("X${1}X" == "X-sX") then
    set standalone_arg="-s"
    set coupled_suffix=""
    if ($JOB_NAME == "SOLPS-ITER") set JOB_NAME="B2.5"
    echo Asking for a B2.5 standalone run
    shift
    set LOOP_OPTS="-s ${LOOP_OPTS}"
    goto argloop
  endif
  if ("X${1}X" == "X-opt_tgtX") then
    shift
    set standalone="yes"
    setenv SOLPS_OPT "opt_"
    if (! $?SOLPS_TGT) then
      source $SOLPSTOP/SETUP/tgt
    endif
    set OPTOPTS="$1"
    if (! $?OPT) then
      echo No optimization library specified, reverting to PETSc/TAO
      source $SOLPSTOP/SETUP/tao "${OPTOPTS}"
    endif
    if ($JOB_NAME == "SOLPS-ITER") set JOB_NAME="B2.5_OPT_TGT"
    echo Asking for a B2.5 standalone optimization with tangent AD
    shift
    set HELP_STRING="${OPTOPTS}"
    set LOOP_OPTS="-opt_tgt '${OPTOPTS}' ${LOOP_OPTS}"
    goto argloop
  endif
  if ("X${1}X" == "X-opt_adjX") then
    shift
    set standalone="yes"
    setenv SOLPS_OPT "opt_"
    if (! $?SOLPS_TGT) then
      source $SOLPSTOP/SETUP/adj
    endif
    set OPTOPTS="$1"
    if (! $?OPT) then
      echo No optimization library specified, reverting to PETSc/TAO
      source $SOLPSTOP/SETUP/tao "${OPTOPTS}"
    endif
    if ($JOB_NAME == "SOLPS-ITER") set JOB_NAME="B2.5_OPT_ADJ"
    echo Asking for a B2.5 standalone optimization with adjoint AD
    shift
    set HELP_STRING="${OPTOPTS}"
    set LOOP_OPTS="-opt_adj '${OPTOPTS}' ${LOOP_OPTS}"
    goto argloop
  endif
  if ("X${1}X" == "X-tgtX") then
    set standalone="yes"
    if (! $?SOLPS_TGT) then
      source $SOLPSTOP/SETUP/tgt
    endif
    if ($JOB_NAME == "SOLPS-ITER") set JOB_NAME="B2.5_TGT"
    echo Asking for a B2.5 standalone run with tangent AD
    shift
    set LOOP_OPTS="-tgt ${LOOP_OPTS}"
    goto argloop
  endif
  if ("X${1}X" == "X-adjX") then
    set standalone="yes"
    if (! $?SOLPS_ADJ) then
      source $SOLPSTOP/SETUP/adj
    endif
    if ($JOB_NAME == "SOLPS-ITER") set JOB_NAME="B2.5_ADJ"
    echo Asking for a B2.5 standalone run with adjoint AD
    shift
    set LOOP_OPTS="-adj ${LOOP_OPTS}"
    goto argloop
  endif
  if ("X${1}X" == "X-mX") then
    shift
    if (! $?SOLPS_MPI) then
      source $SOLPSTOP/SETUP/mpi
      set MPI_SET=yes
    endif
    set MPIOPTS="$1"
    echo Using MPI options: $MPIOPTS
    set PROCS=`echo $MPIOPTS | awk.transpose | grep -A 1 "\-np" | tail -n 1`
    set PROCS_ACTUAL=$PROCS
    set PROCS_ACTUAL=`echo $MPIOPTS | awk.transpose | grep -A 1 "\-na" | tail -n 1`
    echo Asking for MPI run with a total of $PROCS processors
    echo PROCS_ACTUAL= $PROCS_ACTUAL
    if ( $PROCS_ACTUAL == "" ) then
      @ PROCS_ACTUAL = $PROCS + 1
    endif
    shift
    set HELP_STRING=`echo \"$MPIOPTS\"`
#    echo $HELP_STRING
    set LOOP_OPTS="-m ${HELP_STRING} ${LOOP_OPTS}"
    goto argloop
  endif
  if ("X$1X" == "X-tX") then
    shift
    if (! $?SOLPS_OPENMP) then
      source $SOLPSTOP/SETUP/openmp
      set OPENMP_SET=yes
    endif
    set THREADS="$1"
    echo Asking for OpenMP run with $THREADS threads
    shift
    set HELP_STRING=\"${THREADS}\"
#    echo $HELP_STRING
    set LOOP_OPTS="-t ${HELP_STRING} ${LOOP_OPTS}"
    goto argloop
  endif
  if ("X${1}X" == "X-NX") then
    shift
    set NODES="$1"
    echo Asking for run over $NODES nodes
    shift
    set HELP_STRING=\"${NODES}\"
#    echo $HELP_STRING
    set LOOP_OPTS="-N ${HELP_STRING} ${LOOP_OPTS}"
    goto argloop
  endif
  if ("X${1}X" == "X-TX") then
    shift
    set hours="$1"
    if ( $hours == 1) then
      echo Requested time is ${hours} hour
    else
      echo Requested time is ${hours} hours
    endif
    shift
    set HELP_STRING=\"${hours}\"
#    echo $HELP_STRING
    set LOOP_OPTS="-T ${HELP_STRING} ${LOOP_OPTS}"
    goto argloop
  endif
  if ("X${1}X" == "X-MX") then
    shift
    set mem="$1"
    echo Requested memory per node is ${mem}
    shift
    set HELP_STRING=\"${mem}\"
#    echo $HELP_STRING
    set LOOP_OPTS="-M ${HELP_STRING} ${LOOP_OPTS}"
    goto argloop
  endif
  if ("X${1}X" == "X-QX") then
    shift
    set part="$1"
    echo Requested partition is ${part}
    shift
    set HELP_STRING="${part}"
#    echo $HELP_STRING
    set LOOP_OPTS="-Q ${HELP_STRING} ${LOOP_OPTS}"
    goto argloop
  endif
  if ("X${1}X" == "X-cX") then
    shift
    set chain="$1"
    echo Chain submission following job number ${chain}
    shift
    goto argloop
  endif
  if ("X${1}X" == "X-xX") then
    shift
    set exclusive="--exclusive"
    echo Requesting an exclusive job allocation
    goto argloop
  endif
  if ("X${1}X" == "X-pX") then
    shift
    set STEP="$1"
    echo Interval between recorded plasmastates is ${STEP}
    echo However, option -p is not yet active
    set DO_MONITOR=1
    shift
    goto argloop
  endif

set nodename=`hostname`
set job_prefix="SBATCH"

if ($1 == "") then
  echo No argument is specified. Looking for $job_prefix.scnet
  set QSUB=`climb_and_look_for $job_prefix.scnet`
  if ($QSUB == "//$job_prefix.scnet") then
    if (-s $SOLPSTOP/runs/$job_prefix.scnet) then
      set QSUB="$SOLPSTOP/runs/$job_prefix.scnet"
    else
      set QSUB=""
    endif
  endif
else if (-s $1) then
  echo Submission file $1 is specified as an argument.
  echo Submission file $1 is found in current directory
  set QSUB=$1
else
  echo Submission file $1 is specified as an argument.
  echo Looking for submission file $1
  set QSUB=`climb_and_look_for $1`
  if ($QSUB == "//"$1) then
    if (-s $SOLPSTOP/runs/$1) then
      set QSUB="$SOLPSTOP/runs/$1"
      echo Submission file $QSUB is found
    else
      set QSUB=""
    endif
  else
    echo Submission file $QSUB is found
  endif
endif
if($QSUB == "") then
  echo No SCNET submission file $1 found. Exiting.
  exit 1
endif

echo Using submission file template $QSUB
if ($chain == "unset") then
  echo For loop resubmission following options will be used: $LOOP_OPTS
endif

@ TASKS = $PROCS / $NODES

echo $TASKS tasks per node is set to SLURM

@ MEM_TOT = $mem * $NODES
@ MEM_TOT = $mem

sed \
  -e 's:#PWD#:'$PWD':g' \
  -e 's:#SOLPSTOP#:'$SOLPSTOP':g' \
  -e 's:#EMAIL#:'$EMAIL':g' \
  -e "s:#MPIOPTS#:'$MPIOPTS':g" \
  -e 's:#NODES#:'$NODES':g' \
  -e "s:#TASKS#:'$TASKS':g" \
  -e 's:#PROCS#:'$PROCS':g' \
  -e 's:#PROCS_ACTUAL#:'$PROCS_ACTUAL':g' \
  -e 's:#THREADS#:'$THREADS':g' \
  -e 's:#MEM#:'${mem}G':g' \
  -e 's:#MEM_TOTAL#:'${MEM_TOT}G':g' \
  -e 's:#HOURS#:'$hours':g' \
  -e 's:#PART#:'$part':g' \
  -e 's:#JOBNAME#:'$JOB_NAME':g' \
  -e 's:#USER#:'$USER':g' \
  -e 's:#LOOPOPTS#:'"$LOOP_OPTS"':g' \
  -e 's:#COMPRESS_ARG#:'"$compress_arg"':g' \
  -e 's:#COMPRESS_SUFFIX#:'"$compress_suffix"':g' \
  -e 's:#STANDALONE_ARG#:'"$standalone_arg"':g' \
  -e 's:#COUPLED_SUFFIX#:'"$coupled_suffix"':g' \
  -e 's:#STEP#:'"$STEP"':g' \
  -e 's:#DO_MONITOR#:'"$DO_MONITOR"':g' \
  < $QSUB > $NAME

echo $PROCS
# echo $PROCS_REQ
if ($chain != "unset") then
  set b2run_line=`grep -n "b2run" $NAME | cut -d ':' -f 1`
  @ before_line = $b2run_line - 1
  head -n ${before_line} $NAME > SBATCH.scnet.after_$chain
  echo "mv run.log.gz run.log.$chain.gz" >> SBATCH.scnet.after_$chain
  echo "mv b2mn.prt b2mn.prt.$chain" >> SBATCH.scnet.after_$chain
  echo "mv b2fstate b2fstati" >> SBATCH.spbstu.scnet_$chain
  echo "if (-e b2favere) mv b2favere b2faveri" >> SBATCH.scnet.after_$chain
  set all_lines=`cat $NAME | wc -l`
  @ tail_lines = $all_lines - $before_line
  tail -n $tail_lines $NAME >> SBATCH.scnet.after_$chain
  set NAME=SBATCH.scnet.after_$chain
endif

update_solps_run_status -n "Submitted at `date`"

echo sbatch $NAME
echo $NAME
if ($chain == "unset") then
  sbatch ${exclusive} $NAME
else
  sbatch ${exclusive} --dependency=afterok:${chain} $NAME
endif
rm -f $NAME


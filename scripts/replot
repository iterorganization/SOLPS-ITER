#! /bin/csh -f
start:
if("$1" == "-l") then
  mv gnuplot.data gnuplot.data.$$
  tail -$2 gnuplot.data.$$ > gnuplot.data
  rm gnuplot.data.$$
  shift ; shift ; goto start
endif
if("$1" == "-m") then
  mv gnuplot.data gnuplot.data.$$
  awk 'NR%'$2'=='$3'{print $0}' gnuplot.data.$$ > gnuplot.data
  rm gnuplot.data.$$
  shift ; shift ; shift ; goto start
endif
gnuplot gnuplot.cmd

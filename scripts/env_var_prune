#! /usr/bin/env python

# This script (provided by David Coster) tries to prune environment variable X
# Usage:
#  setenv X `env_var_prune X`

import os
import sys
if len(sys.argv) <= 1:
   VAR="PATH"
else:
   VAR=sys.argv[1]

path = os.environ[VAR].split(':')
print(':'.join(sorted(set(path), key=path.index)))


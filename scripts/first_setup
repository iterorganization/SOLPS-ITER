#! /usr/bin/env ksh
OLD_PWD=$PWD
filename=setup.csh.${HOST_NAME}.${COMPILER}
echo Looking if ${filename} file is present...
cd $SOLPSTOP/SETUP
[ -s ${filename} ] && {
  echo "Non-empty ${filename} already present in $PWD: nothing done"
} || {
  cp setup.csh.default.default ${filename}
  echo "Created ${filename} from setup.csh.default.default in $PWD: please modify if needed"
}
filename=config.${HOST_NAME}.${COMPILER}
echo Looking for ${filename} files...
[ -s ${filename} ] && {
  echo "Non-empty ${filename} already present in $PWD: nothing done"
} || {
  cp config.default.default ${filename}
  echo "Created ${filename} from config.default.default in $PWD: please modify if needed"
}
cd $SOLPSTOP/modules/B2.5/config
[ -s ${filename} ] && {
  echo "Non-empty ${filename} already present in $PWD: nothing done"
} || {
  [ -s config.default.$COMPILER ] && {
    cp config.default.$COMPILER ${filename}
    echo "Created ${filename} from config.default.$COMPILER in $PWD: please modify if needed"
  } || {
    cp config.default.default ${filename}
    echo "Created ${filename} from config.default.default in $PWD: please modify if needed"
  }
}
cd $SOLPSTOP/modules/Eirene/config
[ -s ${filename} ] && {
  echo "Non-empty ${filename} already present in $PWD: nothing done"
} || {
  [ -s config.default.$COMPILER ] && {
    cp config.default.$COMPILER ${filename}
    echo "Created ${filename} from config.default.$COMPILER in $PWD: please modify if needed"
  } || {
    echo "No config.default.$COMPILER file available in $PWD: nothing done"
  }
}

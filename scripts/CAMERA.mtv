#! /bin/csh -f
set NX=$1
set NY=$2
@ XMIN = - $NX / 2
@ XMAX = $NX / 2
@ YMIN = - $NY / 2
@ YMAX = $NY / 2
@ NX += 1
@ NY += 1
echo "$ DATA=CONTOUR" 
echo '% toplabel = "'$3'"'
echo '% xlabel = ""'
echo '% ylabel = ""'
echo '% zlabel = "photons/m^2"'
echo "% nx=$NX ny=$NY xmin=$XMIN xmax=$XMAX ymin=$YMIN ymax=$YMAX contfill=T nsteps=10 logsteps=5"
echo "% cmin=1e16 cmax=1e24"
sed '1d' b2plot.write | awk '{print $2}'
echo "$ END"

# Set up SOLPS-ITER environment
. $(dirname $0)/SOLPS-ITER_CI_GNU_env

# Compile the code
echo "FCOPTS += -mcmodel=large" >> ${SOLPSTOP}/modules/B2.5/config/config.ITER.gfortran.local
echo "LDOPTS += -mcmodel=large" >> ${SOLPSTOP}/modules/B2.5/config/config.ITER.gfortran.local
export NO_MANUAL="true"
make listobj_nox depend_nox
make divgeo_nox
make MAKE_OPTIONS=-j8 solps_nox b25_nox b25_adj b25_tgt b25_hess_tgt b25_tgt_debug b25_adj_debug b25_hess_tgt_debug

# Run test case sensitivity for tangent, adjoint and hessian

cd ${SOLPSTOP}/runs/examples
make COMPASS_sensitivity_D+T
cd COMPASS_sensitivity_D+T
export DEVICE=compass
correct_baserun_timestamps

mkdir run_test
cd run_test
setup_baserun_B25_links
cp ../run_AD_CI/b2.*.parameters .
cp ../run_AD_CI/b2mn.dat .
cp ../run_AD_CI/b2fstati .
cp ../run_AD_CI/cf2.dat .
echo "'b2mndr_ntim' '10'" >> b2mn.dat

. ${SOLPSTOP}/SETUP/debug.ksh
b2run -tgt b2mn | tee run.log
grep -i 'Cost function gradient 1' run.log | awk '{print $5}' | tail -n 10 > tgt_sens_10iter_test.dat
${SOLPSTOP}/modules/B2.5/src/test/sensitivity_checks.sh ../tgt_sens_10iter.dat ./tgt_sens_10iter_test.dat 10 1.0e-12 || exit 1

rm b2mn.prt run.log; b2run -adj b2mn | tee run.log
grep -i 'Cost function gradient' run.log | awk '{print $5}' | tail -n 10 > adj_sens_10iter_test.dat
${SOLPSTOP}/modules/B2.5/src/test/sensitivity_checks.sh ../adj_sens_10iter.dat ./adj_sens_10iter_test.dat 10 1.0e-12 || exit 2

rm b2mn.prt run.log; b2run -hess_tgt b2mn | tee run.log
grep -i 'Cost function hessian 1' run.log | awk '{print $5}' | tail -n 100 > hess_sens_10iter_test.dat
../crop_data.py hess_sens_10iter_test.dat
${SOLPSTOP}/modules/B2.5/src/test/sensitivity_checks.sh ../hess_sens_10iter.dat ./hess_sens_10iter_test.dat 55 1.0e-12 || exit 3

# Run test case optimization
cd ${SOLPSTOP}
. $SOLPSTOP/SETUP/tao.ksh
rm ${SOLPSTOP}/modules/B2.5/builds/*/b2optim_tao*.*
make MAKE_OPTIONS=-j8 b25_tgt b25_adj

cd ${SOLPSTOP}/runs/examples/COMPASS_sensitivity_D+T
mkdir opt_test
cd opt_test
setup_baserun_B25_links
cp ../opt_CI/b2.*.parameters .
cp ../opt_CI/b2mn.dat .
cp ../opt_CI/b2fstati .
cp ../opt_CI/cf2.dat .

b2run -opt_tgt b2mn | tee run.log
result_tao.sh
tail -n 1 ../opt_CI/parm_hist1.dat > optim.dat
tail -n 1 ../opt_CI/parm_hist2.dat >> optim.dat
tail -n 1 parm_hist1.dat > optim_test.dat
tail -n 1 parm_hist2.dat >> optim_test.dat
${SOLPSTOP}/modules/B2.5/src/test/sensitivity_checks.sh ./optim.dat ./optim_test.dat 2 1.0e-3 || exit 4

rm b2mn.prt run.log run.info parm* optim_test.dat; b2run -opt_adj b2mn | tee run.log
result_tao.sh
tail -n 1 parm_hist1.dat > optim_test.dat
tail -n 1 parm_hist2.dat >> optim_test.dat
${SOLPSTOP}/modules/B2.5/src/test/sensitivity_checks.sh ./optim.dat ./optim_test.dat 2 1.0e-3 || exit 5


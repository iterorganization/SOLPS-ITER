# Set up SOLPS-ITER environment
. $(dirname $0)/SOLPS-ITER_CI_GNU_env

# Compile the code
echo "CXXFLAGS += -mcmodel=large" > ${SOLPSTOP}/SETUP/config.ITER.gfortran.local

#! /bin/ksh

# syntax for call: hlp_res detail, where detail is anything.
# plots all species and given iterations if RES exists
# all species and 40 iterations if detail has a value
# all species and 40 iterations otherwise
# Version 970627

# do the following only if run free-standing, i.e. not from trc

name=`basename $0`

case "$OBJECTCODE" in
    IBMaix  )   ;;
    *       )   echo "$name: Improper platform $OBJECTCODE"; exit 4;;
esac

view=
keep=
freestanding=
[ -z "$GNUPLOT_BATCH" ] && freestanding=yes
if [ -n "$freestanding" ]; then 
   export GNUPLOT_BATCH=yes
   export GNUPLOT_DELAY=0
# clean up the directory
   rm -f GNUPLOT_COUNT gnuplot.cmd $name.ps gnuplot.[1-9]*.data >/dev/null 2>&1
   echo 0 > GNUPLOT_COUNT
   echo set term postscript landscape color > gnuplot.cmd
   echo set output \'$name.ps\' >> gnuplot.cmd
fi


detail=$1

filename=tracing/residuals.trc
[ ! -r "$filename" ] && { echo "$name: filename=$filename does not exist!!!" >&2; exit 33; }


#assume RES contains a number followed by desired number of iterations for species-dependent
#quantities
#first number was previously number of species: no longer used but still there
# if RES is not there plot all species
it=40
ispecies=all
[ -r RES ] && { it=`cat RES | awk '{print $2}'`; ispecies=all; }


specieslist=`hlp_species $filename resco01_`
if [ -z "$ispecies" ]; then
  echo "ispecies=$ispecies"
  if [ -z "$detail" ]; then
    specieslist=`echo $specieslist | awk '{ print $1 }'`
  fi
fi

# copy files to local directory tempdir and shorten them to iterations, 
# output files: in $tempdir/$header headerfile, 1 column per line
# in $tempdir/$data, all data for $iterations,  1 line per timestep

dir=`hlp_src_cp $it $filename`

[ $? -gt 0 ] && { echo "$name: file copy to local directory did not work" >&2; exit 33; }

header=$dir/header
data=$dir/data

equationlist="resco resmo"
regionlist="01 02 03 04"
for e in $equationlist; do
  for r in $regionlist; do
    arglist=
    for f in $specieslist; do
      arglist="$arglist ${e}${r}_${f}"
     done
     hlp_src ${e}${r} log $header $data 0 $arglist
  done
done

hlp_src resee log $header $data 0 resee01 resee02 resee03 resee04
hlp_src resei log $header $data 0 resei01 resei02 resei03 resei04

if [ -n "$freestanding" ]; then 
#  Replace the labels

[ -r VarID ] && { [ -n "$verb" ] && echo "%%%% editing gnuplot.cmd ..."
    v=`cat VarID | tr _/ '  '`; echo "1,\$g/^set title/s/\".*\"/\"$v\"/
w
q" | ed -s gnuplot.cmd > /dev/null; }

gnuplot gnuplot.cmd
  [ -z "$keep" ] && rm GNUPLOT_COUNT gnuplot.*data

  if [ -z "$view" ] ; then
    ghostview $GV_OPT $name.ps &
    setnice 0 $!
  fi

fi

rm -rf plots_$name >/dev/null 2>&1
mv $dir/plots plots_$name
rm -rf $dir >/dev/null 2>&1


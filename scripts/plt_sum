#ACT='V1-C FEAT-V1W FEAT FEAT-Sp DUMP FEAT-Ne FEAT-noC'
#ACT='F12 F-el F-var F-dome F-ss'
#ACT='F-el F-el-Sp F-el-pwr F-var'
#ACT='F-wll F-xpt F-el F-el-Sp F-el-pwr'
#ACT='F-el-Qi F-wll F-xpt F-el F-el-pwr'
#ACT='F-el-Qi F-wll F-xpt F-el'
#ACT='F-el-Qi F-wll F-xpt F-el F-var-el'
#ACT='F-el-Qi F-xpt F-var-el'
#ACT='F-xpt F-C F-var-el F-el-Qi'
#ACT='F-xpt F-C-100MW F-C F-var-el F-el-Qi'
#ACT='F-xpt F-C-100MW F-C F-var-el'
#ACT='F-var-C F-C-100MW F-C F-xpt F-var-el'
#ACT='F-var-C F-C-100MW F-C F-var-el'
#ACT='F-var-Y F-var-C F-var-el'
#ACT='F-var-Y F-var-C F-SS-C'
#ACT='F-var-Y F-C1-100 F-var-C F-SS-C'
#ACT='F-C1-dome F-var-Y F-C1-100 F-var-C F-SS-C'
#ACT='F-C0-ntrl F-C1-dome F-var-Y F-C1-100 F-var-C F-SS-C'
#ACT='F-C0-ntrl F-var-Y F-C1-100 F-var-C F-SS-C'
#ACT='F-C0-ntrl F-var-Y F-var-C F-SS-C'
#ACT='F-C0-ntrl F-var-Y F-SS-C'
#ACT='F-C0-ntrl F-var-Y F-SS-C F-C1-100'
#ACT='F-C0-ntrl F-var-Y F-SS-C'
#ACT='F-C0-ntrl F-var-Y'
#ACT='F-NN-dome F-C0-ntrl'
#ACT='AUG-2 AUG-1 F-NN-dome F-C0-ntrl'
ACT='AUG-2 AUG-1 F-NN-pwr F-NN-dome'

pneu_def=20
qpk_map_margin=-3

set -A Series_list  --  F-NN-pwr    AUG-2           AUG-1           F-NN-dome   F-C0-ntrl   TT          F-var-Y     F-SS-C      F-var-C     F-C1-dome   F-C1-100    F-var-el    F-C-100MW   F-C         F-xpt        F-el-Qi      F-wll       F-el        F-var       F-el-pwr    F-el-Sp     F12         F-dome      F-ss        V1-100        V1-86       FEAT-V1W    FEAT        FEAT-Sp     DUMP        FEAT-Ne     FEAT-noC          VT            FLAT        IAM-q       IAM-n
set -A SELECTION    --  'F-NN-pwr'  'AUG-2'         'AUG-1'         'F-NN-dome' 'F-C0-ntrl' 'TT'        'F-var-Y'   'F-SS-C'    'F-var-C'   'F-C1-dome' 'F-C1-100'  'F-var-el'  'F-C-100MW' 'F-C'       'F-xpt'      'F-el-Qi'    'F-wll'     'F-el'      'F-var'     'F-el-pwr'  'F-el-Sp'   'F12'       'Fdm'       'F12ss C'   'V1-C 100MW'  'V1-C 86MW' 'V1 Wdome'  'FEAT Sp75' 'FEAT Sp'   'dumptrg'   'FEAT Ne'   'FEAT no_C'       'RTO/RC D VT' 'c_shape'   'IAM q_var' 'IAM low_n'
set -A nsrange      --  '0.22:0.32' '0.05:0.35'     '0.05:0.42'     '0.22:0.32' '0.22:0.34' '0.21:0.47' '0.20:0.50' '0.18:0.35' '0.16:0.47' '0.16:0.35' '0.22:0.36' '0.20:0.45' '0.23:0.36' '0.22:0.40' '0.12:0.58'  '0.28:0.60'  '0.20:0.77' '0.26:0.63' '0.20:0.48' '0.25:0.60' '0.25:0.45' '0.25:0.50' '0.20:0.48' '0.25:0.43' '0.26:0.42'   '0.25:0.37' '0.25:0.37' '0.25:0.37' '0.25:0.37' '0.25:0.37' '0.25:0.37' '0.26:0.39'       '0.24:0.48'   '0.24:0.48' '0.25:0.38' '0.25:0.38'
set -A trange       --  '0:500'     '10:100'        '10:100'        '0:500'     '40:500'    '50:350'    '40:350'    '40:220'    '20:370'    '20:280'    '40:300'    '40:250'    '40:200'    '40:250'    '20:250'     '60:300'     '50:250'    '50:320'    '50:350'    '50:360'    '50:350'    '50:300'    '50:300'    '50:250'    '60:300'      '60:300'    '60:300'    '60:300'    '60:300'    '60:300'    '60:300'    '100:300'         '50:400'      '50:400'    '60:200'    '60:200'
set -A prange       --  '0:25'      '1.0:5.0'       '0.8:7.2'       '0:25'      '3:24'      '3:20'      '2:23'      '2:23'      '2:23'      '2:15'      '3:16'      '2:20'      '3:11'      '3:16'      '0:17'
set -A cfrange      --  '0:100'     '0:9'           '0:2.5'         '0:100'     '0:100'     '0:50'      '0:240'     '0:30'      '0:240'     '0:240'     '0:240'      '0:30'     '0:200'     '0:30'      '0:30'       '10:300'     '0:30'      '0:300'     '0:200'     '0:30'      '0:30'      '0:30'      '0:30'      '0:30'      ':'           ':'         ':'         ':'         ':'         ':'         ':'         ':'               ':'           ':'         ':'         ':'
set -A mapZrange    --  '3:14'      '0:12'          '0:20'          '3:14'      '1.5:14'    '2:14'      '2:14'      '1:10'      '2:16'      '2:10'      '2:10'      '2:16'      '2:10'      '2:20'      '1:16'       '2:16'       '2:16'      '2:16'      '2:16'      '2:16'      '2:16'      '2:16'      '2:16'      '2:16'      '2:16'       '2:16'      '2:16'      '2:16'      '2:16'      '2:16'      '2:16'      '2:16'            '2:16'        '2:16'      '2:16'      '2:16'
set -A maplegend    --  -i          -i              -i              -i          -i          -i          -is         -i          -is         -i          -i          -is         -i          -i          -is          -i           -is         -i          -is         -i          -i          -i          -i          -i          -i            -i          -i          -is         -is         -is         -is         -is               -i            -i          -i          -i
set -A NO_HE        --  ''          '-nohe'         '-nohe'         ''          ''          ''          ''          ''          ''          ''          ''          ''          ''          ''          ''           ''           ''          ''          ''          ''          ''          ''          ''          ''          ''            ''          ''          ''          ''          ''          ''          ''                ''            ''          ''          ''
set -A layoutfile   --  layout.sum  layout.sum.aug1 layout.sum.aug1 layout.sum  layout.sum  layout.sum  layout.sum  layout.sum  layout.sum  layout.sum  layout.sum  layout.sum  layout.sum  layout.sum  layout.sum   layout.sum   layout.sum  layout.sum  layout.sum  layout.sum  layout.sum  layout.sum  layout.sum  layout.sum  layout.sum    layout.sum  layout.sum  layout.sum  layout.sum  layout.sum  layout.sum  layout.sum.Ne_Ar  layout.sum    layout.sum  layout.sum  layout.sum

set -A xrange       -- ${prange[*]}

D=SERIES
A=ACTUAL_SERIES

SCRIPT="$0"
[ "$SCRIPT" = "${SCRIPT#/}" ] && {
  d=`(cd "${SCRIPT%/*}" && pwd)`
  SCRIPT="${d%/}/${SCRIPT##*/}"
}

NAME="${0##*/}"

Usage="$NAME produces standard sets of the summary plots and sends them to the printer. Usage:
$NAME [-n] [-m] [-w] [-t] { <list> | a | ALL }
  -n      to avoid printing
  -p      to print already prepared PS files
  -m      to produce only (ns-Zeff) map with the legend
  -w      to produce only the operational window plots
  -t      to produce only the operational window plots with data spread
  -r      to produce all plots using average +/-rms (box/cross) rather than average only
  <list>  sets to be produced. Should consist of (${Series_list[*]}).
      	  Series name \"CHe\" stands for helium concentration vs. throughput for all the cases.
  a       the actual selection ($ACT) to be done
  ALL     the full list (${Series_list[*]}) to be done."


unset MAP_ONLY NO_PRINT WIN_ONLY TRC_ONLY RMS PRINT_ONLY
until [ -z "$1" ]; do {
  { case $1 in
    ( -h | -\? )  print -- "$Usage"; exit;;
    ( -m )        MAP_ONLY=y;;
    ( -n )        NO_PRINT=-n;;
    ( -p )        NO_PRINT=-o; PRINT_ONLY=y;;
    ( -t )        TRC_ONLY=-ds;;
    ( -r )        RMS=-r;;
    ( -w )        WIN_ONLY=-ow;;
    ( -* )        print -u2 "$NAME: illegal option $1"; exit 4;;
    ( *  )        break;;
  esac; }
  shift
}; done

[ -z "$1" ] && {
  print -- "$Usage" 
  exit
}
for f in $*; do {
  { case "$f" in
    ( a )   LIST="$ACT"; break;;
    ( ALL ) LIST="${Series_list[*]}"; break;;
    ( * )   ;;
  esac; }
  { case " ${Series_list[*]} " in
    ( *\ $f\ * ) ;;
    ( * ) print -u2 "$NAME: wrong series $f - must be one of (${Series_list[*]})"
          exit 4;;
  esac; }
  LIST="$LIST $f"
}; done

#echo "LIST = $LIST"        #!!!

cd $SOLPSTOP/data/Summary_plots/summary

[ -d $D ] || mkdir $D || {
  print -u2 "$NAME: unable to create the directory $D"
  exit 4
}

l=`ls -d ../summary.* | tail -1`
LABEL="${l#../summary.}"
[ "$LABEL" = "$l" ] && LABEL=0
((LABEL=LABEL+1))



for S in $LIST; do {
  print "Series: $S"
  [ -n "$PRINT_ONLY" ] && (
    cd $D/$S  && {
      [ -n "$MAP_ONLY" ] || { [ -z "$WIN_ONLY" ] && [ -z "$TRC_ONLY" ]; } && print_file -Pc series_map.ps series_map_legend_out.ps
      [ -n "$WIN_ONLY" ] || { [ -z "$MAP_ONLY" ] && [ -z "$TRC_ONLY" ]; } && print_file -Pc op_wndw4.ps
      [ -n "$TRC_ONLY" ] || { [ -z "$MAP_ONLY" ] && [ -z "$WIN_ONLY" ]; } && print_file -Pc dt_sprd4.ps
      [ -z "$MAP_ONLY" ] && [ -z "$WIN_ONLY" ] && [ -z "$TRC_ONLY" ] && print_file -Pc sum_pneu4.ps
      true
    } || {
      print -u2 "$NAME: cannot switch to $D/$S"
    }
    true
  ) || {
    [ -d $D/$S ] || mkdir $D/$S || {
      print -u2 "$NAME: unable to create the directory $D/$S"
      exit 4
    }
    i=0; while true; do {
      case $S in
        ( ${Series_list[$i]} ) break;;
        ( * ) ;;
      esac
      let 'i=i+1'
    }; done
#    echo "i = $i" #!!!

#   Map with legend ==================================================================================
    [ -n "$MAP_ONLY" ] || { [ -z "$WIN_ONLY" ] && [ -z "$TRC_ONLY" ]; } && [ -n "${mapZrange[$i]}" ] && {
      set -A y -- `echo "${mapZrange[$i]}" | tr : \ `
      [ -z "${y[1]}" ] && { y[0]=2; y[1]=16; }
      set -A x -- `echo "${xrange[$i]}" | tr : \ `
      [ -z "${x[0]}" ] && x[0]=0
      [ -z "${x[1]}" ] && x[1]=$pneu_def
      [ "${maplegend[$i]}" = -is ] && y0=0 || y0=`echo "${y[*]}" | awk '{ print (1.5*$1-0.5*$2) }'`
      dy=`echo "${y[*]}" | awk '{ print ($2-('"$y0))/20 }"`
      dx=`echo "${x[*]}" | awk '{ print ($2-$1)/12 }'`
      x0=`echo "${x[0]} $dx" | awk '{ print $1+$2*0.4 }'`
      ddy=$dy
      ddx=`echo "${x[*]}" | awk '{ print ($2-$1)/120 }'`
#<  <<
#      echo "y0 : ${y0}"
#      echo "y : ${y[*]}"
#      echo "x : ${x[*]}"
#      echo "dy : ${dy}"
#      echo "dx : ${dx}"
#      echo "x0 : ${x0}"
#      echo "ddy : ${ddy}"
#      echo "ddx : ${ddx}"
#>  >>
#      set -x        #!!!
      PNEU_RANGE="${prange[$i]}"  XLEGEND0_PLOTSUM="$x0" YLEGEND0_PLOTSUM="$y[0]" YLEGEND1_PLOTSUM=${y0} DXLEGEND_PLOTSUM="$dx" \
        DYLEGEND_PLOTSUM="$dy" DDX_PLOTSUM=$ddx DDY_PLOTSUM=$ddy MAPY_RANGE="${y0}:" plotsum -t $S $NO_PRINT $RMS -m ${maplegend[$i]} -s "${SELECTION[$i]}"
#      set +x        #!!!
      sleep 5
#      echo "moving to $D/$S"  #!!!
#      set -x        #!!!
      mv series_map.ps* shot_* *_legend_out.ps $D/$S
#      set +x        #!!!
#      echo "... finished map"  #!!!
    }

#   Operational window ===============================================================================

#    echo "Operational window: i = $i" #!!!
#    echo "Operational window: NO_HE[$i] = ${NO_HE[$i]}" #!!!
    [ -n "$WIN_ONLY" ] || { [ -z "$MAP_ONLY" ] && [ -z "$TRC_ONLY" ]; } && {
#      set -x  #!!!
      ZEFF_RANGE="1:" THRPT_RANGE="${trange[$i]}" NS_RANGE="${nsrange[$i]}" COREFLX_RANGE="${cfrange[$i]}" PNEU_RANGE="${prange[$i]}" \
        plotsum -t $S ${NO_HE[$i]} $NO_PRINT $RMS -ow  -s "${SELECTION[$i]}"
#      set +x  #!!!
      sleep 5
      mv op_wndw*.ps* $D/$S
    }
 
#   Operational window with data spread ==============================================================

    [ -n "$TRC_ONLY" ] || { [ -z "$MAP_ONLY" ] && [ -z "$WIN_ONLY" ]; } && {
      ZEFF_RANGE="1:" THRPT_RANGE="${trange[$i]}" NS_RANGE="${nsrange[$i]}" COREFLX_RANGE="${cfrange[$i]}" PNEU_RANGE="${prange[$i]}"\
        plotsum -t $S ${NO_HE[$i]} $NO_PRINT $RMS -ds  -s "${SELECTION[$i]}"
      sleep 5
      mv dt_sprd*.ps* $D/$S
    }
 
#   General set ======================================================================================
 
    [ -z "$MAP_ONLY" ] && [ -z "$WIN_ONLY" ] && [ -z "$TRC_ONLY" ] && {
      unset u
      { case $S in
        ( CHe ) [ -n "${SELECTION[$i]}" ] && u="-s \'${SELECTION[$i]}\'"
                THRPT_RANGE="${trange[$i]}" plotsum -t $S $NO_PRINT $RMS -he $u
                sleep 5
                mv c_he.ps* $D/$S;;

        ( * )   u="${NO_HE[$i]}"
                [ -n "${layoutfile[$i]}" ] && u="$u -y ${layoutfile[$i]}"
#                NS_RANGE="${nsrange[$i]}" plotsum -t $S $NO_PRINT $RMS $u -s "${SELECTION[$i]}" ns
                PNEU_RANGE="${prange[$i]}" plotsum -t $S $NO_PRINT $RMS $u -s "${SELECTION[$i]}" pneu
                sleep 5
                rm -r *.ps_dir
                mv sum_*.ps* $D/$S
#               [ -z "${NO_HE[$i]}" ] && {
##                set -x                          #!!!
#                  THRPT_RANGE="${trange[$i]}" plotsum -t $S $NO_PRINT $RMS -he $u -s "${SELECTION[$i]}"
##                set +x                          #!!!
#                 sleep 5
#                 mv c_he.ps* $D/$S
#               };;
     esac; }
    }
  }
}; done

#exit #!!!

[ -n "$PRINT_ONLY" ] && exit

# If the directory for actual series exists, copy the produced series there
  
[ -n "$A" ] && [ -d "../$A" ] && {
  dd="../$A.b"
  [ -d "$dd" ] || mkdir -p "$dd" || {
    print -u2 -- "Unable to create $dd - actual series not updated"
    false
  } && {
    sleep 60
    for S in $LIST; do {
      d="../$A/$S"
      [ -a "$d" ] && {
        dd="$dd/$S"
        [ -a "$dd" ] && find $dd -maxdepth 0 -atime +2 -exec rm -r {} \; 
        [ -a "$dd" ] && {
          rm -r "$d"
          true
        } || mv "$d" "$dd"
      }
      [ -a "$d" ] && {
        print -u2 -- "Unable to clear $d - actual series not updated"
        true
      } || {
        echo "copying $S to ACTUAL_SERIES"   #!!!
        cp -a "$D/$S" "$d"
        echo $LABEL > "$d"/\#Version
      }
    }; done
    echo "... done"                   #!!!
  }
}
cp "$SCRIPT" ../filelist.smt ../template.sum $D

#! /bin/ksh

#  VERSION : 21.04.2005 20:00

# Te, Ti, ne, nD+, nD0, and TD0 profiles along the LPS PI chords - A. Polevoi

# Universal script for b2plot.
# Multiple boxes can be specified in box.b2p - if the first line there starts with #

DATE=20050421

PS=$1
NAME=${0##*/}
[ -n "$PS" ] && echo "$NAME: producing PostScript files ..." || echo "$NAME: producing gmeta files ..."

STEM=${NAME}_PS
LK=bpt

[ -n "$PS" ] && {
  [ -d "${STEM}" ] && {
    [ -d "${STEM}.$DATE" ] && {
      rm -rf ${STEM}/* >/dev/null 2>&1; true
    } || {
      mv "${STEM}" "${STEM}.$DATE"; false
    }
  } || mkdir ${STEM}
  [ -d ${STEM}/mono ] || mkdir ${STEM}/mono
  [ -d ${STEM}/color ] || mkdir ${STEM}/color
}

# First, determine the basic variables

unset swbox
[ -s box.${LK} ] && {
  [ -a box.b2p ] && {
    [ -a box.b2p.$$ ] && {
      print -u2 -- "Cannot switch box.b2p: box.b2p.$$ exists"
      exit 4
    }
    mv box.b2p box.b2p.$$
  }
  mv box.${LK} box.b2p && swbox=y
}
. get_parm.bpl
[ -n "$swbox" ] && {
  mv box.b2p box.${LK} && [ -a box.b2p.$$ ] && mv box.b2p.$$ box.b2p
  unset swbox
}

B="'$LL' extl"
BBB="comp"
ST="lbof sep clvl vesl phys 1.2 lbsz"

rm -f gmeta color.${LK} mono.${LK} ${LK}_${L}[cm].ps.legend ${LK}.log b2plot.ps 2>/dev/null
ic=0
im=0
ib=0
echo "$ST $BB" > color.${LK}.h
echo "$ST $BB writ" > mono.${LK}.h

unset ss sf kw
[ -n "${BB[1]}" ] && ss=_b

# Loop over frames specified in box.b2p - or the default one

#for bb in " ${BB[@]}"; do {###}

#for bb in " 4.0 rmin 6.5 rmax -5.0 zmin -2.5 zmax"; do {#}
for bb in " 4.0 rmin 7.5 rmax -5.0 zmin -1.5 zmax"; do {
  print -- "$bb" >> color.${LK}
  print -- "$bb" >> mono.${LK}
  kw=

# Check whether this frame should be plotted in this mode (empty kw means yes)

#  [ -n "$ss" ] && {
#    let 'ib=ib+1'
#    sf="_${SB[$ib]:-${ib}}"
#    kw=${KW[$ib]}
#    [ -n "$kw" ] && {
#      [ -n "$PS" ] && {
#        [ "${kw#P}" = "$kw" ] || kw=
#        true
#      } || [ "${kw#g}" = "$kw" ] || kw=
#    }
#    [ -z "$kw" ] && {
#      print -- "$bb" >> color.${LK}
#      print -- "$bb" >> mono.${LK}
#    }
#  }

  [ -z "$kw" ] && {

# Prepare the 2D plots depending on the frame (samples are below)
 
    let "ic=ic+1"
    echo "$B 'LFS_PI.chr' chpl" >> color.${LK}
    echo "ch_${L}${sf}\t$ic" >> ${LK}_${L}c.ps.legend

    let "ic=ic+1"
    echo "$B
      te 1.0 2.0 3.0 5.0 7.0 10. 20. 30. 50. 70. 100. 200. 300. 13 clvs surf drop" >> color.${LK}
    echo "te_${L}${sf}\t$ic" >> ${LK}_${L}c.ps.legend

    let "ic=ic+1"
    echo "$B
      ti 1.0 2.0 3.0 5.0 7.0 10. 20. 30. 50. 70. 100. 200. 300. 13 clvs surf drop" >> color.${LK}
    echo "ti_${L}${sf}\t$ic" >> ${LK}_${L}c.ps.legend

    let "ic=ic+1"
    echo "$B mach 1 1 sumz
      -1.e8 -2.0 -1.0 -0.99999 -0.99998 0.0 0.99995 0.99996 0.99997 0.99998 0.99999 1.0 2.0 13 clvs surf drop" >> color.${LK}
    echo "mach_${L}${sf}\t$ic" >> ${LK}_${L}c.ps.legend

    i=0; while  [ $i -lt $NS ]; do {
      let "ii=i+1"
      let "ic=ic+1"
      echo "$B up $ii $ii sumz
        -1.e5 -1.e4 -1.e3 -1.e2 -1.e1 0. 10. 100. 1000. 1.e4 1.e5 11 clvs surf" >> color.${LK}
      echo "up_${ii}_${L}${sf}\t$ic" >> ${LK}_${L}c.ps.legend
      i=$ii
    }; done

#    case " ${SPEC[*]} " in
#      ( *' Ar '* )
#          iAr=0; for f in ${SPEC[*]}; do
#            [ $f = Ar ] && break
#            let "iAr=iAr+1"
#          done
#          let "ic=ic+1"
#          echo "$B
#            ni ${SUMZ_1[iAr]} ${SUMZ_1[iAr]} sumz
#            5.e14 1.e15 2.e15 5.e15 1.e16 2.e16 5.e16 1.e17 2.e17 5.e17 1.e18 2.e18 5.e18 13 clvs surf drop" >> color.${LK}
#          echo "nAr1_${L}${sf}\t$ic" >> ${LK}_${L}c.ps.legend;;
#      ( * ) ;;
#    esac

  }
}; done

# Plots invariant with respect to the bounding box (sample is below)

echo "phys $B" >> mono.${LK}
for i in 1 2 3; do {
  let "im=im+1"
  echo "te 'LFS_PI.00$i' chvl drop" >> mono.${LK}
  echo "Te\t$im" >> ${LK}_${L}m.ps.legend
  echo "ti 'LFS_PI.00$i' chvl drop" >> mono.${LK}
  echo "Ti\t$im" >> ${LK}_${L}m.ps.legend
  echo "ne 'LFS_PI.00$i' chvl drop" >> mono.${LK}
  echo "ne\t$im" >> ${LK}_${L}m.ps.legend
  echo "ni 1 1 sumz 'LFS_PI.00$i' chvl drop" >> mono.${LK}
  echo "nD+\t$im" >> ${LK}_${L}m.ps.legend
  echo "dab2 1 1 sumz 'LFS_PI.00$i' chvl drop" >> mono.${LK}
  echo "nD0\t$im" >> ${LK}_${L}m.ps.legend
  echo "tab2 1 1 sumz 'LFS_PI.00$i' chvl drop" >> mono.${LK}
  echo "TD0\t$im" >> ${LK}_${L}m.ps.legend
}; done

# Produce the plots from the prepared control files

S=mono
for C in m c; do {
  [ -s ${S}.${LK} ] && {
    cat ${S}.${LK} >> ${S}.${LK}.h
    mv ${S}.${LK}.h ${S}.${LK}
    b2plot < ${S}.${LK} >> ${LK}.log 2>&1
    [ -n "$PS" ] && {
      [ -s gmeta ] && {
        ctrans -d ps.$S -outfile ${STEM}/${S}/${LK}_${L}${C}.ps gmeta
        mv ${LK}_${L}${C}.ps.legend ${STEM}/${S}
        ln -s $PWD/VarID ${STEM}/${S}
        [ -s b2plot.write ] && mv b2plot.write ${STEM}/${S} && (cd ${STEM}/${S} && parse_b2pw)
        [ $C = c ] && (cd ${STEM}/${S}
          ps_GV ${LK}_${L}${C}.ps && mv ${LK}_${L}${C}_GV.ps ${LK}_${L}${C}.ps && ps_mac ${LK}_${L}${C}.ps
        )
        rm gmeta
      }
    }
    [ -s gmeta ] && mv gmeta gmeta.${LK}.${S}
    true
  } || {
    rm ${S}.${LK}.h 2>/dev/null
  }
  [ -a b2plot.write ] && [ ! -s b2plot.write ] && rm b2plot.write
  S=color
}; done

[ -s gmeta.${LK}.color ] && ln -s gmeta.${LK}.color gmeta

#!/bin/bash
# Module : multips.base
# Date : 8/14/90
# Synopsis : Prints multiple logical postscript pages on a single
# physical page.
# Authors : Neil Skilling and D. Murray Laing
# Update :
#
# PSLIB is set by the Makefile do not edit the next line !!
PSLIB="$SOLPSTOP/lib/ps"
# Set variables to defaults
Landscape=true
Nrows=2
Ncols=2
Left_Right=true
Up_Down=true
Row_Major=true
Dividers=true


usage()
{
echo "$0 [-H] [-p] [-l] [-r num] [-c num] [-j justflags] " >&2;
echo "   [-o orderflag] [-d] [-n] [filename...] " >&2  ;
echo " " >&2 ;
echo "   justflags = ( t or b ) and/or  ( r or l ) " >&2 ;
echo "   orderflag = c or r " >&2 ;
echo "" >&2 ;
}

# Use command getopts to parse the command line
# arguments
while getopts Hplr:c:j:o:dn arg
do
  case $arg in
    H|h) usage ;;
    p) Landscape=false;;
    l) Landscape=true;;
    r) Nrows=$OPTARG;;
    c) Ncols=$OPTARG;;
    j) case $OPTARG in 
	t) Up_Down=true;;
	b) Up_Down=false;;
	r) Left_Right=false;;
	l) Left_Right=true;;
	\?) usage ; exit 2;;
       esac;;
    o) case $OPTARG in
	r) Row_Major=true;;
	c) Row_Major=false;;
        \?) usage ; exit 2;;
       esac;;
    d) Dividers=true;;
    n) Dividers=false;;
    \?) usage
	exit 2;;
  esac
done

# Get the filename(s)
shift `expr $OPTIND - 1`
filename=$*   
if [ "$filename" = "" ]; then 
   # No filename we are in a pipeline
   filename=stdin
else
  # test that we can read all the files
  for file in $filename
  do
    if [ ! -r $file ]; then 
       echo "Cannot open $file for reading" >&2
       exit 2
    fi
  done
fi
# Lets do it.......
# Remember >&1 is the standard output
cat $PSLIB/multi.ps >&1
echo "$Landscape $Nrows $Ncols $Left_Right" >&1
echo " $Up_Down $Row_Major $Dividers multi" >&1
if [ "$filename" = "stdin" ]; then
  # Map standard input to standard output
  cat <&0 | sed -e '/^%[%!]/d' >&1
else
  cat $filename | sed -e '/^%[%!]/d' >&1
fi
echo "endmulti" >&1

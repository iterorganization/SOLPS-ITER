#! /usr/bin/ksh

#  VERSION : 29.08.2003 14:35

#DEFAULT_COLOR_PRINTER=COLOR-NET-T1-234
DEFAULT_COLOR_PRINTER=c
[ ! -s ~/.color_printer ] && COLOR_DEFAULT="$DEFAULT_COLOR_PRINTER" || COLOR_DEFAULT="`cat ~/.color_printer`"
COLOR_PRINTER=${COLOR_PRINTER:=$COLOR_DEFAULT}
NET_SERVER=netfs

NAME=${0##*/}
Usage="Usage: $NAME [ <parameters> ] <filename1> [ [ <parameters> ] <filename2> ... ]
  <parameters> may include the following
    -pxxx or -Pxxx or -p xxx or -P xxx; specify printer xxx, where xxx is a valid printername.
        If this is not specified, default printer is chosen
        Default printer name is read from file 'defaultprinter' in user's home directory
        if this file does not exist, the default printer is ITER-II-1
    -ps or -PS or -postscript or -POSTSCRIPT or -pos* or -POS* or -ep* or -EP*:
       following file printed out as postscript regardless of name
    -a* or -A* or -t* or -T* (ascii or text):
       following file printed out as text regardless of name
       (i.e. can print out postscript instructions)
    -por* or -POR*: specify portrait orientation for text file
       (must use this to generate -p option for a2ps since we use -p to specify printer above)
    -l* or -L*; specify landscape oroentation for text file
    -tum*  or -TUM* (for tumble): specify paper turned 180 degrees for text file
       (must use this to generate -t option for a2ps since we use -t to specify text above)
    -* other than the above are valid options for a2ps (e.g. -1: 1 page rather than 2, etc.)
    * other than the above are filenames
    Filenames and parameters may be interspersed in any order
    Printer name shortcuts are:
        b     NET-T1-234
        bw     NET-T1-234
        B     NET-T1-234
        BW     NET-T1-234
        c     $COLOR_PRINTER
        C     $COLOR_PRINTER
        m     a4mj
        M     a4mj
	n     COLOR-NET-T1-234
	N     COLOR-NET-T1-234
        1     ITER-II-1
        2     ITER-II-2
        31     NET-T1-323-1
        32     NET-T1-323-2
    Name for the colour printer (-Pc or -PC option) can be set up in the variable COLOR_PRINTER
    or in the file  ~/.color_printer (the variable superseeds the file, the default is $DEFAULT_COLOR_PRINTER)"

#helpstart=3
#helpend=30
#let "helplines= $helpend - $helpstart + 1"


scriptname="$NAME"

psprint=0
#check whether file ends in .ps or .eps. If it does, automatically postscript unless
#text asked for specifically

#procid=$$
#temp_print0=~/temp_print_${procid}

defaultprinterfile=~/defaultprinter
if [ -a ${defaultprinterfile} ]; then
  defaultprintername=`cat ${defaultprinterfile}`
else
#  defaultprintername='a4mj'
  defaultprintername='ITER-II-2'
fi

# Parse the parameters
help=
printername=
a2psoptions=
filelist=
ps_or_txt=
while true; do
    case "$1" in
        -h  )   help=yes;;
        -H  )   help=yes;;
        -a*  )   ps_or_txt=0;;
        -ep*  )   ps_or_txt=1;;
        -l*  )   a2psoptions="${a2psoptions} -l";;
        -p  )   shift; printername=$1;;
        -ps  )   ps_or_txt=1;;
        -pos* )   ps_or_txt=1;;
        -por*  )   a2psoptions="${a2psoptions} -p";;
        -p*  )   printername=`echo "$1" | cut -c3-`;;
        -tum*  )   a2psoptions="${a2psoptions} -t";;
        -t*  )   ps_or_txt=0;;
        -A*  )   ps_or_txt=0;;
        -EP*  )   ps_or_txt=1;;
        -L*  )   a2psoptions="${a2psoptions} -l";;
        -P  )   shift; printername=$1;;
        -PS  )   ps_or_txt=1;;
        -POS*  )   ps_or_txt=1;;
        -P*  )   printername=`echo "$1" | cut -c3-`;;
        -TUM*  )   a2psoptions="${a2psoptions} -t";;
        -T*  )   ps_or_txt=0;;
        -*  )   a2psoptions="${a2psoptions} $1";;
        *   )   filelist="${filelist} $1";;
    esac
    if [ "$2." = "." ]; then
      break
    else
      shift
    fi
done

echo "Parameters parsed" #!!!

#[ ! "${help}." = "." ] && { echo "$scriptname"; tail -n +$helpstart $0 | head -$helplines; exit 32; }

[ ! "${help}." = "." ] && { echo "$Usage"; exit; }

#check to see that printername doesn't start with "-"
check=`echo "${printername}" | cut -c1`
# echo "${scriptname}: check=$check"
[ "${check}." = "-." ] && { echo "${scriptname}: ERROR: printer ${printername} does not exist"; exit 32; }

#translate printername:
if [ "${printername}." = "." ]; then
  printername=${defaultprintername}
else
    case "${printername}" in
      b  )   printername='NET-T1-234';;
      bw  )   printername='mi-2-1';;
      B  )   printername='NET-T1-234';;
      BW  )   printername='NET-T1-234';;
      c | C )   printername="$COLOR_PRINTER";;
      m | M )   printername='a4mj';;
      n | N )   printername='COLOR-NET-T1-234';;
      1  )   printername='ci-2-1';;
      2  )   printername='ci-2-2';;
      31  )   printername='NET-T1-323-1';;
      32  )   printername='NET-T1-323-2';;
      *   )   printername="$COLOR_PRINTER";;
    esac
fi

echo "Printers parsed" #!!!

[ "$printername" = off ] && {
  print -u2 -- "$NAME: printername set to \"off\" - no printing"
  exit
}

#previously netrs uses ethershare lpr, /usr/local/es/lpr, alias lpr_es
#other NET printers were linked to this via alias lpr_es
#now simple lpr works
#prt does not work on NET printers
#iterg can also use ethershare lpr, /usr/local/es/lpr
#other ITER printers use prt
#so use lpr_es -h on NET printers, prt on ITER printers
#ITER printers are accessible form NET or ITER, NET printers are accessible only from NET, e.g. ${NET_SERVER}

#lprscript=/usr/local/es/lpr
a2pscript=/usr/local/bin/a2ps

case "$printername" in
  NET-D1-CAD  )   printer="net";;
  COLOR-NET-T1-234  )   printer="net";;
  NET-T1-234  )   printer="net";;
  NET-T1-323-1  )   printer="net";;
  NET-T1-323-2  )   printer="net";;
  *   )   printer="iter";;
esac

#   check to see if logged in on NET (machines whose name starts with net: netrs, netrs01)

hh=`hostname`
hostnet=`echo $hh | cut -c 1-3`
[ ! $hostnet = "net" ] && hostnet="iter"

[ "$hh" = 'eskimo' ] && printer="$hostnet"

#<<
#echo "${scriptname}: ps_or_txt=${ps_or_txt}"
#echo "${scriptname}: printername=${printername}"
#echo "${scriptname}: printer=${printer}"
#echo "${scriptname}: hostnet=${hostnet}"
#echo "${scriptname}: a2psoptions=${a2psoptions}"
#echo  "\n${scriptname}: files to be printed: ${filelist} "
#>>

i=0
for itemname in ${filelist}; do
  let "i = i + 1"
#  temp_print=${temp_print0}_${i}
  if [ ! -a ${itemname} ]; then
    echo "\n${scriptname}:file ${i} filename=${itemname} DOES NOT EXIST !!! \n"
  else
#    echo "\n${scriptname}:file ${i} filename=${itemname} being printed \n"
#    if ps_or_txt is set, use its value, otherwise determine type (ps or text) from filename
#    if name ends in ".ps" or ".eps", it is postscript file
    if [ "${ps_or_txt}." = "." ]; then
#      psprint=0
#      psid=`echo $itemname | awk 'BEGIN { FS= "." } { print $NF }'`
#      [ "$psid." = "ps." ] && psprint=1
#      [ "$psid." = "eps." ] && psprint=1
      case $itemname in
        ( *.ps | *.eps ) psprint=1;;
        ( *            ) psprint=0;;
      esac
    else
      psprint=${ps_or_txt}
    fi
#    echo "${scriptname}:itemname=${itemname} psprint=${psprint}"
#      prt does not work on NET and on ITER color printer. So use lpr
#      very old: lprscript="prt -P $printername"

    lprscript="lpr -h -P $printername"

#    if [ $printer = "net" ]; then
##   old:  lprscript="lpr_es -h -P $printername"
#      lprscript="lpr -h -P $printername"
#    fi
    if [ $psprint -eq 1 ]; then
      if [ $printer = "iter" ]; then
#           postscript printer iter host either iter or net
        $lprscript $itemname
      else
        if [ $hostnet = "iter" ]; then
#           postscript printer net host iter
#              if host is iter and printer is net must use remote shell
#          rm -f ${temp_print}  >/dev/null 2>&1
#          cp $itemname ${temp_print}
#          rsh ${NET_SERVER} "$lprscript ${temp_print}"
#          rm -f ${temp_print}  >/dev/null 2>&1
          cat "$itemname" | rsh ${NET_SERVER} "$lprscript"
        else
#           postscript printer net host net
          $lprscript $itemname
        fi
      fi
      echo "${scriptname}:file ${i}: $itemname postscript printing: $printername at $printer, host at $hostnet"
    else
      if [ $printer = "iter" ]; then
#           text printer iter host either iter or net
        $a2pscript -m $a2psoptions -H"file $itemname" ${itemname} | $lprscript 2>/dev/null
      else
        if [ $hostnet = "iter" ]; then
#           text printer net host iter
#               if host is iter and printer is net must use remote shell
#          rm -f ${temp_print}  >/dev/null 2>&1
#          cp $itemname ${temp_print}
#          rsh ${NET_SERVER} "$a2pscript -m $a2psoptions -H\"file $itemname\" ${temp_print} | $lprscript 2>/dev/null"
#          rm -f ${temp_print}  >/dev/null 2>&1
          $a2pscript -m $a2psoptions -H"file $itemname" $itemname | rsh ${NET_SERVER} "$lprscript 2>/dev/null"
        else
#           text printer net host net
          $a2pscript -m $a2psoptions -H"file $itemname" ${itemname} | $lprscript 2>/dev/null

        fi
      fi
      echo "${scriptname}:file ${i}: $itemname text       printing: $printername at $printer, host at $hostnet"
    fi
  fi
done
#rm -f ${temp_print0}_*  >/dev/null 2>&1

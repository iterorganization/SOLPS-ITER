#! /bin/csh -f
if ($?LAST10) then
  set FILE=b2.log.last10
else
  set FILE=b2.log
endif
if (-x $SOLPSTOP/bin/$OBJECTCODE/zcat) then
    set ZCAT=$SOLPSTOP/bin/$OBJECTCODE/zcat
else if (-x $SOLPSMASTER/@sys/bin/zcat) then
    set ZCAT=$SOLPSMASTER/@sys/bin/zcat
else
    set ZCAT="gzip --decompress --force --stdout"
endif
$ZCAT -f $FILE |\
  egrep b2bremcore\|b2rad\|totadd\|'ITER.*TIME' |\
  awk '/b2bremcore/{for (i=1;i<=4;i++) {rad[i]=$(i+1)}}\
        /b2radcore/{for (i=1;i<=4;i++) {rad[i]+=$(i+1)}}\
        /totaddee/{add=$2+$3}\
        /TIME/{printf "%e ",$4;for (i=1;i<=4;i++) {printf "%e ",-rad[i]/add};print ""}' |\
  plot xyplot4 'radiated fraction core' 'radiated fraction sol' 'radiated fraction inner divertor' 'radiated fraction outer divertor' 'time' 'frac' $PWD

#! /usr/bin/ksh

#  VERSION : 20.01.98 14:07

alias grep='/bin/grep'
control_file=last_2d_write_input


# Temporary solution

headerlist='SSNIreg_.* imp_rad_0[1-4] SSEEreg_0[1-4] SSEIreg_.*'

NAME="${0##*/}"
Usage="
  $NAME: append the auxiliary data columns taken from 'last_2d_outall' to the summary files.
    This script uses the list of the output files created by 'last_2d_write' command.
    The list of the column headers to be used is, at present, hardwired as:
    $headerlist"

#    The list of the column headers to be used must be specified in the file 'auxiliary columns'
#    in the current directory, the parent directory, or the directory where this script resides.
#    The headers in this file are written one per line, without extra spaces.
#    'Regular expressions' (see 'grep' manual) can be used."

tab="\t"

#  Find the list of headers for the additional data columns


#  Find the control file with filenames to be processed and make the file lists

[ -r "$control_file" ] || {
  print -u2 "$NAME: the control file '$control_file' not found"
  exit 4
}
unset outlist inlist n_out line
exec 3< "$control_file"
while read -u3 u; do {
  let "line=$line+1"
#  echo ">> u :$u:"
  case "$u" in
    ( '##'* ) ;;
    ( '#'*  )
# output filename
      let "n_out=$n_out+1"
      outlist="$outlist summary/${u#\#}"
      ;;
    ( *     )
# specification  of the input file
      [ -z "$n_out" ] && {
        print -u2 "$NAME: wrong format of the control file '$control_file': line $line"
        print -u2 ">>$u<<"
        print -u2 "   The first output file is not specified"
        exit 4
      }
      set -- $u
      [ -z "$3" ] && {
        print -u2 "$NAME: wrong format of the control file '$control_file': line $line"
        print -u2 ">>$u<<"
        print -u2 "   The case directory is not specified"
        exit 4
      }
      case "$1" in
        ( central  )
#  Central storage
          d=/prg/b2/data/kuku/${SOLPSTOP##*/}
          file="$d/src/B2Eirene/$3/last_2dir/last_2d_outall"
          ;;
        ( arch     )
          d="$HOMEMASTER/b2arch"
          file="$d/$3/last_2dir/last_2d_outall"
          ;;
        ( local2*  )
            print -u2 "$NAME: 'local2*' specification is not supported yet. Line $line"
            print -u2 ">>$u<<"
            exit 4
          ;;
        ( scratch* )
            print -u2 "$NAME: 'scratch*' specification is not supported yet. Line $line"
            print -u2 ">>$u<<"
            exit 4
          ;;
        ( *        )
            print -u2 "$NAME: local machine specification is not supported yet. Line $line"
            print -u2 ">>$u<<"
            exit 4
          ;;
      esac
      [ -r "$file" ] && inlist[$n_out]="${inlist[$n_out]} $file" || {
        print -u2 "$NAME: the input file '$file' not found. Line $line"
        print -u2 ">>$u<<"
        exit 4
      }
      ;;
  esac
}; done

#echo "%% outlist :$outlist:"

#  For each output file...

unset n_out n_in bad_set
for outfile in $outlist; do {
  let "n_out=$n_out+1"
#  echo "%% n_out=$n_out;  inlist :${inlist[$n_out]}:"

#  Grab the data from last_b2_outall for each line

  unset j_in content first_header
  for infile in ${inlist[$n_out]}; do {
    let "j_in=$j_in+1"
    unset i header cont
    for h in $headerlist; do {
      set a `grep "$h" "$infile"`
      shift
      while true; do {
        [ -z "$1" ] && break
        [ -z "$2" ] && {
          print -u2 "Unexpected error: odd number of parameters set. Pair $i :$1:, h :$h:"
          print -u2 "Probably, something is wrong with the file $infile"
          bad_set[$n_out]=y
          break 3
# here, we go directly to the next output file
        }
        let "i=$i+1"
        cont="$cont\t$1"
        header="$header\t$2"
        shift 2
      }; done
    }; done
    header="${header#$tab}"
    content[$j_in]="${cont#$tab}"

#  Compare the headers

    [ "$j_in" -eq 1 ] && first_header="$header" || {
      [ -z "$first_header" ] && {
        print -u2 "$NAME: unexpected error. The first header is not set. Line=$line"
        print -u2 ">>$u<<"
        bad_set[$n_out]=y
        break
      }
      [ "$first_header" = "$header" ] || {
        print -u2 "$NAME: the auxiliary headers for the set '$outfile' differ"
        print -u2 "  ==> no columns appended!!!"
        print -u2 "  infile =>$infile<"
        print -u2 "  first  =>$first_header<"
        print -u2 "  current=>$header<"
        bad_set[$n_out]=y
        break
      }
    }
  }; done

#  Append the data columns to the output file

  [ -z "${bad_set[$n_out]}" ] && {
#    echo "%% Append to the file '$outfile'\n"
    mv "$outfile" "$outfile"~ && {
      print "$header"
      i=0; until { let "i=$i+1"; [ "$i" -gt "$j_in" ]; }; do {
        print "${content[$i]}"
      }; done
    } | paste "$outfile"~ - > "$outfile"
  }
}; done

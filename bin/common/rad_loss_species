#! /bin/csh -f
if ($?LAST10) then
  set FILE=b2.log.last10
else
  set FILE=b2.log
endif
if (-x $SOLPSTOP/bin/$OBJECTCODE/zcat) then
    set ZCAT=$SOLPSTOP/bin/$OBJECTCODE/zcat
else if (-x $SOLPSMASTER/@sys/bin/zcat) then
    set ZCAT=$SOLPSMASTER/@sys/bin/zcat
else
    set ZCAT="gzip --decompress --force --stdout"
endif
$ZCAT -f $FILE | \
  egrep 'b2bremcore,|b2radcore,|ITER.*TIME' | \
  awk '/b2bremcore,/{NC=0}\
       /b2radcore,/{NC=NC+1;b2rad[NC]=$2+$3+$4+$5}\
       /ITER.*TIME/{printf "%s ",$4; for (i=1;i<=NC;i+=2) printf "%s ",b2rad[i]+b2rad[i+1]; printf "\n"}' | \
  plot xyplot$#argv $argv "Time" "rad_loss_species(MW)" $PWD

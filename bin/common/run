#!/bin/sh
#
	
	if [ -f job.no ]; then
		JobNumber=`jobcount job.no 0`
	else
		echo "   There must be a file job.no."
		exit
	fi

	if [ $# -gt 0 ]; then
 		if [ $1 = batch ]; then 
			echo "   Running job in batch mode ..."
			outputfile=batchjob.${JobNumber}
			echo "   ... job output to "${outputfile}
			echo "   ... code output to "output.${JobNumber}
#		    qsub -x -eo -o ${outputfile} ${OBJECTCODE}/nqs.job
			qsub -eo ${outputfile} ${OBJECTCODE}/nqs.job
		else 
			echo "   Unknown argument: "$1" ..."
			echo "   ... running job interactively ..."
    		${OBJECTCODE}/b2obj $* 
		fi
	else 
		echo "   Running job interactively ..."
    	${OBJECTCODE}/b2obj $* 
	fi 
    exit


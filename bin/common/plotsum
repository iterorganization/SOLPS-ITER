      ps4 summary/${PLOT_IT_STEM}.ps -n 1 2 3
      print_list="dt_sprd4"
    }
  }
  [ -z "$NO_PLOT" ] && {
    for f in $print_list; do {
      [ -s "summary/$f.ps" ] && print_file -P$PRINTER "summary/$f.ps" &
    }; done
  }
  exit
}


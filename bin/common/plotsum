    [ -s filelist.sum ] && {
#      DEFINES='-DNSRANGE="xrange=['"${NS_RANGE}]\""' -DTHRANGE="xrange=['"${THRPT_RANGE}]\""' -DZRANGE="xrange=['"${ZEFF_RANGE}]\""' -DCFRANGE="xrange=['"${COREFLX_RANGE}]\""
      DEFINES='-DNSRANGE="xrange=['"${NS_RANGE}]\""' -DTHRANGE="xrange=['"${THRPT_RANGE}]\""' -DZRANGE="yrange=['"${ZEFF_RANGE}]\""' -DCFRANGE="xrange=['"${COREFLX_RANGE}]\""' -DPNRANGE="xrange=['"${PNEU_RANGE}]\""
      # hdp: for data spread want normal runs to use rms box values and data spread cases to use standard

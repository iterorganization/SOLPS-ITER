    # with suffix _z to filenames, so the following if not necessary then
    if [ -z "$RMS" ]; then
	sed 's/$/ @=@/' < filelist.sum > filelist.tmh
    else
	cat filelist.sum | sed 's/$/ @=@/' | sed s/"${varsuffix} "/" "/ > filelist.tmh

#! /bin/tcsh -f
cat > tmp.$$.tmp
ave.awk < tmp.$$.tmp | cat - tmp.$$.tmp | \
  awk '\
    BEGIN{CNT=-1}\
    /^[#]/{print $0}\
    /^[^#]/&&CNT>=0{for (j=1;j<=NF;j++) {VAL[j]=VAL[j]+($j-AVE[j])**2};CNT=CNT+1;OLDNF=NF}\
    /^[^#]/&&CNT<0{for (j=1;j<=NF;j++) {AVE[j]=$j};CNT=CNT+1;OLDNF=NF}\
    END{for (j=1;j<=OLDNF;j++) {printf "%s ",sqrt(VAL[j]/(CNT-1))};printf "\n"}'
rm tmp.$$.tmp

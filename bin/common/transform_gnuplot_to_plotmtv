#! /bin/csh -f
set nx=`cat $1 | awk '/^[^#]/{print $1}' | sort -n | uniq | wc -l`
set ny=`cat $1 | awk '/^[^#]/{print $2}' | sort -n | uniq | wc -l`
echo '$ data=contour'
echo "% NY = $nx ylabel='time' ygrid=t"
cat $1 | awk '/^[^#]/{print $1+0}' | sort -g +0 -1 | uniq
echo "% NX = $ny xlabel='distance' xgrid=t"
cat $1 | awk '/^[^#]/{print $2+0}' | sort -g +0 -1 | uniq
if ($3 == "lin") then
  echo "% contfill=t equalscale=f nsteps=20 toplabel=\'$2\'"
else
  echo "% contfill=t equalscale=f logsteps=10 toplabel=\'$2\'"
endif
cat $1 | awk '/^[^#]/{print $3+0}'
echo '$ end'

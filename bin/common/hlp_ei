#! /bin/ksh

#  VERSION : 20.04.96 14:02

f=$1; shift
ff=`basename $0`
case "$f" in
     1  )   l='$2,$3,$4,$5'; n=4;;
     2  )   l='$6,$7,$8,$9'; n=4;;
     3  )   l='$10,$11,$12,$13'; n=4;;
     c  )   l='$2,$6,$10'; n=3;;
     s  )   l='$3,$7,$11'; n=3;;
     i  )   l='$4,$8,$12'; n=3;;
     o  )   l='$5,$9,$13'; n=3;;
     t  )   l='t1,t2,t3'; n=3;;
     *  )   echo "Illegal option :$f:"; exit 4;;
esac

case "$f" in
    *[1-3]  )   legend='core sol divin divout';;
    *       )   legend='1 2 3';;
esac

if [ "$1" = "" ]; then
  if ($?LAST10) then
  set FILE=b2.log.last10
else
  set FILE=b2.log
endif
$SOLPSMASTER/@sys/bin/zcat -f $FILE | \
    egrep $ff | \
    awk "/$ff/{t1=\$2+\$3+\$4+\$5; t2=\$6+\$7+\$8+\$9; t3=\$10+\$11+\$12+\$13; \
        print $l}" | \
    nl | \
    plot xyplot$n $legend "iteration number" "${ff}_$f" $PWD
else
  if ($?LAST10) then
  set FILE=b2.log.last10
else
  set FILE=b2.log
endif
$SOLPSMASTER/@sys/bin/zcat -f $FILE | \
    egrep $ff | \
    awk "/$ff/{t1=\$2+\$3+\$4+\$5; t2=\$6+\$7+\$8+\$9; t3=\$10+\$11+\$12+\$13; \
        print $l}" | \
    nl | \
    tail -$1 | \
    plot xyplot$n $legend "iteration number" "${ff}_$f" $PWD
fi

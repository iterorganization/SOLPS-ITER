/Ov
{/strn exch def
 /ispc exch def
 /str1 1 string def
  strn
  {/code exch def
   /chr str1 0 code put str1 def
   0 ispc neg rmoveto
   gsave
   chr stringwidth pop 2 div neg
   0 rmoveto
   chr false charpath stroke
   grestore
  } forall
} bind def

/Oh
{/strn exch def
 /ispc exch def
 /tstr 1 string def
 strn
   {
    /code exch def
    /chr tstr 0 code put tstr def
    chr false charpath
    currentpoint
    /yt exch def /xt exch def
    stroke
    xt ispc add yt moveto
   } forall
 } bind def

